[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/Mylab-yo/be-yours-mylab.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/master
	github-pr-base-branch = "Mylab-yo#be-yours-mylab#master"
	vscode-merge-base = origin/master
[branch "feature/stock-mrp-setup"]
	github-pr-base-branch = "Mylab-yo#be-yours-mylab#main"
	vscode-merge-base = origin/master
	remote = origin
	merge = refs/heads/feature/stock-mrp-setup
[branch "feature/bulk-configurator-fortifiant-pricing"]
	github-pr-base-branch = "Mylab-yo#be-yours-mylab#feature/stock-mrp-setup"
	vscode-merge-base = origin/feature/stock-mrp-setup
[branch "_scratch_cp"]
	remote = origin
	merge = refs/heads/master
	vscode-merge-base = origin/master
[branch "master"]
	remote = origin
	merge = refs/heads/master
	vscode-merge-base = origin/master
