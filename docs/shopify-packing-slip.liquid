<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Bon de livraison {{ order.name }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    @page { size: A4; margin: 14mm 14mm 14mm 14mm; }
    * { box-sizing: border-box; }
    body {
      font-family: 'DM Sans', Arial, sans-serif;
      font-size: 9pt;
      color: #1a1a1a;
      margin: 0;
      padding: 0;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 600; margin: 0; color: #1a1a1a; }
    table { border-collapse: collapse; width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* ===== Brand header (logo + raison sociale) ===== */
    .brand-bar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 8pt;
      margin-bottom: 10pt;
      border-bottom: 0.5pt solid #1a1a1a;
    }
    .brand-bar .company {
      font-size: 8.5pt;
      line-height: 1.45;
      text-align: right;
      color: #444;
    }
    .brand-bar .company strong { color: #1a1a1a; font-size: 9.5pt; }
    .brand-bar img { height: 72px; width: auto; display: block; }

    /* ===== BL header ===== */
    .doc-head {
      display: flex;
      justify-content: space-between;
      border-bottom: 1pt solid #1a1a1a;
      padding-bottom: 8pt;
      margin-bottom: 10pt;
    }
    .doc-head h2 { font-size: 22pt; line-height: 1.1; }
    .doc-head .ref { font-size: 11pt; font-weight: 700; margin-top: 2pt; }
    .doc-head .meta { font-size: 9pt; color: #555; margin-top: 2pt; }
    .doc-head .ship-to { text-align: right; font-size: 9pt; line-height: 1.45; }
    .doc-head .ship-to .label { font-weight: 700; color: #1a1a1a; margin-bottom: 3pt; display: block; }

    /* ===== Summary badge ===== */
    .badge {
      background: #f0f0f0;
      color: #1a1a1a;
      padding: 6pt 10pt;
      border-radius: 4pt;
      display: inline-block;
      margin-bottom: 12pt;
      font-weight: 700;
    }

    /* ===== Section heading ===== */
    h3.section {
      font-family: 'Cormorant Garamond', serif;
      font-size: 14pt;
      margin-top: 8pt;
      margin-bottom: 4pt;
    }

    /* ===== Products table ===== */
    table.products thead tr {
      background: #f0f0f0;
      border-bottom: 1pt solid #1a1a1a;
    }
    table.products th {
      text-align: left;
      padding: 4pt;
      font-size: 9pt;
      font-weight: 700;
    }
    table.products th.num { text-align: right; }
    table.products td {
      padding: 3pt 4pt;
      border-bottom: 0.5pt solid #e5e0d0;
      font-size: 9pt;
      vertical-align: top;
    }
    table.products td.num { text-align: right; }
    table.products tfoot td {
      border-top: 1pt solid #1a1a1a;
      border-bottom: none;
      padding: 4pt;
      font-weight: 700;
    }
    .variant { color: #777; font-size: 8.5pt; display: block; margin-top: 1pt; }
    .props { color: #777; font-size: 8pt; display: block; margin-top: 1pt; font-style: italic; }

    /* ===== Note ===== */
    .order-note {
      margin-top: 10pt;
      padding: 6pt 8pt;
      background: #f7f5f1;
      border-left: 2pt solid #1a1a1a;
      font-size: 8.5pt;
    }

    /* ===== Signature ===== */
    .signature {
      margin-top: 20pt;
      border: 0.5pt solid #1a1a1a;
      padding: 8pt;
      font-size: 9pt;
      page-break-inside: avoid;
    }
    .signature .line { margin-bottom: 6pt; }
    .signature .pad { height: 28pt; }

    /* ===== Footer ===== */
    .legal-footer {
      margin-top: 14pt;
      padding-top: 6pt;
      border-top: 0.3pt solid #ccc;
      font-size: 7.5pt;
      color: #888;
      text-align: center;
      line-height: 1.5;
    }
  </style>
</head>
<body>

  {% comment %} ============ BRAND BAR ============ {% endcomment %}
  <div class="brand-bar">
    <img src="https://cdn.shopify.com/s/files/1/0924/1922/7982/files/Logo-rond-noir-sans-fond.png?v=1773170347" alt="MY.LAB">
    <div class="company">
      <strong>SARL STARTEC</strong> &mdash; MY.LAB<br>
      231 Avenue de la Voguette, 84300 Cavaillon &mdash; France<br>
      04 85 69 33 47 &middot; contact@mylab-shop.com &middot; mylab-shop.com
    </div>
  </div>

  {% comment %} ============ DOC HEADER ============ {% endcomment %}
  <div class="doc-head">
    <div>
      <h2>Bon de livraison</h2>
      <div class="ref">{{ order.name }}</div>
      <div class="meta">Date : {{ order.created_at | date: "%d/%m/%Y" }}</div>
      {% if order.shipping_method %}
        <div class="meta">Transporteur : {{ order.shipping_method.title }}</div>
      {% endif %}
    </div>
    <div class="ship-to">
      <span class="label">Livré à</span>
      {% if order.shipping_address %}
        {{ order.shipping_address.name }}<br>
        {% if order.shipping_address.company != blank %}{{ order.shipping_address.company }}<br>{% endif %}
        {{ order.shipping_address.address1 }}<br>
        {% if order.shipping_address.address2 != blank %}{{ order.shipping_address.address2 }}<br>{% endif %}
        {{ order.shipping_address.zip }} {{ order.shipping_address.city }}<br>
        {{ order.shipping_address.country }}
        {% if order.shipping_address.phone != blank %}<br>Tél. {{ order.shipping_address.phone }}{% endif %}
      {% else %}
        {{ order.billing_address.name }}<br>
        {{ order.billing_address.address1 }}<br>
        {{ order.billing_address.zip }} {{ order.billing_address.city }}<br>
        {{ order.billing_address.country }}
      {% endif %}
    </div>
  </div>

  {% comment %} ============ SUMMARY BADGE ============ {% endcomment %}
  {% assign total_qty = 0 %}
  {% assign total_grams = 0 %}
  {% for line in order.line_items %}
    {% assign total_qty = total_qty | plus: line.quantity %}
    {% assign total_grams = total_grams | plus: line.grams | times: line.quantity %}
  {% endfor %}
  {% assign total_kg = total_grams | divided_by: 1000.0 %}

  <div class="badge">
    {{ total_qty }} article{% if total_qty > 1 %}s{% endif %}
    &mdash; {{ total_kg | round: 2 }} kg
    {% if order.shipping_method %} &mdash; {{ order.shipping_method.title }}{% endif %}
  </div>

  {% comment %} ============ PRODUCTS TABLE ============ {% endcomment %}
  <h3 class="section">Récapitulatif produits</h3>
  <table class="products">
    <thead>
      <tr>
        <th style="width: 18%;">Référence</th>
        <th>Désignation</th>
        <th class="num" style="width: 10%;">Qté</th>
        <th class="num" style="width: 14%;">Poids unit.</th>
        <th class="num" style="width: 14%;">Poids total</th>
      </tr>
    </thead>
    <tbody>
      {% for line in order.line_items %}
        {% assign unit_kg = line.grams | divided_by: 1000.0 %}
        {% assign line_kg = line.grams | times: line.quantity | divided_by: 1000.0 %}
        <tr>
          <td>{{ line.sku }}</td>
          <td>
            {{ line.title }}
            {% if line.variant_title and line.variant_title != 'Default Title' %}
              <span class="variant">{{ line.variant_title }}</span>
            {% endif %}
            {% if line.properties %}
              {% for p in line.properties %}
                {% unless p.first contains '_' or p.last == blank %}
                  <span class="props">{{ p.first }} : {{ p.last }}</span>
                {% endunless %}
              {% endfor %}
            {% endif %}
          </td>
          <td class="num">{{ line.quantity }}</td>
          <td class="num">{{ unit_kg | round: 2 }} kg</td>
          <td class="num">{{ line_kg | round: 2 }} kg</td>
        </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="2">Total</td>
        <td class="num">{{ total_qty }}</td>
        <td></td>
        <td class="num">{{ total_kg | round: 2 }} kg</td>
      </tr>
    </tfoot>
  </table>

  {% comment %} ============ ORDER NOTE (si présente) ============ {% endcomment %}
  {% if order.note != blank %}
    <div class="order-note">
      <strong>Note de commande :</strong> {{ order.note }}
    </div>
  {% endif %}

  {% comment %} ============ SIGNATURE ============ {% endcomment %}
  <div class="signature">
    <div class="line"><strong>Reçu en bon état par :</strong> ____________________________</div>
    <div class="line"><strong>Date :</strong> ________________ &nbsp;&nbsp;&nbsp; <strong>Signature :</strong></div>
    <div class="pad"></div>
  </div>

  {% comment %} ============ LEGAL FOOTER ============ {% endcomment %}
  <div class="legal-footer">
    SARL STARTEC au capital variable de 300 000 € &middot; SIRET 499 500 668 00060 &middot; RCS Avignon<br>
    231 Avenue de la Voguette, 84300 Cavaillon &middot; mylab-shop.com
  </div>

</body>
</html>
