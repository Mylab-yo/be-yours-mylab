{%- comment -%}
  MY.LAB branding override for Shopify "Order confirmation" notification.

  HOW TO APPLY:
  1. Shopify Admin > Paramètres > Notifications > Commandes > Confirmation de commande > Modifier le code.
  2. Dans le template actuel, localiser le bloc :
       <head>
         <title>{{ email_title }}</title>
         ...
         <style>
           .button__cell { background: {{ shop.email_accent_color }}; }
           .actions-buttons .button__cell--primary { background-color: {{ shop.email_accent_color }}; }
           a, a:hover, a:active, a:visited { color: {{ shop.email_accent_color }}; }
         </style>
       </head>
  3. Remplacer intégralement ce bloc <head>...</head> par celui ci-dessous.
  4. Répéter l'opération pour les autres notifications qu'on veut aligner
     (Shipping confirmation, Order invoice, Order refund, etc.) — le bloc est réutilisable.

  NOTES EMAIL-SAFE :
  - Google Fonts (Cormorant Garamond, DM Sans) chargées via <link> ; Outlook ignore et
    utilise les fallbacks serif / Helvetica — le rendu reste propre.
  - Palette alignée sur assets/mylab-product.css (--ml-black #111, --ml-off #F5F4F2, etc.).
  - L'accent color Shopify (shop.email_accent_color) est ignoré volontairement —
    on force le noir MY.LAB pour garantir la cohérence avec le site.
{%- endcomment -%}

<head>
  <title>{{ email_title }}</title>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width">
  <link rel="stylesheet" type="text/css" href="/assets/notifications/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ============ MY.LAB email branding ============ */
    body, table, td, p, a, li, span, h1, h2, h3, h4, div {
      font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #111111;
    }
    body {
      background: #F5F4F2;
      -webkit-font-smoothing: antialiased;
    }
    .body {
      background: #F5F4F2;
    }
    .header, .header__cell {
      background: #FFFFFF;
    }
    .content, .content__cell,
    .section, .section__cell {
      background: #FFFFFF;
    }
    .shop-name__text,
    .shop-name__text a,
    h1, h2, h3, h4 {
      font-family: 'Cormorant Garamond', 'Georgia', 'Times New Roman', serif !important;
      color: #111111 !important;
      font-weight: 500;
      letter-spacing: 0.3px;
    }
    h2 { font-size: 28px; line-height: 1.2; margin: 0 0 12px; }
    h3 { font-size: 20px; line-height: 1.3; margin: 16px 0 8px; }
    .order-number__text,
    .po-number__text {
      font-family: 'DM Sans', Helvetica, Arial, sans-serif !important;
      color: #555555 !important;
      font-size: 13px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    p {
      font-size: 15px;
      line-height: 1.55;
      color: #333333;
    }
    /* ============ Buttons (override Shopify accent) ============ */
    .button__cell,
    .actions-buttons .button__cell--primary {
      background: #111111 !important;
      background-color: #111111 !important;
      border-radius: 2px;
    }
    .button__cell a,
    .button__text {
      font-family: 'DM Sans', Helvetica, Arial, sans-serif !important;
      color: #FFFFFF !important;
      font-weight: 500;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      font-size: 13px;
    }
    /* Hide "Track with Shop App" button — clients B2B FR ne l'utilisent pas */
    .button__cell--shop-app,
    .button__cell--separator {
      display: none !important;
    }
    .actions-buttons .button__cell--primary {
      width: 100% !important;
      display: block !important;
    }
    .button__shop-logo {
      display: none !important;
    }
    /* ============ Links ============ */
    a, a:hover, a:active, a:visited {
      color: #111111;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .link__cell,
    .link__cell a {
      color: #555555 !important;
      font-size: 14px;
    }
    /* ============ Order list ============ */
    .order-list__item-title {
      font-family: 'DM Sans', Helvetica, Arial, sans-serif !important;
      color: #111111 !important;
      font-weight: 500;
      font-size: 15px;
    }
    .order-list__item-variant {
      color: #888888 !important;
      font-size: 13px;
    }
    .order-list__item-price {
      font-family: 'DM Sans', Helvetica, Arial, sans-serif !important;
      color: #111111 !important;
      font-weight: 500;
    }
    .order-list__item-original-price {
      color: #AAAAAA !important;
    }
    .order-list__item-refunded {
      color: #888888 !important;
      font-style: italic;
    }
    .order-list__delivery-method-type-separator {
      border: none;
      border-top: 1px solid #E5E3DF;
      margin: 20px 0;
    }
    .order-list__delivery-method-type {
      font-family: 'Cormorant Garamond', Georgia, serif !important;
      color: #111111 !important;
      font-size: 18px;
      margin: 16px 0 8px;
    }
    .order-list__estimated-delivery {
      color: #555555 !important;
      font-size: 14px;
    }
    /* ============ Discounts tag ============ */
    .order-list__item-discount-allocation {
      color: #2D4A2D !important;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.3px;
    }
    /* ============ Totals & section headings ============ */
    .subtotal-line__title,
    .subtotal-line__value {
      font-family: 'DM Sans', Helvetica, Arial, sans-serif !important;
      color: #555555 !important;
      font-size: 14px;
    }
    .subtotal-line--grand-total .subtotal-line__title,
    .subtotal-line--grand-total .subtotal-line__value,
    .subtotal-line--grand-total strong {
      color: #111111 !important;
      font-size: 18px !important;
      font-weight: 600 !important;
    }
    .subtotal-line__small-text {
      color: #888888 !important;
      font-size: 12px;
    }
    /* ============ Addresses / customer info ============ */
    .customer-info__item-title {
      font-family: 'Cormorant Garamond', Georgia, serif !important;
      color: #111111 !important;
      font-size: 16px;
      font-weight: 600;
    }
    .customer-info__item-content {
      color: #555555 !important;
      font-size: 14px;
      line-height: 1.5;
    }
    /* ============ Footer ============ */
    .footer__cell {
      background: #111111 !important;
      color: #FFFFFF !important;
      padding: 28px 20px !important;
    }
    .footer__cell,
    .footer__cell p,
    .footer__cell a,
    .footer__cell span {
      color: #FFFFFF !important;
      font-size: 13px;
    }
    .footer__cell a {
      text-decoration: underline;
    }
    /* ============ Mobile ============ */
    @media only screen and (max-width: 600px) {
      h2 { font-size: 24px; }
      .button__text { font-size: 12px; }
      .order-list__item-title { font-size: 14px; }
    }
  </style>
</head>
