# ── Miroir RAG maison — copie ce fichier en `.env` et remplis les valeurs ──

# Accès SFTP au VPS (mêmes creds que ton .env.vps habituel) — pour tirer les docs
VPS_HOST=82.25.112.124
VPS_PORT=22
VPS_USER=root
VPS_PASS=__voir_ton_.env.vps__

# Ton AnythingLLM LOCAL (sur ce PC maison)
LOCAL_ANYTHINGLLM_URL=http://127.0.0.1:3001
# Clé générée dans l'UI locale : Settings → Tools → Developer API → Generate New API Key
LOCAL_ANYTHINGLLM_KEY=__colle_ta_cle_locale__

# Workspace cible (créé automatiquement s'il n'existe pas)
WORKSPACE=mylab-kb

# ── Miroir skills + mémoires (mirror_skills_memory_from_vps.py) ──
# Réutilise les mêmes creds VPS_* ci-dessus. Tout est optionnel (valeurs par défaut pip ~/.hermes).
# Dossiers cibles du Hermes maison (où il LIT ses skills + mémoires) :
#   pip/llama.cpp : ~/.hermes/skills  et  ~/.hermes/memories
#   Docker        : le dossier hôte monté sur /opt/data du conteneur (ex. /root/.hermes)
# HERMES_SKILLS_DIR=C:\Users\<toi>\.hermes\skills
# HERMES_MEMORIES_DIR=C:\Users\<toi>\.hermes\memories
# Dossier Hermes côté VPS (hôte, PAS /opt/data qui n'existe que dans le conteneur) :
# VPS_HERMES_DIR=/root/.hermes
# Skills MyLab à mirrorer (par défaut la liste connue ; ajoute les nouveaux ici, séparés par virgule) :
# HERMES_SKILLS_INCLUDE=check-ca,check-customer,check-order,check-stock,faire-of,gerer-bl,mylab-rag,mylab-chatbot-ops,mylab-printer-ops,n8n-workflow-ops,relance-impayes
