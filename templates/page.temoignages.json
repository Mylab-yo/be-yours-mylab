    "temoignage_aurelien": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"display:flex;flex-wrap:wrap;gap:2rem;align-items:center;max-width:1100px;margin:0 auto;\">\n  <div style=\"flex:1 1 500px;min-width:300px;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.12);\">\n    <video controls playsinline preload=\"metadata\" style=\"width:100%;height:auto;display:block;\">\n      <source src=\"{{ 'montage-bonhomme-v4_ygCa9teq.mp4' | file_url }}\" type=\"video/mp4\">\n    </video>\n  </div>\n  <div style=\"flex:1 1 400px;min-width:280px;padding:1rem 0;\">\n    <p style=\"font-size:.85rem;text-transform:uppercase;letter-spacing:2px;color:#c5a467;margin-bottom:.5rem;font-weight:600;\">Témoignage 01</p>\n    <h2 style=\"font-size:2rem;margin:0 0 .5rem;font-family:'Cormorant Garamond',serif;\">Aurélien</h2>\n    <p style=\"font-size:1rem;color:#c5a467;font-weight:600;margin-bottom:1rem;\">Fondateur de Bonhomme Paris</p>\n    <p style=\"font-size:1.05rem;line-height:1.7;color:#333;\">Créateur de Bonhomme Paris, il commercialise ses produits dans ses 7 salons. Une marque masculine forte, portée par des formules MY.LAB de qualité professionnelle.</p>\n    <a href=\"https://www.instagram.com/bonhomme_paris/\" target=\"_blank\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;gap:.5rem;margin-top:1.5rem;padding:.75rem 1.5rem;background:#1a1a1a;color:#fff;text-decoration:none;border-radius:50px;font-size:.9rem;font-weight:500;transition:background .3s;\">Voir sur Instagram →</a>\n  </div>\n</div>",
        "full_width": false,
        "show_divider": false,
        "padding_top": 60,
        "padding_bottom": 20
      }
    },
    "temoignage_amandine": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"display:flex;flex-wrap:wrap-reverse;gap:2rem;align-items:center;max-width:1100px;margin:0 auto;\">\n  <div style=\"flex:1 1 400px;min-width:280px;padding:1rem 0;\">\n    <p style=\"font-size:.85rem;text-transform:uppercase;letter-spacing:2px;color:#c5a467;margin-bottom:.5rem;font-weight:600;\">Témoignage 02</p>\n    <h2 style=\"font-size:2rem;margin:0 0 .5rem;font-family:'Cormorant Garamond',serif;\">Amandine</h2>\n    <p style=\"font-size:1rem;color:#c5a467;font-weight:600;margin-bottom:1rem;\">Salon de Coiffure — Cannes</p>\n    <p style=\"font-size:1.05rem;line-height:1.7;color:#333;\">Gérante de son salon de coiffure à Cannes, elle a développé sa marque depuis 2 ans. Une réussite qui montre qu'avec MY.LAB, créer sa propre gamme capillaire est accessible à tous les professionnels.</p>\n    <a href=\"https://www.instagram.com/amandine_private_salon/\" target=\"_blank\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;gap:.5rem;margin-top:1.5rem;padding:.75rem 1.5rem;background:#1a1a1a;color:#fff;text-decoration:none;border-radius:50px;font-size:.9rem;font-weight:500;transition:background .3s;\">Voir sur Instagram →</a>\n  </div>\n  <div style=\"flex:1 1 500px;min-width:300px;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.12);\">\n    <video controls playsinline preload=\"metadata\" style=\"width:100%;height:auto;display:block;\">\n      <source src=\"{{ 'reel-mylab-interview2_MiP9420u.mp4' | file_url }}\" type=\"video/mp4\">\n    </video>\n  </div>\n</div>",
