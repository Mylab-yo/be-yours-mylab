      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"display:flex;flex-wrap:wrap;gap:2rem;align-items:center;max-width:1100px;margin:0 auto;\">\n  <div style=\"flex:1 1 500px;min-width:300px;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.12);\">\n    <video controls playsinline preload=\"metadata\" style=\"width:100%;height:auto;display:block;\">\n      <source src=\"{{ 'itw-minh_DbGJg6mw.mp4' | file_url }}\" type=\"video/mp4\">\n    </video>\n  </div>\n  <div style=\"flex:1 1 400px;min-width:280px;padding:1rem 0;\">\n    <p style=\"font-size:.85rem;text-transform:uppercase;letter-spacing:2px;color:#c5a467;margin-bottom:.5rem;font-weight:600;\">Témoignage 03</p>\n    <h2 style=\"font-size:2rem;margin:0 0 .5rem;font-family:'Cormorant Garamond',serif;\">Minh</h2>\n    <p style=\"font-size:1rem;color:#c5a467;font-weight:600;margin-bottom:1rem;\">Professionnel des Cheveux — Paris</p>\n    <p style=\"font-size:1.05rem;line-height:1.7;color:#333;\">Minh travaille tous les jours avec ses propres produits MY.LAB, et il en est absolument ravi. Une collaboration au quotidien qui prouve la qualité de nos formules professionnelles.</p>\n    <a href=\"https://www.instagram.com/minh.lv.paris/\" target=\"_blank\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;gap:.5rem;margin-top:1.5rem;padding:.75rem 1.5rem;background:#1a1a1a;color:#fff;text-decoration:none;border-radius:50px;font-size:.9rem;font-weight:500;transition:background .3s;\">Voir sur Instagram →</a>\n  </div>\n</div>",
