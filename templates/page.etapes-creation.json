            "heading": "De l\u2019essai \u00e0 la commercialisation",
            "heading_size": "h1",
            "heading_tag": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>MY.LAB vous accompagne de A \u00e0 Z dans la cr\u00e9ation de votre marque de cosm\u00e9tique capillaire. D\u00e9couvrez nos formules, validez votre dossier r\u00e9glementaire, personnalisez vos \u00e9tiquettes et commandez en toute autonomie.</p>"
          }
        }
      },
      "block_order": ["subheading", "heading", "text"],
      "settings": {
        "text_alignment": "center",
        "narrow": true,
        "padding_top": 60,
        "padding_bottom": 40
