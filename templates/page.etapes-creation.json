{
  "sections": {
    "banner": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Les étapes pour créer votre marque capillaire",
            "heading_size": "h0",
            "heading_tag": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Lancez-vous dans l\u2019aventure dès aujourd\u2019hui en suivant nos 4 étapes simples pour créer votre propre marque de cosmétique capillaire.<\/p>",
            "text_size": "typeset2"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Découvrir la boutique",
            "button_link": "shopify:\/\/collections\/all",
            "button_style_secondary": false,
            "button_alt_label": "Nous contacter",
            "button_alt_link": "shopify:\/\/pages\/contact",
            "button_alt_style_secondary": true
          }
        }
      },
      "block_order": ["heading", "text", "button"],
      "settings": {
        "image_height": "medium",
        "desktop_text_position": "center",
        "show_text_box": true,
        "mobile_text_position": "center",
        "colors_overlay_opacity": 40,
        "colors_overlay": "#000000",
        "colors_text": "#ffffff",
        "colors_button_background": "#ffffff",
        "colors_button_label": "#000000",
        "padding_top": 0,
        "padding_bottom": 0
