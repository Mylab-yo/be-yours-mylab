    "etapes_timeline": {
      "type": "timeline",
      "blocks": {
        "step_1": {
          "type": "timeline_item",
          "settings": {
            "date": "ÉTAPE 01",
            "text": "<p><strong>Essayez nos produits<\/strong><\/p><p>Découvrez et testez nos formules capillaires via la boutique en ligne. Shampooings, après-shampooings, masques, soins… Trouvez les formules qui correspondent à votre projet.<\/p>",
            "image_alt": "",
            "source_link": "shopify:\/\/pages\/la-boutique-my-lab",
            "source_text": "Voir la boutique",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "step_2": {
          "type": "timeline_item",
          "settings": {
            "date": "ÉTAPE 02",
            "text": "<p><strong>Dossier cosmétologique<\/strong><\/p><p>Notre équipe enregistre votre compte, dépose votre marque sur le CPNP et crée vos codes-barres pour une mise en conformité totale.<\/p>",
            "image_alt": "",
            "source_link": "",
            "source_text": "",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "step_3": {
          "type": "timeline_item",
          "settings": {
            "date": "ÉTAPE 03",
            "text": "<p><strong>Personnalisez votre étiquette<\/strong><\/p><p>3 options : le design MY.LAB gratuit, nos modèles personnalisables, ou une création sur mesure unique à votre image.<\/p>",
            "image_alt": "",
            "source_link": "",
            "source_text": "",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "step_4": {
          "type": "timeline_item",
          "settings": {
            "date": "ÉTAPE 04",
            "text": "<p><strong>Commandez en autonomie<\/strong><\/p><p>Accédez à la boutique professionnelle et constituez votre gamme à partir de 6 unités par référence. Simple, rapide et efficace.<\/p>",
            "image_alt": "",
            "source_link": "",
            "source_text": "",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
      },
      "block_order": [
        "step_1",
        "step_2",
        "step_3",
        "step_4"
      ],
