    "testimonials_section": {
      "type": "testimonials",
      "blocks": {
        "t_aurelien": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>Créateur de Bonhomme Paris, il commercialise ses produits dans ses 7 salons. Une marque masculine forte, portée par des formules MY.LAB de qualité professionnelle.<\/p>",
            "author": "Aurélien — Fondateur de Bonhomme Paris",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "t_amandine": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>Gérante de son salon de coiffure à Cannes, elle a développé sa marque depuis 2 ans. Une réussite qui montre qu'avec MY.LAB, créer sa propre gamme capillaire est accessible à tous les professionnels.<\/p>",
            "author": "Amandine — Salon de Coiffure, Cannes",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "t_minh": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>Minh travaille tous les jours avec ses propres produits MY.LAB, et il en est absolument ravi. Une collaboration au quotidien qui prouve la qualité de nos formules professionnelles.<\/p>",
            "author": "Minh — Professionnel des Cheveux, Paris",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
      },
      "block_order": [
        "t_aurelien",
        "t_amandine",
        "t_minh"
