eft","speed":1.6,"show_divider":false,"use_custom_colors":true,"colors_icon":"#f1ff34","colors_text":"#212326","colors_background":"#f1ff34","gradient_background":"","padding_top":28,"padding_bottom":28}},"1653722143884a90ea":{"type":"guarantees","blocks":{"16537221439f2cd929-0":{"type":"guarantee","settings":{"icon":"leaf","icon_size":"medium","custom_icon":"","title":"Clean Skincare","title_size":"h4","text":"<p>Clean and natural skincare with safe and transparent ingredients<\/p>"}},"16537221439f2cd929-1":{"type":"guarantee","settings":{"icon":"globe","icon_size":"medium","custom_icon":"","title":"European Delivery","title_size":"h4","text":"<p>Fast delivery options with tracking<br\/>No EU import duties<\/p>"}},"41d9f7be-7316-4bd4-969e-72810a04584a":{"type":"guarantee","settings":{"icon":"recycle","icon_size":"medium","custom_icon":"","title":"Sustainability","title_size":"h4","text":"<p>Our signature shipping boxes are fully recyclable and biodegradable<\/p>"}},"2f066833-7abc-4a6e-a507-515b82f94d13":{"type":"guarantee","settings":{"icon":"shield","icon_size":"medium","custom_icon":"","title":"Authorized Retailer","title_size":"h4","text":"<p>We are an authorized retailer for all the brands we carry<\/p>"}}},"block_order":["16537221439f2cd929-0","16537221439f2cd929-1","41d9f7be-7316-4bd4-969e-72810a04584a","2f066833-7abc-4a6e-a507-515b82f94d13"],"settings":{"layout":"default","column_alignment":"center","horizontal_content":false,"full_width":true,"show_divider":false,"columns_desktop":4,"heading":"Why Be Yours?","heading_size":"h1","heading_tag":"h2","columns_mobile":"1","swipe_on_mobile":true,"use_custom_colors":false,"colors_icon":"#ffffff","colors_text":"#1a1b18","colors_background":"#ffffff","gradient_background":"","padding_top":60,"padding_bottom":36}},"16537199731cb9d913":{"type":"rich-text","blocks":{"1653719973a73fe318-0":{"type":"heading","settings":{"heading":"“Protect Your Skin And It Will Protect You Back”","heading_size":"h0","heading_tag":"h2"}},"1653719973a73fe318-1":{"type":"text","settings":{"text":"<p>– DR. BARBARA STURM<\/p>","text_size":"typeset","secondary_color":true}}},"block_order":["1653719973a73fe318-0","1653719973a73fe318-1"],"settings":{"text_alignment":"center","mobile_text_alignment":"center","horizontal_content":false,"narrow":false,"show_divider":false,"use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","colors_highlight":"#bbff00","gradient_background":"","padding_top":48,"padding_bottom":60}},"d9e21821-1696-4a1a-b0c2-08252d253ad5":{"type":"collapsible-content","blocks":{"template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-0":{"type":"collapsible_row","settings":{"heading":"Are your products organic \/ natural?","row_content":"<p>Our products combine the power of naturally occurring and advanced science ingredients that are simple to use, highly effective, non-toxic, non-irritating, and absolutely cruelty-free. We do not use aggressive, irritating ingredients. Beyond this, we do not like labels such as ‘organic,’ ‘natural’ or ‘clean,’ which have no consistent definition and tell you nothing about a product’s safety or efficacy. We are committed to bringing you the very best ingredient science and being certified “organic” does not always yield the best ingredient.<\/p>","page":""}},"template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-1":{"type":"collapsible_row","settings":{"heading":"Do your products contain fragrance?","row_content":"<p>Generally not, but with limited exceptions. “Fragrance,” when used in our products like the ANTI-AGING BODY CREAM, is selected for its pleasant scent but also for its proven tolerability. Most fragrances contain allergic substances, or “allergens”: if present, it is compulsory to state this on the label, even if the percentage contained is minimal. Where possible, we tend to use fragrances which do not contain allergens and which should therefore give rise to fewer problems. When fragrance is present in a our product, is indicated in the list of ingredients as PARFUM or FRAGRANCE.<\/p>","page":""}},"template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-2":{"type":"collapsible_row","settings":{"heading":"Is there talc in any of your products?","row_content":"<p>The minerals that are used to produce talc can contain asbestos, which is why there are legitimate concerns about its potential effect on our health. The talc used in our ENZYME CLEANSER, BABY BUM CREAM and tinted CLARIFYING SPOT TREATMENTS is NOT made of minerals that contain asbestos and thus is not carcinogenic and completely safe. The talc we use is periodically and consistently reviewed by independent laboratories.<\/p>","page":""}},"template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-3":{"type":"collapsible_row","settings":{"heading":"What is the shelf life of my product?","row_content":"<p>All beauty products need to be used by a certain period. This is known as the 'period after opening' and can be easily identified by the PAO symbol. The symbol can be recognised as the shape of an opened jar, and will have a number inside; 9M will indicate 9 months, 12M is 12 months, and 36M is 36 months. Once opened the product should be used in this period, as after this time the quality of the product will deteriorate.<\/p>","page":""}}},"block_order":["template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-0","template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-1","template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-2","template--16533939224817__d9e21821-1696-4a1a-b0c2-08252d253ad5-1666501456e0f3b882-3"],"settings":{"open_first_collapsible_row":false,"narrow":true,"show_divider":false,"heading":"FAQs","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","padding_top":36,"padding_bottom":36}},"product-recommendations":{"type":"product-recommendations","settings":{"product_list_limit":4,"show_divider":false,"heading":"You May Also Like","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","columns_mobile":"1","swipe_on_mobile":true,"image_ratio":"portrait","image_position":"center center","enable_image_fill":true,"show_secondary_image":true,"show_vendor":true,"show_rating":true,"show_quick_buy":true,"enable_quick_view":true,"enable_color_swatches":true,"enable_countdown":true,"padding_top":36,"padding_bottom":36}},"recently-viewed-products":{"type":"recently-viewed-products","settings":{"show_divider":false,"heading":"Recently Viewed","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","columns_mobile":"1","swipe_on_mobile":true,"image_ratio":"portrait","image_position":"center center","enable_image_fill":true,"show_secondary_image":true,"show_vendor":true,"show_rating":true,"show_quick_buy":true,"enable_quick_view":true,"enable_color_swatches":true,"enable_countdown":true,"padding_top":36,"padding_bottom":36}},"testimonials":{"type":"testimonials","blocks":{"testimonials-0":{"type":"testimonial","settings":{"icon":"5","text":"<p>“The second product I have bought in the smaller size. Love the little tingle I get on my face after use and a couple of drops is enough.”<\/p>","image":"","author":"Paige Alexander"}},"testimonials-1":{"type":"testimonial","settings":{"icon":"5","text":"<p>“Fantastic cleanser ! My skin is clean & fresh , ready to absorb the rest of my<br\/>Dr. Barbara Sturm skincare routine.”<\/p>","image":"","author":"Claire Cooper"}},"testimonials-2":{"type":"testimonial","settings":{"icon":"5","text":"<p>“This cleanser is very lightweight & doesn’t dry out your skin like most cleansers. I have my teenage son using it & it has helped with his acne.”<\/p>","image":"","author":"Sara Bond"}},"testimonials-3":{"type":"testimonial","settings":{"icon":"5","text":"<p>“I now don't want to use any other cleanser. Use it in the morning and evenings. It doesn't dry the skin and leaves it nicely clean.”<\/p>","image":"","author":"Nikolay Balushev"}},"testimonials-4":{"type":"testimonial","settings":{"icon":"5","text":"<p>“My skin feels soft and clean after using this cleanser because it’s very gentle and doesn't dry out my skin. i combine with the facial scrub every other day.”<\/p>","image":"","author":"Angela McCafferty"}}},"block_order":["testimonials-0","testimonials-1","testimonials-2","testimonials-3","testimonials-4"],"settings":{"autorotate":false,"autorotate_speed":5,"hide_images":false,"show_divider":false,"heading":"What Clients Are Saying","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","padding_top":36,"padding_bottom":36}},"ed3661ce-8c31-45dc-bc0c-1476c55f53bd":{"type":"rich-text","blocks":{"template--16533939224817__ed3661ce-8c31-45dc-bc0c-1476c55f53bd-16665018649fad2685-0":{"type":"heading","settings":{"heading":"Express yourself with","heading_size":"h1","heading_tag":"h2"}},"template--16533939224817__ed3661ce-8c31-45dc-bc0c-1476c55f53bd-16665018649fad2685-1":{"type":"text","settings":{"text":"<p>#ImwithBeYours<\/p>","text_size":"typeset2","secondary_color":true}}},"block_order":["template--16533939224817__ed3661ce-8c31-45dc-bc0c-1476c55f53bd-16665018649fad2685-0","template--16533939224817__ed3661ce-8c31-45dc-bc0c-1476c55f53bd-16665018649fad2685-1"],"settings":{"text_alignment":"center","mobile_text_alignment":"center","horizontal_content":false,"narrow":false,"show_divider":false,"use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","colors_highlight":"#bbff00","gradient_background":"","padding_top":36,"padding_bottom":36}},"2fa0e761-5cfe-4405-bc21-ed7f9f36b64b":{"type":"gallery","blocks":{"template--16533939224817__2fa0e761-5cfe-4405-bc21-ed7f9f36b64b-1666501757e19fc7c2-0":{"type":"image","settings":{"image":"","i