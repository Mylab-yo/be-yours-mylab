      "default": "Votre demande a bien été envoyée !"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Texte succès",
      "default": "Vous recevrez le catalogue par email dans quelques minutes. Pensez à vérifier vos spams."
    },
    {
      "type": "header",
      "content": "Intégration n8n"
    },
    {
