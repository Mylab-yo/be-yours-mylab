      "default": "Vos coordonnées nous permettent de vous envoyer le catalogue par email et de vous proposer un accompagnement personnalisé adapté à votre activité."
    },
    {
      "type": "header",
      "content": "Formulaire"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Titre du formulaire",
      "default": "Recevez le catalogue"
    },
    {
      "type": "text",
      "id": "form_desc",
      "label": "Description du formulaire",
      "default": "Remplissez le formulaire, vous recevrez le catalogue sous quelques minutes."
    },
    {
      "type": "text",
