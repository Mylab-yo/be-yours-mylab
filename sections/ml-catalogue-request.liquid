    },
    {
      "type": "header",
      "content": "Contenu catalogue"
    },
    {
      "type": "text",
      "id": "content_heading",
      "label": "Titre du contenu",
      "default": "Ce que contient le catalogue"
    },
    {
      "type": "text",
