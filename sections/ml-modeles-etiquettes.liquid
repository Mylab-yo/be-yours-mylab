{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ml-etiquettes-hero {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 1.5rem {{ section.settings.padding_bottom }}px;
  }
  .ml-etiquettes-hero__subheading {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.8rem;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
  }
  .ml-etiquettes-hero__heading {
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    margin: 0 0 2rem;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    letter-spacing: 0.02em;
  }
  .ml-etiquettes-hero__heading strong,
  .ml-etiquettes-hero__heading em {
    color: {{ section.settings.accent_color }};
    font-style: normal;
    font-weight: 700;
  }
  .ml-etiquettes-hero__note {
    font-size: 1.1rem;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  /* ── FORFAITS ── */
  .ml-forfaits {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }
  .ml-forfait {
    background: {{ section.settings.card_bg }};
    border: 2px solid #E5E5E5;
    border-radius: 1.2rem;
    padding: 2rem 1.8rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ml-forfait:hover {
    border-color: {{ section.settings.accent_color }};
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .ml-forfait--popular {
    border-color: {{ section.settings.accent_color }};
    position: relative;
  }
  .ml-forfait__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 1.2rem;
    border-radius: 50px;
    white-space: nowrap;
  }
  .ml-forfait__icon {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
  }
  .ml-forfait__name {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.4rem;
  }
  .ml-forfait__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem;
    color: #888;
    line-height: 1.5;
    margin: 0 0 1rem;
    flex: 1;
  }
  .ml-forfait__price {
    font-family: 'DM Sans', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin-bottom: 0.3rem;
  }
  .ml-forfait__price-note {
    font-size: 1.1rem;
    color: #888;
    margin-bottom: 1.2rem;
  }
  .ml-forfait__cta {
    display: inline-block;
    width: 100%;
    padding: 0.9rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: {{ section.settings.text_color }};
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    min-height: 44px;
  }
  .ml-forfait__cta:hover { background: {{ section.settings.accent_color }}; }
  .ml-forfait__cta:active { transform: scale(0.98); }
  .ml-forfait__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.2rem;
    text-align: left;
    width: 100%;
  }
  .ml-forfait__features li {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    color: #555;
    padding: 0.4rem 0;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .ml-forfait__features li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Section title for modèles grid ── */
  .ml-etiquettes-section-title {
    text-align: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.6rem;
  }
  .ml-etiquettes-section-subtitle {
    text-align: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem;
    color: #888;
    margin: 0 0 2rem;
  }

  @media screen and (max-width: 749px) {
    .ml-forfaits {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
  .ml-etiquettes-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .ml-etiquette-card {
    text-align: center;
    transition: transform 0.3s ease;
    background: {{ section.settings.card_bg }};
    border-radius: 1.2rem;
    overflow: hidden;
    border: 1px solid #E5E5E5;
  }
  .ml-etiquette-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
  .ml-etiquette-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #fff;
  }
  .ml-etiquette-card__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    transition: opacity 0.4s ease;
    padding: 1rem;
  }
  .ml-etiquette-card__image--hover {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.4s ease;
    padding: 1rem;
  }
  .ml-etiquette-card:hover .ml-etiquette-card__image--primary {
    opacity: 0;
  }
  .ml-etiquette-card:hover .ml-etiquette-card__image--hover {
    opacity: 1;
  }
  .ml-etiquette-card__body {
    padding: 1rem 1.2rem 1.4rem;
  }
  .ml-etiquette-card__name {
    font-size: 1.4rem;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.3rem;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.02em;
  }
  .ml-etiquette-card__price {
    font-size: 1.2rem;
    font-weight: 500;
    color: {{ section.settings.accent_color }};
    font-family: 'DM Sans', sans-serif;
    margin-bottom: 0.8rem;
  }
  .ml-etiquette-card__btn {
    display: inline-block;
    width: 100%;
    padding: 0.7rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffffff;
    background: {{ section.settings.text_color }};
    border: none;
    border-radius: 0.6rem;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.15s ease;
  }
  .ml-etiquette-card__btn:hover {
    background: {{ section.settings.accent_color }};
    transform: scale(1.02);
  }
  .ml-etiquette-card__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
  .ml-etiquette-card__btn--added {
    background: #2e7d32;
  }
  .ml-etiquette-card__btn--added:hover {
    background: #2e7d32;
    transform: none;
  }
  .ml-etiquette-card__unavailable {
    font-size: 1.1rem;
    color: #888;
    font-family: 'DM Sans', sans-serif;
    padding: 0.7rem 0;
  }
  @media screen and (max-width: 749px) {
    .ml-etiquettes-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 1.5rem;
      padding: 1rem 1rem 3rem;
    }
    .ml-etiquettes-hero__heading {
      font-size: 2rem;
    }
    .ml-etiquettes-info {
      flex-direction: column;
      align-items: center;
    }
  }
{%- endstyle -%}

<div class="ml-etiquettes-hero">
  <p class="ml-etiquettes-hero__subheading">{{ section.settings.subheading }}</p>
  <h1 class="ml-etiquettes-hero__heading">{{ section.settings.heading }}</h1>

  <p class="ml-etiquettes-hero__note">{{ section.settings.note }}</p>
</div>

{%- comment -%} ====== 3 FORFAITS ====== {%- endcomment -%}
<div class="ml-forfaits">
  {%- comment -%} ── Forfait 1 : Standard ── {%- endcomment -%}
  <div class="ml-forfait">
    <svg class="ml-forfait__icon" viewBox="0 0 48 48" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5"><rect x="8" y="6" width="32" height="36" rx="3"/><path d="M16 16h16M16 22h16M16 28h10"/></svg>
    <h2 class="ml-forfait__name">Standard</h2>
    <p class="ml-forfait__desc">Étiquettes avec fonds colorés et impression noire. Simple et efficace.</p>
    <ul class="ml-forfait__features">
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Fonds colorés au choix</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Impression texte noir</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Votre logo intégré</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Conforme réglementation</li>
    </ul>
    <div class="ml-forfait__price">99 €</div>
    <div class="ml-forfait__price-note">HT / forfait unique</div>
    <button type="button" class="ml-forfait__cta" data-variant-id="55418362003790" onclick="mlAddLabel(this)">Ajouter au panier</button>
  </div>

  {%- comment -%} ── Forfait 2 : Modèle d'étiquette ── {%- endcomment -%}
  <div class="ml-forfait ml-forfait--popular">
    <div class="ml-forfait__badge">Populaire</div>
    <svg class="ml-forfait__icon" viewBox="0 0 48 48" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="1.5"><rect x="6" y="10" width="36" height="28" rx="3"/><circle cx="18" cy="22" r="4"/><path d="M6 34l10-8 6 4 10-10 10 8"/></svg>
    <h2 class="ml-forfait__name">Modèle design</h2>
    <p class="ml-forfait__desc">Choisissez parmi nos modèles d'étiquettes créés par nos designers.</p>
    <ul class="ml-forfait__features">
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Design professionnel</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Impression couleur</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Votre logo intégré</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Conforme réglementation</li>
    </ul>
    <div class="ml-forfait__price">99 €</div>
    <div class="ml-forfait__price-note">HT / par modèle</div>
    <a href="#ml-modeles-grid" class="ml-forfait__cta" style="text-decoration:none;text-align:center;">Voir les modèles</a>
  </div>

  {%- comment -%} ── Forfait 3 : Création sur mesure ── {%- endcomment -%}
  <div class="ml-forfait">
    <svg class="ml-forfait__icon" viewBox="0 0 48 48" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5"><path d="M34 7l7 7-24 24H10v-7L34 7z"/><path d="M28 13l7 7"/></svg>
    <h2 class="ml-forfait__name">Création sur mesure</h2>
    <p class="ml-forfait__desc">Design d'étiquette 100% personnalisé par notre graphiste selon votre charte.</p>
    <ul class="ml-forfait__features">
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Design 100% unique</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Votre charte graphique</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Allers-retours illimités</li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Conforme réglementation</li>
    </ul>
    <div class="ml-forfait__price">390 €</div>
    <div class="ml-forfait__price-note">HT / création</div>
    <button type="button" class="ml-forfait__cta" data-variant-id="55418346242382" onclick="mlAddLabel(this)">Ajouter au panier</button>
  </div>
</div>

{%- comment -%} ====== TITRE GRILLE MODÈLES ====== {%- endcomment -%}
<div id="ml-modeles-grid">
  <h2 class="ml-etiquettes-section-title">Nos modèles d'étiquettes</h2>
  <p class="ml-etiquettes-section-subtitle">Choisissez un modèle et ajoutez-le à votre panier</p>
</div>

<div class="ml-etiquettes-grid">
  {%- for block in section.blocks -%}
    {%- assign block_product = block.settings.product -%}
    <div class="ml-etiquette-card" {{ block.shopify_attributes }}>
      <div class="ml-etiquette-card__image-wrap">
        {%- if block.settings.image != blank -%}
          {%- if block.settings.image_hover != blank -%}
            <img
              class="ml-etiquette-card__image ml-etiquette-card__image--primary"
              src="{{ block.settings.image | image_url: width: 500 }}"
              alt="{{ block.settings.name | escape }}"
              width="500"
              height="500"
              loading="lazy"
            >
            <img
              class="ml-etiquette-card__image ml-etiquette-card__image--hover"
              src="{{ block.settings.image_hover | image_url: width: 500 }}"
              alt="{{ block.settings.name | escape }} — variante"
              width="500"
              height="500"
              loading="lazy"
            >
          {%- else -%}
            <img
              class="ml-etiquette-card__image"
              src="{{ block.settings.image | image_url: width: 500 }}"
              alt="{{ block.settings.name | escape }}"
              width="500"
              height="500"
              loading="lazy"
            >
          {%- endif -%}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'ml-etiquette-card__image' }}
        {%- endif -%}
      </div>
      <div class="ml-etiquette-card__body">
        <h3 class="ml-etiquette-card__name">{{ block.settings.name }}</h3>
        {%- if block_product != blank -%}
          <div class="ml-etiquette-card__price">{{ block_product.price | money }}</div>
          {%- if block_product.available -%}
            <button
              type="button"
              class="ml-etiquette-card__btn"
              data-variant-id="{{ block_product.selected_or_first_available_variant.id }}"
              onclick="mlAddLabel(this)"
            >
              Commander
            </button>
          {%- else -%}
            <div class="ml-etiquette-card__unavailable">Indisponible</div>
          {%- endif -%}
        {%- else -%}
          <div class="ml-etiquette-card__unavailable">Bientôt disponible</div>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</div>

<script>
  function mlAddLabel(btn) {
    if (btn.disabled) return;
    var variantId = btn.getAttribute('data-variant-id');
    btn.disabled = true;
    btn.textContent = 'Ajout...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Erreur');
      return res.json();
    })
    .then(function() {
      btn.textContent = 'Ajouté ✓';
      btn.classList.add('ml-etiquette-card__btn--added');
      setTimeout(function() {
        btn.disabled = false;
        btn.textContent = 'Commander';
        btn.classList.remove('ml-etiquette-card__btn--added');
      }, 2000);
      /* Ouvre le cart drawer si disponible */
      var drawer = document.querySelector('#ml-drawer');
      if (drawer) {
        fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
          document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { cart: cart } }));
          if (typeof window.MylabCart !== 'undefined' && window.MylabCart.open) {
            window.MylabCart.open();
          }
        });
      } else {
        /* Fallback — pubsub Be Yours */
        if (typeof publish === 'function') {
          fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
            publish('cart:update', { cart: cart });
          });
        }
      }
    })
    .catch(function() {
      btn.textContent = 'Erreur — Réessayer';
      btn.disabled = false;
      btn.classList.remove('ml-etiquette-card__btn--added');
    });
  }
</script>

{% schema %}
{
  "name": "Modèles d'étiquettes",
  "tag": "section",
  "class": "ml-modeles-etiquettes",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "PERSONNALISATION"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Titre",
      "default": "<p>Personnalisez les étiquettes de vos <em>produits cosmétiques</em></p>"
    },
    {
      "type": "text",
      "id": "price_etiquette",
      "label": "Prix étiquette",
      "default": "99 €"
    },
    {
      "type": "text",
      "id": "price_etiquette_label",
      "label": "Libellé prix étiquette",
      "default": "par modèle — valable pour toutes les références"
    },
    {
      "type": "text",
      "id": "price_impression",
      "label": "Prix impression",
      "default": "250 € / an"
    },
    {
      "type": "text",
      "id": "price_impression_label",
      "label": "Libellé prix impression",
      "default": "forfait impression interne illimité"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note",
      "default": "Toutes les étiquettes ont des couleurs variables selon la gamme."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes bureau",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur accent",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#F5F4F2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "etiquette",
      "name": "Modèle",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nom du modèle",
          "default": "Modèle"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Produit lié (virtuel)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image principale"
        },
        {
          "type": "image_picker",
          "id": "image_hover",
          "label": "Image au survol (optionnelle)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modèles d'étiquettes",
      "blocks": [
        { "type": "etiquette", "settings": { "name": "Black and Yellow" } },
        { "type": "etiquette", "settings": { "name": "Green Floral" } },
        { "type": "etiquette", "settings": { "name": "Aquarel" } }
      ]
    }
  ]
}
{% endschema %}
