{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ml-etiquettes-hero {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 1.5rem {{ section.settings.padding_bottom }}px;
  }
  .ml-etiquettes-hero__subheading {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .ml-etiquettes-hero__heading {
    font-size: 2.2rem;
    font-family: 'Cormorant Garamond', serif;
    margin: 0 0 1.5rem;
    color: {{ section.settings.text_color }};
  }
  .ml-etiquettes-hero__heading strong,
  .ml-etiquettes-hero__heading em {
    color: {{ section.settings.accent_color }};
  }
  .ml-etiquettes-info {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .ml-etiquettes-info__card {
    background: {{ section.settings.card_bg }};
    border-radius: 12px;
    padding: 1.5rem 2rem;
    text-align: center;
    flex: 1;
    min-width: 220px;
    max-width: 320px;
  }
  .ml-etiquettes-info__price {
    font-size: 1.8rem;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.3rem;
    font-family: 'Cormorant Garamond', serif;
  }
  .ml-etiquettes-info__label {
    font-size: 0.9rem;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
  }
  .ml-etiquettes-hero__note {
    font-size: 0.95rem;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
    font-style: italic;
  }
  .ml-etiquettes-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .ml-etiquette-card {
    text-align: center;
    transition: transform 0.3s ease;
  }
  .ml-etiquette-card:hover {
    transform: translateY(-4px);
  }
  .ml-etiquette-card__image-wrap {
    position: relative;
    width: 100%;
    max-width: 280px;
    margin: 0 auto 1rem;
  }
  .ml-etiquette-card__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    transition: opacity 0.4s ease;
  }
  .ml-etiquette-card__image--hover {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .ml-etiquette-card:hover .ml-etiquette-card__image--primary {
    opacity: 0;
  }
  .ml-etiquette-card:hover .ml-etiquette-card__image--hover {
    opacity: 1;
  }
  .ml-etiquette-card__name {
    font-size: 1.15rem;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    letter-spacing: 0.5px;
  }
  @media screen and (max-width: 749px) {
    .ml-etiquettes-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 1.5rem;
      padding: 1rem 1rem 3rem;
    }
    .ml-etiquettes-hero__heading {
      font-size: 1.6rem;
    }
    .ml-etiquettes-info {
      flex-direction: column;
      align-items: center;
    }
    .ml-etiquette-card__image-wrap {
      max-width: 200px;
    }
  }
{%- endstyle -%}

<div class="ml-etiquettes-hero">
  <p class="ml-etiquettes-hero__subheading">{{ section.settings.subheading }}</p>
  <h1 class="ml-etiquettes-hero__heading">{{ section.settings.heading }}</h1>

  <div class="ml-etiquettes-info">
    <div class="ml-etiquettes-info__card">
      <div class="ml-etiquettes-info__price">{{ section.settings.price_etiquette }}</div>
      <div class="ml-etiquettes-info__label">{{ section.settings.price_etiquette_label }}</div>
    </div>
    <div class="ml-etiquettes-info__card">
      <div class="ml-etiquettes-info__price">{{ section.settings.price_impression }}</div>
      <div class="ml-etiquettes-info__label">{{ section.settings.price_impression_label }}</div>
    </div>
  </div>

  <p class="ml-etiquettes-hero__note">{{ section.settings.note }}</p>
</div>

<div class="ml-etiquettes-grid">
  {%- for block in section.blocks -%}
    <div class="ml-etiquette-card" {{ block.shopify_attributes }}>
      <div class="ml-etiquette-card__image-wrap">
        {%- if block.settings.image != blank -%}
          {%- if block.settings.image_hover != blank -%}
            <img
              class="ml-etiquette-card__image ml-etiquette-card__image--primary"
              src="{{ block.settings.image | image_url: width: 500 }}"
              alt="{{ block.settings.name | escape }}"
              width="500"
              height="auto"
              loading="lazy"
            >
            <img
              class="ml-etiquette-card__image ml-etiquette-card__image--hover"
              src="{{ block.settings.image_hover | image_url: width: 500 }}"
              alt="{{ block.settings.name | escape }} — variante"
              width="500"
              height="auto"
              loading="lazy"
            >
          {%- else -%}
            <img
              class="ml-etiquette-card__image"
              src="{{ block.settings.image | image_url: width: 500 }}"
              alt="{{ block.settings.name | escape }}"
              width="500"
              height="auto"
              loading="lazy"
            >
          {%- endif -%}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'ml-etiquette-card__image' }}
        {%- endif -%}
      </div>
      <h3 class="ml-etiquette-card__name">{{ block.settings.name }}</h3>
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Modèles d'étiquettes",
  "tag": "section",
  "class": "ml-modeles-etiquettes",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "PERSONNALISATION"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Titre",
      "default": "<p>Personnalisez les étiquettes de vos <em>produits cosmétiques</em></p>"
    },
    {
      "type": "text",
      "id": "price_etiquette",
      "label": "Prix étiquette",
      "default": "99 €"
    },
    {
      "type": "text",
      "id": "price_etiquette_label",
      "label": "Libellé prix étiquette",
      "default": "par modèle — valable pour toutes les références"
    },
    {
      "type": "text",
      "id": "price_impression",
      "label": "Prix impression",
      "default": "250 € / an"
    },
    {
      "type": "text",
      "id": "price_impression_label",
      "label": "Libellé prix impression",
      "default": "forfait impression interne illimité"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note",
      "default": "Toutes les étiquettes ont des couleurs variables selon la gamme."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes bureau",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur accent",
      "default": "#c5a467"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#f5f0eb"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "etiquette",
      "name": "Modèle",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nom du modèle",
          "default": "Modèle"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image principale"
        },
        {
          "type": "image_picker",
          "id": "image_hover",
          "label": "Image au survol (optionnelle)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modèles d'étiquettes",
      "blocks": [
        { "type": "etiquette", "settings": { "name": "Black and Yellow" } },
        { "type": "etiquette", "settings": { "name": "Green Floral" } },
        { "type": "etiquette", "settings": { "name": "Aquarel" } }
      ]
    }
  ]
}
{% endschema %}
