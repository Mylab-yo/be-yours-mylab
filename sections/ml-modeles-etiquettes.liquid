{% comment %}
  MyLab Shop — Page Étiquettes (3 forfaits + grille modèles)
  sections/ml-modeles-etiquettes.liquid
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .ml-etiq {
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    color: #111;
  }

  /* ── HERO ── */
  .ml-etiq__hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 3rem;
  }
  .ml-etiq__badge {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 1rem;
  }
  .ml-etiq__title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.15;
    margin: 0 0 1rem;
    color: #111;
  }
  .ml-etiq__subtitle {
    font-size: 1.4rem;
    line-height: 1.6;
    color: #555;
    max-width: 520px;
    margin: 0 auto;
  }

  /* ── FORFAITS ── */
  .ml-etiq__forfaits {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto 4rem;
  }
  .ml-etiq__card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 2.4rem 1.8rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ml-etiq__card:hover {
    border-color: #111;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .ml-etiq__card--popular {
    border: 2px solid #111;
    position: relative;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .ml-etiq__card-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #111;
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 1.2rem;
    border-radius: 50px;
    white-space: nowrap;
  }
  .ml-etiq__card-icon {
    width: 44px;
    height: 44px;
    margin-bottom: 1rem;
    stroke: #111;
    fill: none;
    stroke-width: 1.5;
  }
  .ml-etiq__card-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 0.4rem;
  }
  .ml-etiq__card-desc {
    font-size: 1.2rem;
    color: #888;
    line-height: 1.5;
    margin: 0 0 1.2rem;
    flex: 1;
  }
  .ml-etiq__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.4rem;
    text-align: left;
    width: 100%;
  }
  .ml-etiq__features li {
    font-size: 1.2rem;
    color: #555;
    padding: 0.4rem 0;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    line-height: 1.4;
  }
  .ml-etiq__features li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .ml-etiq__price {
    font-size: 2.4rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 0.2rem;
  }
  .ml-etiq__price-note {
    font-size: 1.1rem;
    color: #888;
    margin-bottom: 1.4rem;
  }
  .ml-etiq__cta {
    display: inline-block;
    width: 100%;
    padding: 1rem 1.5rem;
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: #111;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    min-height: 48px;
    text-decoration: none;
    text-align: center;
    line-height: 1.4;
  }
  .ml-etiq__cta:hover { background: #333; color: #fff; }
  .ml-etiq__cta:active { transform: scale(0.98); }

  /* ── SECTION MODÈLES ── */
  .ml-etiq__models-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .ml-etiq__models-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    font-style: italic;
    color: #111;
    margin: 0 0 0.4rem;
  }
  .ml-etiq__models-subtitle {
    font-size: 1.3rem;
    color: #888;
    margin: 0;
  }

  /* ── GRILLE MODÈLES ── */
  .ml-etiq__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 4 }}, 1fr);
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .ml-etiq__model {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .ml-etiq__model:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .ml-etiq__model-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #fafafa;
  }
  .ml-etiq__model-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    padding: 1rem;
    transition: opacity 0.4s;
  }
  .ml-etiq__model-img--hover {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .ml-etiq__model:hover .ml-etiq__model-img--primary { opacity: 0; }
  .ml-etiq__model:hover .ml-etiq__model-img--hover { opacity: 1; }
  .ml-etiq__model-body {
    padding: 1rem 1.2rem 1.4rem;
    text-align: center;
  }
  .ml-etiq__model-name {
    font-size: 1.3rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 0.3rem;
  }
  .ml-etiq__model-price {
    font-size: 1.2rem;
    font-weight: 500;
    color: #888;
    margin-bottom: 0.8rem;
  }
  .ml-etiq__model-btn {
    display: inline-block;
    width: 100%;
    padding: 0.8rem 1rem;
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: #111;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: background 0.2s;
    min-height: 44px;
  }
  .ml-etiq__model-btn:hover { background: #333; }
  .ml-etiq__model-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ml-etiq__model-btn--added { background: #2d7a45; }
  .ml-etiq__model-btn--added:hover { background: #2d7a45; }

  /* ── RESPONSIVE TABLET ── */
  @media screen and (min-width: 750px) and (max-width: 999px) {
    .ml-etiq__forfaits {
      grid-template-columns: 1fr;
      max-width: 450px;
      margin-left: auto;
      margin-right: auto;
    }
    .ml-etiq__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── RESPONSIVE MOBILE ── */
  @media screen and (max-width: 749px) {
    .ml-etiq__forfaits {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
    .ml-etiq__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile | default: 2 }}, 1fr);
      gap: 1.2rem;
    }
    .ml-etiq__card {
      padding: 1.6rem 1.4rem;
    }
  }
</style>

<div class="ml-etiq page-width">

  {%- comment -%} ====== HERO ====== {%- endcomment -%}
  <div class="ml-etiq__hero">
    <div class="ml-etiq__badge">{{ section.settings.subheading | default: 'Personnalisation' }}</div>
    <h1 class="ml-etiq__title">{{ section.settings.heading | default: 'Personnalisez vos étiquettes' }}</h1>
    <p class="ml-etiq__subtitle">{{ section.settings.subtitle | default: 'Choisissez parmi 3 forfaits adaptés à vos besoins : impression standard, modèles design ou création sur mesure.' }}</p>
  </div>

  {%- comment -%} ====== 3 FORFAITS ====== {%- endcomment -%}
  <div class="ml-etiq__forfaits">

    {%- comment -%} Forfait 1 : Standard — GRATUIT {%- endcomment -%}
    <div class="ml-etiq__card">
      <svg class="ml-etiq__card-icon" viewBox="0 0 48 48"><rect x="8" y="6" width="32" height="36" rx="3"/><path d="M16 16h16M16 22h16M16 28h10"/></svg>
      <h2 class="ml-etiq__card-name">Standard</h2>
      <p class="ml-etiq__card-desc">Étiquettes avec fonds colorés et impression noire. Simple et efficace.</p>
      <ul class="ml-etiq__features">
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Fonds colorés au choix</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Impression texte noir</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Votre logo intégré</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Conforme réglementation</li>
      </ul>
      <div class="ml-etiq__price">Gratuit</div>
      <div class="ml-etiq__price-note">Inclus avec votre commande</div>
      {%- if section.settings.product_standard != blank -%}
        <button type="button" class="ml-etiq__cta" data-variant-id="{{ section.settings.product_standard.selected_or_first_available_variant.id }}" onclick="mlAddLabel(this)">Ajouter au panier</button>
      {%- endif -%}
    </div>

    {%- comment -%} Forfait 2 : Modèle design {%- endcomment -%}
    <div class="ml-etiq__card ml-etiq__card--popular">
      <div class="ml-etiq__card-badge">Populaire</div>
      <svg class="ml-etiq__card-icon" viewBox="0 0 48 48"><rect x="6" y="10" width="36" height="28" rx="3"/><circle cx="18" cy="22" r="4"/><path d="M6 34l10-8 6 4 10-10 10 8"/></svg>
      <h2 class="ml-etiq__card-name">Modèle design</h2>
      <p class="ml-etiq__card-desc">Choisissez parmi nos modèles d'étiquettes créés par nos designers.</p>
      <ul class="ml-etiq__features">
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Design professionnel</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Impression couleur</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Votre logo intégré</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Conforme réglementation</li>
      </ul>
      <div class="ml-etiq__price">99 €</div>
      <div class="ml-etiq__price-note">HT / par modèle</div>
      <a href="#ml-modeles-grid" class="ml-etiq__cta">Voir les modèles</a>
    </div>

    {%- comment -%} Forfait 3 : Création sur mesure {%- endcomment -%}
    <div class="ml-etiq__card">
      <svg class="ml-etiq__card-icon" viewBox="0 0 48 48"><path d="M34 7l7 7-24 24H10v-7L34 7z"/><path d="M28 13l7 7"/></svg>
      <h2 class="ml-etiq__card-name">Création sur mesure</h2>
      <p class="ml-etiq__card-desc">Design 100% personnalisé par notre graphiste selon votre charte.</p>
      <ul class="ml-etiq__features">
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Design 100% unique</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Votre charte graphique</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Allers-retours illimités</li>
        <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2.5"><path d="M5 12l5 5L19 7"/></svg>Conforme réglementation</li>
      </ul>
      <div class="ml-etiq__price">390 €</div>
      <div class="ml-etiq__price-note">HT / création</div>
      {%- if section.settings.product_sur_mesure != blank -%}
        <button type="button" class="ml-etiq__cta" data-variant-id="{{ section.settings.product_sur_mesure.selected_or_first_available_variant.id }}" onclick="mlAddLabel(this)">Ajouter au panier</button>
      {%- endif -%}
    </div>

  </div>

  {%- comment -%} ====== GRILLE MODÈLES ====== {%- endcomment -%}
  <div id="ml-modeles-grid" class="ml-etiq__models-header">
    <h2 class="ml-etiq__models-title">Nos modèles d'étiquettes</h2>
    <p class="ml-etiq__models-subtitle">Choisissez un modèle et ajoutez-le à votre panier — 99 € HT par modèle</p>
  </div>

  <div class="ml-etiq__grid">
    {%- for block in section.blocks -%}
      {%- assign block_product = block.settings.product -%}
      <div class="ml-etiq__model" {{ block.shopify_attributes }}>
        <div class="ml-etiq__model-img-wrap">
          {%- if block.settings.image != blank -%}
            {%- if block.settings.image_hover != blank -%}
              <img class="ml-etiq__model-img ml-etiq__model-img--primary" src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.name | escape }}" width="500" height="500" loading="lazy">
              <img class="ml-etiq__model-img ml-etiq__model-img--hover" src="{{ block.settings.image_hover | image_url: width: 500 }}" alt="{{ block.settings.name | escape }} — variante" width="500" height="500" loading="lazy">
            {%- else -%}
              <img class="ml-etiq__model-img" src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.name | escape }}" width="500" height="500" loading="lazy">
            {%- endif -%}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'ml-etiq__model-img' }}
          {%- endif -%}
        </div>
        <div class="ml-etiq__model-body">
          <h3 class="ml-etiq__model-name">{{ block.settings.name }}</h3>
          {%- if block_product != blank -%}
            <div class="ml-etiq__model-price">{{ block_product.price | money }}</div>
            {%- if block_product.available -%}
              <button type="button" class="ml-etiq__model-btn" data-variant-id="{{ block_product.selected_or_first_available_variant.id }}" onclick="mlAddLabel(this)">Ajouter au panier</button>
            {%- else -%}
              <div style="font-size:1.1rem;color:#888;padding:0.7rem 0;">Indisponible</div>
            {%- endif -%}
          {%- else -%}
            <div style="font-size:1.1rem;color:#888;padding:0.7rem 0;">Bientôt disponible</div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

</div>

<script>
  function mlAddLabel(btn) {
    if (btn.disabled) return;
    var variantId = btn.getAttribute('data-variant-id');
    btn.disabled = true;
    var originalText = btn.textContent;
    btn.textContent = 'Ajout...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Erreur');
      return res.json();
    })
    .then(function() {
      btn.textContent = 'Ajouté ✓';
      btn.classList.add('ml-etiq__model-btn--added');
      document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { open: true } }));
      setTimeout(function() {
        btn.disabled = false;
        btn.textContent = originalText;
        btn.classList.remove('ml-etiq__model-btn--added');
      }, 2000);
    })
    .catch(function() {
      btn.textContent = 'Erreur — Réessayer';
      btn.disabled = false;
    });
  }
</script>

{% schema %}
{
  "name": "ML Étiquettes",
  "tag": "section",
  "class": "ml-etiquettes-section",
  "settings": [
    {
      "type": "header",
      "content": "En-tête"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Badge",
      "default": "Personnalisation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Personnalisez vos étiquettes"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Choisissez parmi 3 forfaits adaptés à vos besoins : impression standard, modèles design ou création sur mesure."
    },
    {
      "type": "header",
      "content": "Forfaits"
    },
    {
      "type": "product",
      "id": "product_standard",
      "label": "Produit — Forfait Standard (gratuit)"
    },
    {
      "type": "product",
      "id": "product_sur_mesure",
      "label": "Produit — Forfait Création sur mesure"
    },
    {
      "type": "header",
      "content": "Grille"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Colonnes (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacement haut",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacement bas",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "etiquette",
      "name": "Modèle d'étiquette",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nom du modèle",
          "default": "Modèle"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Produit lié"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image principale"
        },
        {
          "type": "image_picker",
          "id": "image_hover",
          "label": "Image au survol (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ML Étiquettes"
    }
  ]
}
{% endschema %}
