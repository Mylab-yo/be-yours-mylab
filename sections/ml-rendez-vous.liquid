{% comment %}
  MyLab Shop — Page Prise de Rendez-vous
  sections/ml-rendez-vous.liquid
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .ml-rdv {
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    color: #111;
  }

  /* ── HERO ── */
  .ml-rdv__hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 2.5rem;
  }
  .ml-rdv__logo {
    max-width: 80px;
    height: auto;
    margin: 0 auto 1.2rem;
    display: block;
  }
  .ml-rdv__subtitle {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #888;
    margin-bottom: 0.6rem;
    font-weight: 600;
  }
  .ml-rdv__title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: clamp(2.8rem, 4vw, 4rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.15;
    margin: 0 0 1.2rem;
    color: #111;
  }
  .ml-rdv__desc {
    font-size: 1.3rem;
    line-height: 1.7;
    color: #555;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── FEATURES ── */
  .ml-rdv__features {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 2rem auto 2.5rem;
    max-width: 700px;
  }
  .ml-rdv__feature {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.2rem;
    color: #555;
  }
  .ml-rdv__feature svg {
    flex-shrink: 0;
  }

  /* ── CALENDLY WRAPPER ── */
  .ml-rdv__calendly-wrap {
    max-width: 900px;
    margin: 0 auto 3rem;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    background: #fff;
  }
  .ml-rdv__calendly-wrap .calendly-inline-widget {
    min-width: 280px;
    width: 100%;
  }

  /* ── INFO CARDS ── */
  .ml-rdv__info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto 2rem;
  }
  .ml-rdv__card {
    text-align: center;
    padding: 1.6rem 1.2rem;
    background: #fafafa;
    border: 1px solid #eee;
    border-radius: 10px;
    transition: border-color 0.2s;
  }
  .ml-rdv__card:hover {
    border-color: #ccc;
  }
  .ml-rdv__card-icon {
    width: 40px;
    height: 40px;
    margin: 0 auto 0.8rem;
    color: #111;
  }
  .ml-rdv__card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 0.4rem;
  }
  .ml-rdv__card-text {
    font-size: 1.15rem;
    color: #888;
    line-height: 1.5;
  }

  /* ── TRUST ── */
  .ml-rdv__trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 1.5rem 0;
    border-top: 1px solid #eee;
    max-width: 700px;
    margin: 0 auto;
  }
  .ml-rdv__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    color: #888;
  }

  /* ── RESPONSIVE ── */
  @media screen and (min-width: 750px) and (max-width: 999px) {
    .ml-rdv__info {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
  @media screen and (max-width: 749px) {
    .ml-rdv__hero {
      margin-bottom: 1.5rem;
    }
    .ml-rdv__title {
      font-size: clamp(2.2rem, 7vw, 3rem);
    }
    .ml-rdv__features {
      flex-direction: column;
      align-items: center;
      gap: 0.8rem;
    }
    .ml-rdv__info {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
    .ml-rdv__trust {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }
  }
</style>

<div class="ml-rdv page-width">

  {%- comment -%} ── HERO ── {%- endcomment -%}
  <div class="ml-rdv__hero">
    {%- if section.settings.logo != blank -%}
      <img
        class="ml-rdv__logo"
        src="{{ section.settings.logo | image_url: width: 160 }}"
        alt="{{ shop.name }}"
        width="80"
        height="80"
        loading="eager"
      >
    {%- endif -%}
    <p class="ml-rdv__subtitle">{{ section.settings.subtitle | default: 'MyLab Professionnel' }}</p>
    <h1 class="ml-rdv__title">{{ section.settings.heading | default: 'Prenez rendez-vous' }}</h1>
    <p class="ml-rdv__desc">{{ section.settings.description | default: 'Échangeons sur votre projet de création de marque capillaire. Choisissez un créneau qui vous convient, nous vous rappelons pour un premier échange gratuit et sans engagement.' }}</p>
  </div>

  {%- comment -%} ── FEATURES ── {%- endcomment -%}
  <div class="ml-rdv__features">
    <div class="ml-rdv__feature">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      <span>{{ section.settings.feature_1 | default: '30 min d\'échange' }}</span>
    </div>
    <div class="ml-rdv__feature">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      <span>{{ section.settings.feature_2 | default: 'Par téléphone ou visio' }}</span>
    </div>
    <div class="ml-rdv__feature">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d7a45" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span>{{ section.settings.feature_3 | default: 'Gratuit et sans engagement' }}</span>
    </div>
  </div>

  {%- comment -%} ── CALENDLY EMBED ── {%- endcomment -%}
  <div class="ml-rdv__calendly-wrap">
    <div class="calendly-inline-widget" data-url="{{ section.settings.calendly_url | default: 'https://calendly.com/yoann-mylab/premier-contact?text_color=000000&primary_color=1a1a1a' }}" style="min-width:280px;height:{{ section.settings.calendly_height | default: 660 }}px;"></div>
    <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
  </div>

  {%- comment -%} ── INFO CARDS ── {%- endcomment -%}
  <div class="ml-rdv__info">
    <div class="ml-rdv__card">
      <svg class="ml-rdv__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <div class="ml-rdv__card-title">{{ section.settings.card_1_title | default: 'Basés en Provence' }}</div>
      <div class="ml-rdv__card-text">{{ section.settings.card_1_text | default: '231 Avenue de la Voguette, 84300 Cavaillon' }}</div>
    </div>
    <div class="ml-rdv__card">
      <svg class="ml-rdv__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      <div class="ml-rdv__card-title">{{ section.settings.card_2_title | default: 'Appelez-nous' }}</div>
      <div class="ml-rdv__card-text">{{ section.settings.card_2_text | default: '04 85 69 33 47' }}</div>
    </div>
    <div class="ml-rdv__card">
      <svg class="ml-rdv__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <div class="ml-rdv__card-title">{{ section.settings.card_3_title | default: 'Par email' }}</div>
      <div class="ml-rdv__card-text">{{ section.settings.card_3_text | default: 'contact@mylab-shop.com' }}</div>
    </div>
  </div>

  {%- comment -%} ── TRUST ── {%- endcomment -%}
  <div class="ml-rdv__trust">
    <div class="ml-rdv__trust-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span>Sans engagement</span>
    </div>
    <div class="ml-rdv__trust-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <span>Accompagnement personnalisé</span>
    </div>
    <div class="ml-rdv__trust-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span>Créneaux flexibles</span>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "ML Prise de RDV",
  "tag": "section",
  "class": "ml-rdv-section",
  "settings": [
    {
      "type": "header",
      "content": "En-tête"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "MyLab Professionnel"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Prenez rendez-vous"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Échangeons sur votre projet de création de marque capillaire. Choisissez un créneau qui vous convient, nous vous rappelons pour un premier échange gratuit et sans engagement."
    },
    {
      "type": "header",
      "content": "Avantages"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Avantage 1",
      "default": "30 min d'échange"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Avantage 2",
      "default": "Par téléphone ou visio"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Avantage 3",
      "default": "Gratuit et sans engagement"
    },
    {
      "type": "header",
      "content": "Calendly"
    },
    {
      "type": "text",
      "id": "calendly_url",
      "label": "URL Calendly",
      "default": "https://calendly.com/yoann-mylab/premier-contact?text_color=000000&primary_color=1a1a1a"
    },
    {
      "type": "range",
      "id": "calendly_height",
      "label": "Hauteur du widget (px)",
      "min": 500,
      "max": 900,
      "step": 10,
      "default": 660,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Cartes info"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Carte 1 — Titre",
      "default": "Basés en Provence"
    },
    {
      "type": "text",
      "id": "card_1_text",
      "label": "Carte 1 — Texte",
      "default": "231 Avenue de la Voguette, 84300 Cavaillon"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Carte 2 — Titre",
      "default": "Appelez-nous"
    },
    {
      "type": "text",
      "id": "card_2_text",
      "label": "Carte 2 — Texte",
      "default": "04 85 69 33 47"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Carte 3 — Titre",
      "default": "Par email"
    },
    {
      "type": "text",
      "id": "card_3_text",
      "label": "Carte 3 — Texte",
      "default": "contact@mylab-shop.com"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacement haut",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacement bas",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "ML Prise de RDV"
    }
  ]
}
{% endschema %}
