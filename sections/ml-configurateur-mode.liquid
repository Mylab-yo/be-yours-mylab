{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }

  /* ═══════════════════════════════════════
     Base
     ═══════════════════════════════════════ */
  .ml-mode {
    --ml-black: #111;
    --ml-mid: #555;
    --ml-muted: #888;
    --ml-line: #e5e5e5;
    --ml-light-bg: #fafafa;
    --ml-off-bg: #f5f4f2;
    --ml-gold: #755a25;
    --ml-gold-light: #c5a467;
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    color: var(--ml-black);
  }

  /* ═══════════════════════════════════════
     Hero
     ═══════════════════════════════════════ */
  .ml-mode__hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 6rem 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__hero { min-height: 75vh; padding: 8rem 2rem; }
  }
  .ml-mode__hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .ml-mode__hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ml-mode__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(17,17,17,0.9), rgba(17,17,17,0.55), rgba(17,17,17,0.3));
  }
  @media screen and (max-width: 749px) {
    .ml-mode__hero-overlay {
      background: linear-gradient(to bottom, rgba(17,17,17,0.88), rgba(17,17,17,0.6));
    }
  }
  .ml-mode__hero-content {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
  }
  .ml-mode__hero-inner {
    max-width: 42rem;
  }
  .ml-mode__hero-label {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ml-gold-light);
    margin: 0 0 1.5rem;
  }
  .ml-mode__hero-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0 0 1.5rem;
  }
  .ml-mode__hero-title em {
    font-style: italic;
    color: var(--ml-gold-light);
  }
  .ml-mode__hero-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    max-width: 36rem;
    margin: 0 0 2.5rem;
  }
  .ml-mode__hero-price {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 1rem 1.6rem;
    margin-bottom: 2.5rem;
  }
  .ml-mode__hero-price-label {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
  }
  .ml-mode__hero-price-value {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--ml-gold-light);
  }
  .ml-mode__hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__hero-actions { flex-direction: row; gap: 1.5rem; }
  }

  /* Buttons */
  .ml-mode__btn-gold {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--ml-gold) 0%, var(--ml-gold-light) 100%);
    color: #fff;
    padding: 1.2rem 2.6rem;
    font-size: 1.05rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    min-height: 44px;
    box-shadow: 0 10px 24px rgba(117, 90, 37, 0.25);
  }
  .ml-mode__btn-gold:hover { opacity: 0.9; }
  .ml-mode__btn-gold:active { transform: scale(0.97); }
  .ml-mode__btn-gold--xl {
    padding: 1.4rem 3.2rem;
    font-size: 1.2rem;
  }
  .ml-mode__btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: #fff;
    padding: 1.2rem 2.6rem;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer;
    transition: all 0.2s;
    min-height: 44px;
  }
  .ml-mode__btn-outline:hover {
    background: #fff;
    color: var(--ml-black);
  }
  .ml-mode__btn-outline--dark {
    color: var(--ml-black);
    border-color: var(--ml-line);
  }
  .ml-mode__btn-outline--dark:hover {
    background: var(--ml-black);
    color: #fff;
  }

  /* ═══════════════════════════════════════
     Steps (detailed, alternating)
     ═══════════════════════════════════════ */
  .ml-mode__steps {
    padding: 6rem 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__steps { padding: 8rem 2rem; }
  }
  .ml-mode__steps-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .ml-mode__steps-header {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto 5rem;
  }
  .ml-mode__steps-label {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ml-gold);
    margin: 0 0 1rem;
  }
  .ml-mode__steps-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin: 0 0 1rem;
  }
  .ml-mode__steps-subtitle {
    font-size: 1.1rem;
    color: var(--ml-mid);
    line-height: 1.6;
    margin: 0;
  }

  /* Individual step */
  .ml-mode__step {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    padding: 4rem 0;
    border-bottom: 1px solid var(--ml-line);
  }
  .ml-mode__step:last-child { border-bottom: none; }
  @media screen and (min-width: 990px) {
    .ml-mode__step {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
  .ml-mode__step:nth-child(even) .ml-mode__step-visual {
    order: -1;
  }
  @media screen and (max-width: 989px) {
    .ml-mode__step-visual { order: -1; }
  }
  .ml-mode__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ml-gold), var(--ml-gold-light));
    color: #fff;
    font-weight: 700;
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
  }
  .ml-mode__step-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .ml-mode__step-text {
    font-size: 1.1rem;
    color: var(--ml-mid);
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }
  .ml-mode__step-details {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .ml-mode__step-details li {
    position: relative;
    padding-left: 1.8rem;
    margin-bottom: 0.8rem;
    font-size: 1rem;
    color: var(--ml-mid);
    line-height: 1.5;
  }
  .ml-mode__step-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ml-gold), var(--ml-gold-light));
  }
  .ml-mode__step-cost {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--ml-off-bg);
    padding: 0.8rem 1.4rem;
    border-left: 3px solid var(--ml-gold);
  }
  .ml-mode__step-cost-icon {
    flex-shrink: 0;
  }
  .ml-mode__step-cost-icon svg {
    width: 1.2rem;
    height: 1.2rem;
    fill: var(--ml-gold);
  }
  .ml-mode__step-cost-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ml-black);
  }
  .ml-mode__step-image {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--ml-off-bg);
    box-shadow: 0 20px 40px -12px rgba(17,17,17,0.08);
  }
  .ml-mode__step-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ═══════════════════════════════════════
     Pricing
     ═══════════════════════════════════════ */
  .ml-mode__pricing {
    background: var(--ml-off-bg);
    padding: 6rem 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__pricing { padding: 8rem 2rem; }
  }
  .ml-mode__pricing-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .ml-mode__pricing-header {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto 4rem;
  }
  .ml-mode__pricing-label {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ml-gold);
    margin: 0 0 1rem;
  }
  .ml-mode__pricing-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin: 0 0 1rem;
  }
  .ml-mode__pricing-subtitle {
    font-size: 1.1rem;
    color: var(--ml-mid);
    line-height: 1.6;
    margin: 0;
  }
  .ml-mode__pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__pricing-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }
  }

  /* Pricing card */
  .ml-mode__price-card {
    background: #fff;
    padding: 2.5rem 2rem;
    border: 1px solid var(--ml-line);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .ml-mode__price-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px -8px rgba(17,17,17,0.1);
  }
  .ml-mode__price-card--featured {
    border-color: var(--ml-gold);
    position: relative;
  }
  .ml-mode__price-card--featured::before {
    content: attr(data-badge);
    position: absolute;
    top: -0.7rem;
    left: 2rem;
    background: linear-gradient(135deg, var(--ml-gold), var(--ml-gold-light));
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 1rem;
  }
  .ml-mode__price-card-name {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .ml-mode__price-card-desc {
    font-size: 0.95rem;
    color: var(--ml-mid);
    line-height: 1.5;
    margin: 0 0 1.5rem;
  }
  .ml-mode__price-card-price {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 2.8rem;
    font-weight: 600;
    color: var(--ml-gold);
    margin: 0;
    line-height: 1;
  }
  .ml-mode__price-card-unit {
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: var(--ml-mid);
  }
  .ml-mode__price-card-divider {
    width: 100%;
    height: 1px;
    background: var(--ml-line);
    margin: 1.5rem 0;
  }
  .ml-mode__price-card-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    flex: 1;
  }
  .ml-mode__price-card-features li {
    position: relative;
    padding-left: 1.6rem;
    margin-bottom: 0.7rem;
    font-size: 0.95rem;
    color: var(--ml-mid);
    line-height: 1.45;
  }
  .ml-mode__price-card-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--ml-gold);
    font-weight: 700;
  }

  /* ═══════════════════════════════════════
     Advantages
     ═══════════════════════════════════════ */
  .ml-mode__advantages {
    padding: 6rem 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__advantages { padding: 8rem 2rem; }
  }
  .ml-mode__advantages-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .ml-mode__advantages-header {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto 4rem;
  }
  .ml-mode__advantages-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin: 0;
  }
  .ml-mode__advantages-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__advantages-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }
  @media screen and (min-width: 990px) {
    .ml-mode__advantages-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .ml-mode__advantage {
    text-align: center;
    padding: 2.5rem 2rem;
    background: var(--ml-off-bg);
    transition: transform 0.3s;
  }
  .ml-mode__advantage:hover {
    transform: translateY(-2px);
  }
  .ml-mode__advantage-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ml-gold), var(--ml-gold-light));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.2rem;
  }
  .ml-mode__advantage-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    fill: #fff;
  }
  .ml-mode__advantage-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .ml-mode__advantage-text {
    font-size: 0.95rem;
    color: var(--ml-mid);
    line-height: 1.6;
    margin: 0;
  }

  /* ═══════════════════════════════════════
     CTA Final
     ═══════════════════════════════════════ */
  .ml-mode__cta {
    background: var(--ml-black);
    padding: 6rem 1.5rem;
    text-align: center;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__cta { padding: 8rem 2rem; }
  }
  .ml-mode__cta-content {
    max-width: 44rem;
    margin: 0 auto;
  }
  .ml-mode__cta-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    color: #fff;
    line-height: 1.15;
    margin: 0 0 1.5rem;
  }
  .ml-mode__cta-text {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.6);
    margin: 0 0 3rem;
    line-height: 1.6;
  }
  .ml-mode__cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-mode__cta-actions { flex-direction: row; justify-content: center; }
  }
  .ml-mode__cta-link {
    color: var(--ml-gold-light);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(197, 164, 103, 0.3);
    padding-bottom: 0.2rem;
    transition: border-color 0.2s;
    font-size: 1rem;
  }
  .ml-mode__cta-link:hover {
    border-color: var(--ml-gold-light);
  }
{%- endstyle -%}

<div class="ml-mode">

  {%- comment -%} ══ HERO ══ {%- endcomment -%}
  <section class="ml-mode__hero">
    <div class="ml-mode__hero-bg">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1800 }}"
          alt="{{ section.settings.hero_image.alt | default: section.settings.hero_title | strip_html }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
      <div class="ml-mode__hero-overlay"></div>
    </div>

    <div class="ml-mode__hero-content">
      <div class="ml-mode__hero-inner">
        {%- if section.settings.hero_label != blank -%}
          <p class="ml-mode__hero-label">{{ section.settings.hero_label }}</p>
        {%- endif -%}
        <h1 class="ml-mode__hero-title">{{ section.settings.hero_title }}</h1>
        <p class="ml-mode__hero-text">{{ section.settings.hero_text }}</p>

        {%- if section.settings.hero_price_label != blank -%}
          <div class="ml-mode__hero-price">
            <span class="ml-mode__hero-price-label">{{ section.settings.hero_price_label }}</span>
            <span class="ml-mode__hero-price-value">{{ section.settings.hero_price_value }}</span>
          </div>
        {%- endif -%}

        <div class="ml-mode__hero-actions">
          {%- if section.settings.hero_cta_text != blank -%}
            <a href="{{ section.settings.hero_cta_link }}" class="ml-mode__btn-gold">
              {{ section.settings.hero_cta_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.hero_cta2_text != blank -%}
            <a href="{{ section.settings.hero_cta2_link }}" class="ml-mode__btn-outline">
              {{ section.settings.hero_cta2_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ══ STEPS (detailed, alternating) ══ {%- endcomment -%}
  {%- assign step_blocks = section.blocks | where: "type", "step" -%}
  {%- if step_blocks.size > 0 -%}
    <section class="ml-mode__steps">
      <div class="ml-mode__steps-inner">
        <div class="ml-mode__steps-header">
          {%- if section.settings.steps_label != blank -%}
            <p class="ml-mode__steps-label">{{ section.settings.steps_label }}</p>
          {%- endif -%}
          <h2 class="ml-mode__steps-title">{{ section.settings.steps_title }}</h2>
          {%- if section.settings.steps_subtitle != blank -%}
            <p class="ml-mode__steps-subtitle">{{ section.settings.steps_subtitle }}</p>
          {%- endif -%}
        </div>

        {%- for block in step_blocks -%}
          <div class="ml-mode__step" {{ block.shopify_attributes }}>
            <div>
              <div class="ml-mode__step-num">{{ forloop.index }}</div>
              <h3 class="ml-mode__step-title">{{ block.settings.title }}</h3>
              <p class="ml-mode__step-text">{{ block.settings.text }}</p>

              {%- if block.settings.detail_1 != blank -%}
                <ul class="ml-mode__step-details">
                  <li>{{ block.settings.detail_1 }}</li>
                  {%- if block.settings.detail_2 != blank -%}<li>{{ block.settings.detail_2 }}</li>{%- endif -%}
                  {%- if block.settings.detail_3 != blank -%}<li>{{ block.settings.detail_3 }}</li>{%- endif -%}
                  {%- if block.settings.detail_4 != blank -%}<li>{{ block.settings.detail_4 }}</li>{%- endif -%}
                </ul>
              {%- endif -%}

              {%- if block.settings.cost != blank -%}
                <div class="ml-mode__step-cost">
                  <span class="ml-mode__step-cost-icon">
                    <svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
                  </span>
                  <span class="ml-mode__step-cost-text">{{ block.settings.cost }}</span>
                </div>
              {%- endif -%}
            </div>

            <div class="ml-mode__step-visual">
              <div class="ml-mode__step-image">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.image.alt | default: block.settings.title }}"
                    loading="lazy"
                    width="800"
                    height="600"
                  >
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ══ PRICING ══ {%- endcomment -%}
  {%- assign pricing_blocks = section.blocks | where: "type", "pricing_card" -%}
  {%- if pricing_blocks.size > 0 -%}
    <section class="ml-mode__pricing">
      <div class="ml-mode__pricing-inner">
        <div class="ml-mode__pricing-header">
          {%- if section.settings.pricing_label != blank -%}
            <p class="ml-mode__pricing-label">{{ section.settings.pricing_label }}</p>
          {%- endif -%}
          <h2 class="ml-mode__pricing-title">{{ section.settings.pricing_title }}</h2>
          {%- if section.settings.pricing_subtitle != blank -%}
            <p class="ml-mode__pricing-subtitle">{{ section.settings.pricing_subtitle }}</p>
          {%- endif -%}
        </div>

        <div class="ml-mode__pricing-grid">
          {%- for block in pricing_blocks -%}
            <div class="ml-mode__price-card{% if block.settings.featured %} ml-mode__price-card--featured{% endif %}" {% if block.settings.badge != blank %}data-badge="{{ block.settings.badge }}"{% endif %} {{ block.shopify_attributes }}>
              <h3 class="ml-mode__price-card-name">{{ block.settings.name }}</h3>
              <p class="ml-mode__price-card-desc">{{ block.settings.description }}</p>
              <p class="ml-mode__price-card-price">
                {{ block.settings.price }}
                {%- if block.settings.unit != blank -%}
                  <span class="ml-mode__price-card-unit"> {{ block.settings.unit }}</span>
                {%- endif -%}
              </p>
              <div class="ml-mode__price-card-divider"></div>
              {%- if block.settings.feature_1 != blank -%}
                <ul class="ml-mode__price-card-features">
                  <li>{{ block.settings.feature_1 }}</li>
                  {%- if block.settings.feature_2 != blank -%}<li>{{ block.settings.feature_2 }}</li>{%- endif -%}
                  {%- if block.settings.feature_3 != blank -%}<li>{{ block.settings.feature_3 }}</li>{%- endif -%}
                  {%- if block.settings.feature_4 != blank -%}<li>{{ block.settings.feature_4 }}</li>{%- endif -%}
                  {%- if block.settings.feature_5 != blank -%}<li>{{ block.settings.feature_5 }}</li>{%- endif -%}
                </ul>
              {%- endif -%}
              {%- if block.settings.cta_text != blank -%}
                <a href="{{ block.settings.cta_link }}" class="ml-mode__btn-gold" style="width:100%;text-align:center;">
                  {{ block.settings.cta_text }}
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ══ ADVANTAGES ══ {%- endcomment -%}
  {%- assign advantage_blocks = section.blocks | where: "type", "advantage" -%}
  {%- if advantage_blocks.size > 0 -%}
    <section class="ml-mode__advantages">
      <div class="ml-mode__advantages-inner">
        {%- if section.settings.advantages_title != blank -%}
          <div class="ml-mode__advantages-header">
            <h2 class="ml-mode__advantages-title">{{ section.settings.advantages_title }}</h2>
          </div>
        {%- endif -%}

        <div class="ml-mode__advantages-grid">
          {%- for block in advantage_blocks -%}
            <div class="ml-mode__advantage" {{ block.shopify_attributes }}>
              <div class="ml-mode__advantage-icon">
                <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              </div>
              <h4 class="ml-mode__advantage-title">{{ block.settings.title }}</h4>
              <p class="ml-mode__advantage-text">{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ══ CTA FINAL ══ {%- endcomment -%}
  <section class="ml-mode__cta">
    <div class="ml-mode__cta-content">
      <h2 class="ml-mode__cta-title">{{ section.settings.cta_title }}</h2>
      {%- if section.settings.cta_text != blank -%}
        <p class="ml-mode__cta-text">{{ section.settings.cta_text }}</p>
      {%- endif -%}
      <div class="ml-mode__cta-actions">
        {%- if section.settings.cta_button_text != blank -%}
          <a href="{{ section.settings.cta_button_link }}" class="ml-mode__btn-gold ml-mode__btn-gold--xl">
            {{ section.settings.cta_button_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_link_text != blank -%}
          <a href="{{ section.settings.cta_link }}" class="ml-mode__cta-link">
            {{ section.settings.cta_link_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Configurateur Mode",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_label", "label": "\u00c9tiquette", "default": "Mode" },
    { "type": "textarea", "id": "hero_title", "label": "Titre (HTML)", "default": "Titre du mode" },
    { "type": "textarea", "id": "hero_text", "label": "Description" },
    { "type": "text", "id": "hero_price_label", "label": "Label prix hero" },
    { "type": "text", "id": "hero_price_value", "label": "Valeur prix hero" },
    { "type": "text", "id": "hero_cta_text", "label": "Bouton principal", "default": "Commencer" },
    { "type": "url", "id": "hero_cta_link", "label": "Lien bouton principal" },
    { "type": "text", "id": "hero_cta2_text", "label": "Bouton secondaire" },
    { "type": "url", "id": "hero_cta2_link", "label": "Lien bouton secondaire" },
    { "type": "image_picker", "id": "hero_image", "label": "Image de fond" },

    { "type": "header", "content": "\u00c9tapes" },
    { "type": "text", "id": "steps_label", "label": "\u00c9tiquette", "default": "\u00c9tape par \u00e9tape" },
    { "type": "text", "id": "steps_title", "label": "Titre", "default": "Comment \u00e7a marche" },
    { "type": "textarea", "id": "steps_subtitle", "label": "Sous-titre" },

    { "type": "header", "content": "Tarifs" },
    { "type": "text", "id": "pricing_label", "label": "\u00c9tiquette", "default": "Tarifs" },
    { "type": "text", "id": "pricing_title", "label": "Titre", "default": "Une tarification transparente" },
    { "type": "textarea", "id": "pricing_subtitle", "label": "Sous-titre" },

    { "type": "header", "content": "Avantages" },
    { "type": "text", "id": "advantages_title", "label": "Titre", "default": "Pourquoi choisir ce mode" },

    { "type": "header", "content": "CTA final" },
    { "type": "text", "id": "cta_title", "label": "Titre" },
    { "type": "textarea", "id": "cta_text", "label": "Texte" },
    { "type": "text", "id": "cta_button_text", "label": "Bouton", "default": "Commencer" },
    { "type": "url", "id": "cta_button_link", "label": "Lien bouton" },
    { "type": "text", "id": "cta_link_text", "label": "Lien secondaire" },
    { "type": "url", "id": "cta_link", "label": "URL lien secondaire" },

    { "type": "header", "content": "Espacement" },
    { "type": "range", "id": "padding_top", "label": "Marge haute", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Marge basse", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "\u00c9tape",
      "settings": [
        { "type": "text", "id": "title", "label": "Titre", "default": "\u00c9tape" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "detail_1", "label": "D\u00e9tail 1" },
        { "type": "text", "id": "detail_2", "label": "D\u00e9tail 2" },
        { "type": "text", "id": "detail_3", "label": "D\u00e9tail 3" },
        { "type": "text", "id": "detail_4", "label": "D\u00e9tail 4" },
        { "type": "text", "id": "cost", "label": "Co\u00fbt de cette \u00e9tape" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "pricing_card",
      "name": "Carte tarif",
      "settings": [
        { "type": "text", "id": "name", "label": "Nom", "default": "Formule" },
        { "type": "text", "id": "description", "label": "Description" },
        { "type": "text", "id": "price", "label": "Prix", "default": "0\u20ac" },
        { "type": "text", "id": "unit", "label": "Unit\u00e9 (ex: /mois, /impression)" },
        { "type": "text", "id": "badge", "label": "Badge (ex: Populaire)" },
        { "type": "checkbox", "id": "featured", "label": "Mise en avant", "default": false },
        { "type": "text", "id": "feature_1", "label": "Inclus 1" },
        { "type": "text", "id": "feature_2", "label": "Inclus 2" },
        { "type": "text", "id": "feature_3", "label": "Inclus 3" },
        { "type": "text", "id": "feature_4", "label": "Inclus 4" },
        { "type": "text", "id": "feature_5", "label": "Inclus 5" },
        { "type": "text", "id": "cta_text", "label": "Bouton" },
        { "type": "url", "id": "cta_link", "label": "Lien" }
      ]
    },
    {
      "type": "advantage",
      "name": "Avantage",
      "settings": [
        { "type": "text", "id": "title", "label": "Titre", "default": "Avantage" },
        { "type": "textarea", "id": "text", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Configurateur Mode"
    }
  ]
}
{% endschema %}
