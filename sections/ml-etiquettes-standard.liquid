{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }

  /* ═══════════════════════════════════════
     Base
     ═══════════════════════════════════════ */
  .ml-std {
    --ml-black: #111;
    --ml-mid: #555;
    --ml-muted: #888;
    --ml-line: #e5e5e5;
    --ml-light-bg: #fafafa;
    --ml-off-bg: #f5f4f2;
    --ml-green: #2d7a45;
    --ml-gold: #755a25;
    --ml-gold-light: #c5a467;
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    color: var(--ml-black);
  }

  /* ═══════════════════════════════════════
     Hero
     ═══════════════════════════════════════ */
  .ml-std__hero {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .ml-std__hero {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      padding: 5rem 2rem 6rem;
    }
  }
  .ml-std__hero-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .ml-std__hero-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 600;
    font-style: italic;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .ml-std__hero-text {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--ml-mid);
    max-width: 30rem;
    margin: 0;
  }
  .ml-std__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--ml-gold) 0%, var(--ml-gold-light) 100%);
    color: #fff;
    padding: 1.1rem 2.4rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    min-height: 44px;
    box-shadow: 0 8px 20px rgba(117, 90, 37, 0.2);
  }
  .ml-std__btn:hover { opacity: 0.92; }
  .ml-std__btn:active { transform: scale(0.97); }
  .ml-std__btn--large {
    padding: 1.3rem 3rem;
    font-size: 1.15rem;
    box-shadow: 0 12px 28px rgba(117, 90, 37, 0.25);
  }
  .ml-std__btn--dark {
    background: var(--ml-black);
    box-shadow: 0 8px 20px rgba(17, 17, 17, 0.15);
  }

  .ml-std__hero-image {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 48px -12px rgba(17, 17, 17, 0.1);
  }
  .ml-std__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ═══════════════════════════════════════
     Steps
     ═══════════════════════════════════════ */
  .ml-std__steps {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 5rem 1.5rem;
    border-top: 1px solid var(--ml-line);
  }
  @media screen and (min-width: 750px) {
    .ml-std__steps { padding: 6rem 2rem; }
  }
  .ml-std__section-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.2rem, 4vw, 3rem);
    margin: 0 0 3rem;
  }
  .ml-std__steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-std__steps-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
  .ml-std__step-card {
    background: var(--ml-off-bg);
    padding: 2rem;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .ml-std__step-icon {
    width: 3rem;
    height: 3rem;
    background: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 3px rgba(17,17,17,0.06);
    color: var(--ml-gold);
    flex-shrink: 0;
  }
  .ml-std__step-icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .ml-std__step-heading {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .ml-std__step-text {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--ml-mid);
    margin: 0;
  }

  /* ═══════════════════════════════════════
     Avantages
     ═══════════════════════════════════════ */
  .ml-std__advantages {
    background: var(--ml-off-bg);
    padding: 5rem 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-std__advantages { padding: 6rem 2rem; }
  }
  .ml-std__advantages-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .ml-std__advantages-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  @media screen and (min-width: 750px) {
    .ml-std__advantages-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }
  .ml-std__adv-card {
    background: #fff;
    padding: 1.5rem;
    border-radius: 6px;
    box-shadow: 0 1px 3px rgba(17,17,17,0.04);
    border: 1px solid var(--ml-line);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .ml-std__adv-icon {
    color: var(--ml-gold);
  }
  .ml-std__adv-icon svg {
    width: 26px;
    height: 26px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .ml-std__adv-heading {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
  }
  .ml-std__adv-text {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ml-mid);
    margin: 0;
  }

  /* ═══════════════════════════════════════
     Exemples
     ═══════════════════════════════════════ */
  .ml-std__examples {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 6rem 1.5rem;
  }
  @media screen and (min-width: 750px) {
    .ml-std__examples { padding: 7rem 2rem; }
  }
  .ml-std__examples-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 750px) {
    .ml-std__examples-grid {
      grid-template-columns: repeat({{ section.settings.examples_columns | default: 3 }}, 1fr);
      gap: 2rem;
    }
  }
  .ml-std__example {
    cursor: pointer;
  }
  .ml-std__example-img {
    aspect-ratio: 1;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 48px -12px rgba(17, 17, 17, 0.08);
    margin-bottom: 1rem;
    background: var(--ml-off-bg);
  }
  .ml-std__example-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .ml-std__example:hover .ml-std__example-img img {
    transform: scale(1.05);
  }
  .ml-std__example-name {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-size: 1.4rem;
    font-weight: 500;
    margin: 0 0 0.2rem;
    padding-left: 0.3rem;
  }
  .ml-std__example-label {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ml-muted);
    margin: 0;
    padding-left: 0.3rem;
  }

  /* ═══════════════════════════════════════
     CTA final
     ═══════════════════════════════════════ */
  .ml-std__cta {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }
  @media screen and (min-width: 750px) {
    .ml-std__cta { padding: 0 2rem 7rem; }
  }
  .ml-std__cta-box {
    background: var(--ml-off-bg);
    border-radius: 14px;
    padding: 4rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    position: relative;
    overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    .ml-std__cta-box { padding: 5rem 3rem; }
  }
  .ml-std__cta-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.08;
    z-index: 0;
  }
  .ml-std__cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 40rem;
  }
  .ml-std__cta-title {
    font-family: 'Cormorant Garamond', var(--font-heading-family), serif;
    font-weight: 600;
    font-style: italic;
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    line-height: 1.15;
    margin: 0;
  }
  .ml-std__cta-sub {
    font-size: 1rem;
    color: var(--ml-mid);
    max-width: 28rem;
    line-height: 1.6;
    margin: 0;
  }
{%- endstyle -%}

<div class="ml-std">

  {%- comment -%} ══ HERO ══ {%- endcomment -%}
  <section class="ml-std__hero">
    <div class="ml-std__hero-content">
      <h1 class="ml-std__hero-title">{{ section.settings.hero_title }}</h1>
      <p class="ml-std__hero-text">{{ section.settings.hero_text }}</p>
      {%- if section.settings.hero_cta_text != blank -%}
        <div>
          <a href="{{ section.settings.hero_cta_link }}" class="ml-std__btn">
            {{ section.settings.hero_cta_text }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="ml-std__hero-image">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 800 }}"
          alt="{{ section.settings.hero_image.alt | default: section.settings.hero_title }}"
          loading="eager"
          width="800"
          height="600"
        >
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ══ COMMENT ÇA MARCHE ══ {%- endcomment -%}
  <section class="ml-std__steps">
    <h2 class="ml-std__section-title">{{ section.settings.steps_title }}</h2>

    <div class="ml-std__steps-grid">
      {%- comment -%} Étape 1 — Panier {%- endcomment -%}
      <div class="ml-std__step-card">
        <div class="ml-std__step-icon">
          <svg viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        </div>
        <h3 class="ml-std__step-heading">{{ section.settings.step_1_title }}</h3>
        <p class="ml-std__step-text">{{ section.settings.step_1_text }}</p>
      </div>

      {%- comment -%} Étape 2 — Upload {%- endcomment -%}
      <div class="ml-std__step-card">
        <div class="ml-std__step-icon">
          <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <h3 class="ml-std__step-heading">{{ section.settings.step_2_title }}</h3>
        <p class="ml-std__step-text">{{ section.settings.step_2_text }}</p>
      </div>

      {%- comment -%} Étape 3 — PDF {%- endcomment -%}
      <div class="ml-std__step-card">
        <div class="ml-std__step-icon">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 class="ml-std__step-heading">{{ section.settings.step_3_title }}</h3>
        <p class="ml-std__step-text">{{ section.settings.step_3_text }}</p>
      </div>
    </div>
  </section>

  {%- comment -%} ══ AVANTAGES ══ {%- endcomment -%}
  {%- assign adv_blocks = section.blocks | where: "type", "advantage" -%}
  {%- if adv_blocks.size > 0 -%}
    <section class="ml-std__advantages">
      <div class="ml-std__advantages-inner">
        <h2 class="ml-std__section-title">{{ section.settings.advantages_title }}</h2>

        <div class="ml-std__advantages-grid">
          {%- for block in adv_blocks -%}
            <div class="ml-std__adv-card" {{ block.shopify_attributes }}>
              <div class="ml-std__adv-icon">
                {%- case block.settings.icon -%}
                  {%- when 'check' -%}
                    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {%- when 'timer' -%}
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- when 'infinity' -%}
                    <svg viewBox="0 0 24 24"><path d="M18.178 8c5.096 0 5.096 8 0 8-5.095 0-7.133-8-12.739-8-4.585 0-4.585 8 0 8 5.606 0 7.644-8 12.74-8Z"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {%- endcase -%}
              </div>
              <h3 class="ml-std__adv-heading">{{ block.settings.title }}</h3>
              <p class="ml-std__adv-text">{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ══ EXEMPLES ══ {%- endcomment -%}
  {%- assign ex_blocks = section.blocks | where: "type", "example" -%}
  {%- if ex_blocks.size > 0 -%}
    <section class="ml-std__examples">
      <h2 class="ml-std__section-title">{{ section.settings.examples_title }}</h2>

      <div class="ml-std__examples-grid">
        {%- for block in ex_blocks -%}
          <div class="ml-std__example" {{ block.shopify_attributes }}>
            <div class="ml-std__example-img">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.name }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <h3 class="ml-std__example-name">{{ block.settings.name }}</h3>
            <p class="ml-std__example-label">{{ block.settings.subtitle }}</p>
          </div>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ══ CTA FINAL ══ {%- endcomment -%}
  <section class="ml-std__cta">
    <div class="ml-std__cta-box">
      {%- if section.settings.cta_bg_image != blank -%}
        <div class="ml-std__cta-bg" style="background-image:url('{{ section.settings.cta_bg_image | image_url: width: 1600 }}');"></div>
      {%- endif -%}

      <div class="ml-std__cta-content">
        <h2 class="ml-std__cta-title">{{ section.settings.cta_title }}</h2>
        {%- if section.settings.cta_button_text != blank -%}
          <a href="{{ section.settings.cta_button_link }}" class="ml-std__btn ml-std__btn--large">
            {{ section.settings.cta_button_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_sub_text != blank -%}
          <p class="ml-std__cta-sub">{{ section.settings.cta_sub_text }}</p>
        {%- endif -%}
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "\u00c9tiquettes standard",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Titre",
      "default": "Vos produits \u00e0 votre image, en 3 clics"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Description",
      "default": "Ajoutez votre logo sur nos \u00e9tiquettes professionnelles. Gratuit, rapide, sans engagement."
    },
    {
      "type": "text",
      "id": "hero_cta_text",
      "label": "Bouton CTA",
      "default": "Personnaliser mes \u00e9tiquettes"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "Lien CTA"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero"
    },
    {
      "type": "header",
      "content": "Comment \u00e7a marche"
    },
    {
      "type": "text",
      "id": "steps_title",
      "label": "Titre section",
      "default": "Comment \u00e7a marche"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "\u00c9tape 1 \u2014 titre",
      "default": "Choisissez vos gammes"
    },
    {
      "type": "textarea",
      "id": "step_1_text",
      "label": "\u00c9tape 1 \u2014 texte",
      "default": "S\u00e9lectionnez parmi nos gammes professionnelles : Volume, Lissant, Boucles, HA Repulpe, Homme\u2026"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "\u00c9tape 2 \u2014 titre",
      "default": "Uploadez votre logo"
    },
    {
      "type": "textarea",
      "id": "step_2_text",
      "label": "\u00c9tape 2 \u2014 texte",
      "default": "Importez le logo de votre salon. On l\u2019applique automatiquement sur l\u2019\u00e9tiquette."
    },
    {
      "type": "text",
      "id": "step_3_title",
      "label": "\u00c9tape 3 \u2014 titre",
      "default": "T\u00e9l\u00e9chargez votre r\u00e9cap"
    },
    {
      "type": "textarea",
      "id": "step_3_text",
      "label": "\u00c9tape 3 \u2014 texte",
      "default": "Recevez un r\u00e9capitulatif PDF avec vos visuels personnalis\u00e9s. Passez commande quand vous \u00eates pr\u00eat."
    },
    {
      "type": "header",
      "content": "Avantages"
    },
    {
      "type": "text",
      "id": "advantages_title",
      "label": "Titre section",
      "default": "Avantages"
    },
    {
      "type": "header",
      "content": "Exemples"
    },
    {
      "type": "text",
      "id": "examples_title",
      "label": "Titre section",
      "default": "Exemples de r\u00e9alisations"
    },
    {
      "type": "range",
      "id": "examples_columns",
      "label": "Colonnes desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "CTA final"
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "Titre",
      "default": "Pr\u00eat \u00e0 personnaliser vos produits ?"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Bouton",
      "default": "Commencer maintenant \u2014 C\u2019est gratuit"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "Lien bouton"
    },
    {
      "type": "textarea",
      "id": "cta_sub_text",
      "label": "Texte secondaire",
      "default": "Vous cherchez plus de personnalisation ? D\u00e9couvrez nos mod\u00e8les d\u2019\u00e9tiquettes ou notre studio de cr\u00e9ation."
    },
    {
      "type": "image_picker",
      "id": "cta_bg_image",
      "label": "Image de fond CTA"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
