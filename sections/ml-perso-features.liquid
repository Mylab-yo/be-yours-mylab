{%- style -%}
  .ml-perso-features {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
  }
  .ml-perso-features__inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .ml-perso-features__heading {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 4rem;
  }
  .ml-perso-features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }
  .ml-perso-feature {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 1.6rem;
    padding: 2.5rem 2rem;
    text-align: left;
    transition: transform 0.3s;
  }
  .ml-perso-feature:hover {
    transform: translateY(-4px);
  }
  .ml-perso-feature__icon {
    width: 4.8rem;
    height: 4.8rem;
    background: {{ section.settings.text_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .ml-perso-feature__icon svg {
    width: 2.2rem;
    height: 2.2rem;
    color: {{ section.settings.bg_color }};
  }
  .ml-perso-feature__title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.8rem;
  }
  .ml-perso-feature__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.3rem;
    color: {{ section.settings.muted_color }};
    line-height: 1.6;
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .ml-perso-features {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    .ml-perso-features__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }
{%- endstyle -%}

<div class="ml-perso-features">
  <div class="ml-perso-features__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ml-perso-features__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ml-perso-features__grid">
      {%- for block in section.blocks -%}
        <div class="ml-perso-feature" {{ block.shopify_attributes }}>
          <div class="ml-perso-feature__icon">
            {%- case block.settings.icon -%}
              {%- when 'palette' -%}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" />
                </svg>
              {%- when 'shield' -%}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              {%- when 'truck' -%}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                </svg>
              {%- when 'sparkles' -%}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                </svg>
              {%- when 'certificate' -%}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                </svg>
            {%- endcase -%}
          </div>
          <h3 class="ml-perso-feature__title">{{ block.settings.title }}</h3>
          <p class="ml-perso-feature__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Perso — Avantages",
  "tag": "section",
  "class": "ml-perso-features-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Pourquoi personnaliser avec MyLab ?"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond",
      "default": "#F5F4F2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Couleur texte secondaire",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Bordure des cartes",
      "default": "#E5E5E5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Avantage",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icone",
          "options": [
            { "value": "palette", "label": "Palette (design)" },
            { "value": "shield", "label": "Bouclier (qualité)" },
            { "value": "truck", "label": "Camion (livraison)" },
            { "value": "sparkles", "label": "Etoiles (premium)" },
            { "value": "certificate", "label": "Document (conformité)" }
          ],
          "default": "sparkles"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Design unique"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Chaque étiquette est conçue pour refléter l'identité de votre marque."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perso — Avantages",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "palette",
            "title": "Design sur mesure",
            "description": "Personnalisez chaque détail de votre étiquette : logo, typographie, couleurs et textes réglementaires."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "certificate",
            "title": "Conforme CPNP",
            "description": "Toutes nos étiquettes respectent la réglementation cosmétique européenne. Mentions INCI incluses."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "sparkles",
            "title": "Visualisation 3D",
            "description": "Prévisualisez votre produit fini en temps réel avant de passer commande."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Livraison rapide",
            "description": "Vos produits étiquetés sont expédiés sous 48h après validation de votre design."
          }
        }
      ]
    }
  ]
}
{% endschema %}
