{% comment %}
  MyLab Shop — Calculateur de Profit
  sections/ml-profit-calculator.liquid
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ============================================================
     CALCULATEUR DE PROFIT — MyLab
     ============================================================ */

  .ml-calc-section {
    width: 100%;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  .ml-calc {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 3rem;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .ml-calc__card {
    box-sizing: border-box;
    min-width: 0;
    max-width: 100%;
  }

  @media screen and (max-width: 989px) {
    .ml-calc {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  /* --- Intro --- */
  .ml-calc__intro-eyebrow {
    display: inline-block;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 1.2rem;
  }

  .ml-calc__intro-title {
    font-size: clamp(2.8rem, 4vw, 4.4rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 2rem;
    color: #111;
  }

  .ml-calc__intro-desc {
    font-size: 1.6rem;
    line-height: 1.75;
    color: rgba(17,17,17,0.6);
    margin: 0 0 3rem;
    max-width: 480px;
  }

  .ml-calc__intro-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .ml-calc__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.4rem;
    background: #f5f5f5;
    border-radius: 50px;
    font-size: 1.3rem;
    font-weight: 500;
    color: #444;
  }

  /* --- Carte calculateur --- */
  .ml-calc__card {
    background: #ffffff;
    border: 1px solid #ebebeb;
    border-radius: 24px;
    padding: 3.2rem;
    box-shadow: 0 8px 48px rgba(0,0,0,0.07);
  }

  /* Sélecteur produit */
  .ml-calc__product-selector {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-bottom: 2.8rem;
    padding-bottom: 2.4rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .ml-calc__product-select {
    width: 100%;
    padding: 0.9rem 1.2rem;
    font-family: 'DM Sans', var(--font-body-family), sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #fafafa;
    color: #111;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23555' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1.2rem center;
    padding-right: 3rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .ml-calc__product-select:focus {
    outline: none;
    border-color: #111;
  }
  .ml-calc__product-select optgroup {
    font-weight: 600;
    font-size: 1.1rem;
  }

  .ml-calc__product-info {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    min-width: 0;
  }

  .ml-calc__product-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    border-radius: 10px;
    background: #f8f8f8;
    flex-shrink: 0;
  }

  .ml-calc__product-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    background: #f0f0f0;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ml-calc__product-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: #111;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ml-calc__product-volume {
    font-size: 1.3rem;
    color: #999;
    margin-top: 3px;
  }

  /* Slider */
  .ml-calc__slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .ml-calc__slider-label {
    font-size: 1.4rem;
    font-weight: 600;
    color: #111;
  }

  .ml-calc__slider-badge {
    background: #111;
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 50px;
    min-width: 42px;
    text-align: center;
  }

  .ml-calc__slider {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 5px;
    border-radius: 3px;
    background: #e0e0e0;
    outline: none;
    cursor: pointer;
    margin-bottom: 0.8rem;
  }

  .ml-calc__slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #111;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    transition: transform 0.1s;
  }

  .ml-calc__slider::-webkit-slider-thumb:hover {
    transform: scale(1.1);
  }

  .ml-calc__slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #111;
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .ml-calc__tier-hint {
    font-size: 1.2rem;
    color: #888;
    margin-bottom: 2.4rem;
    min-height: 1.8rem;
  }

  .ml-calc__tier-hint--best {
    color: #2d7a45;
    font-weight: 500;
  }

  /* Onglets */
  .ml-calc__tabs {
    display: flex;
    background: #f5f5f5;
    border-radius: 50px;
    padding: 4px;
    gap: 4px;
    margin-bottom: 2.4rem;
  }

  .ml-calc__tab {
    flex: 1;
    padding: 8px 16px;
    border: none;
    border-radius: 50px;
    font-size: 1.3rem;
    font-weight: 500;
    cursor: pointer;
    background: transparent;
    color: #777;
    transition: background 0.15s, color 0.15s;
    font-family: inherit;
    white-space: nowrap;
  }

  .ml-calc__tab.is-active {
    background: #111;
    color: #fff;
  }

  /* Résultats */
  .ml-calc__results {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.4rem;
  }

  .ml-calc__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .ml-calc__row-label {
    font-size: 1.4rem;
    color: #777;
  }

  .ml-calc__row-value {
    font-size: 1.45rem;
    font-weight: 500;
    color: #111;
    white-space: nowrap;
  }

  .ml-calc__row--total {
    padding-top: 1.4rem;
    margin-top: 0.4rem;
    border-top: 1px solid #ebebeb;
  }

  .ml-calc__row--total .ml-calc__row-label {
    font-size: 1.7rem;
    font-weight: 700;
    color: #111;
  }

  .ml-calc__row--total .ml-calc__row-value {
    font-size: 1.9rem;
    font-weight: 700;
    color: #111;
  }

  /* CTA */
  .ml-calc__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 1.4rem 2.4rem;
    background: #111;
    color: #fff;
    border-radius: 50px;
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
    font-family: inherit;
  }

  .ml-calc__cta:hover {
    background: #333;
    color: #fff;
  }

  .ml-calc__footnote {
    font-size: 1.2rem;
    color: #bbb;
    text-align: center;
    margin-top: 1.6rem;
    line-height: 1.6;
  }

  /* ============================================================
     RESPONSIVE — Tablette (≤ 989px)
     ============================================================ */
  @media screen and (max-width: 989px) {
    .ml-calc {
      padding: 0 2.4rem;
    }

    .ml-calc__intro {
      text-align: center;
    }

    .ml-calc__intro-desc {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .ml-calc__intro-badges {
      justify-content: center;
    }

    .ml-calc__intro-title {
      font-size: clamp(2.4rem, 5vw, 3.6rem);
    }
  }

  /* ============================================================
     RESPONSIVE — Mobile (≤ 749px)
     ============================================================ */
  @media screen and (max-width: 749px) {
    .ml-calc {
      padding: 0 1.6rem;
      gap: 3.2rem;
    }

    /* Carte : padding réduit, contrainte absolue de largeur */
    .ml-calc__card {
      padding: 2rem 1.6rem;
      border-radius: 18px;
      width: 100%;
      max-width: calc(100vw - 3.2rem);
      overflow: hidden;
    }

    .ml-calc__product-selector {
      gap: 1rem;
      margin-bottom: 2rem;
      padding-bottom: 2rem;
    }

    .ml-calc__product-img,
    .ml-calc__product-placeholder {
      width: 48px;
      height: 48px;
    }

    .ml-calc__product-name {
      font-size: 1.4rem;
      white-space: normal;
      word-break: break-word;
    }

    .ml-calc__product-select {
      padding: 1.1rem 3rem 1.1rem 1.2rem;
      min-height: 44px;
    }

    /* Slider : thumb plus grand pour le touch */
    .ml-calc__slider {
      height: 6px;
      margin-bottom: 1rem;
    }

    .ml-calc__slider::-webkit-slider-thumb {
      width: 28px;
      height: 28px;
    }

    .ml-calc__slider::-moz-range-thumb {
      width: 28px;
      height: 28px;
    }

    .ml-calc__slider-badge {
      font-size: 1.4rem;
      padding: 5px 14px;
    }

    .ml-calc__tier-hint {
      font-size: 1.15rem;
      margin-bottom: 2rem;
    }

    /* Onglets : wrapping autorisé, nowrap supprimé */
    .ml-calc__tabs {
      gap: 3px;
    }

    .ml-calc__tab {
      font-size: 1.15rem;
      padding: 7px 8px;
      white-space: normal;
      text-align: center;
      line-height: 1.3;
    }

    /* Lignes résultats */
    .ml-calc__row {
      flex-wrap: wrap;
      gap: 0.3rem;
    }

    .ml-calc__row-label {
      font-size: 1.3rem;
      flex: 1 1 50%;
      white-space: normal;
    }

    .ml-calc__row-value {
      font-size: 1.35rem;
      text-align: right;
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .ml-calc__row--total .ml-calc__row-label {
      font-size: 1.5rem;
    }

    .ml-calc__row--total .ml-calc__row-value {
      font-size: 1.6rem;
    }

    /* Slider badge : ne doit pas déborder */
    .ml-calc__slider-header {
      gap: 0.8rem;
    }

    /* CTA : padding généreux pour le touch */
    .ml-calc__cta {
      padding: 1.6rem 2rem;
      font-size: 1.45rem;
    }

    /* Titre intro */
    .ml-calc__intro-title {
      font-size: clamp(2.4rem, 7vw, 3.2rem);
    }

    .ml-calc__intro-desc {
      font-size: 1.5rem;
    }
  }

  /* ============================================================
     RESPONSIVE — Très petit mobile (≤ 390px)
     ============================================================ */
  @media screen and (max-width: 390px) {
    .ml-calc {
      padding: 0 1.2rem;
    }

    .ml-calc__card {
      padding: 1.6rem 1.4rem;
    }

    .ml-calc__tabs {
      flex-direction: column;
      border-radius: 14px;
    }

    .ml-calc__tab {
      border-radius: 10px;
      text-align: center;
    }
  }
</style>

<section class="ml-calc-section color-{{ section.settings.color_scheme }} gradient">
  <div class="ml-calc">

    {%- comment -%} ===== INTRO GAUCHE ===== {%- endcomment -%}
    <div class="ml-calc__intro">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ml-calc__intro-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="ml-calc__intro-title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="ml-calc__intro-desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="ml-calc__intro-badges">
        <span class="ml-calc__badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#2d7a45" stroke-width="1.5" stroke-linecap="round"/></svg>
          Tarifs dégressifs
        </span>
        <span class="ml-calc__badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#2d7a45" stroke-width="1.5" stroke-linecap="round"/></svg>
          Formules professionnelles
        </span>
        <span class="ml-calc__badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#2d7a45" stroke-width="1.5" stroke-linecap="round"/></svg>
          Sans engagement
        </span>
      </div>
    </div>

    {%- comment -%} ===== CARTE CALCULATEUR ===== {%- endcomment -%}
    <div class="ml-calc__card" id="ml-calc-card-{{ section.id }}">

      {%- comment -%} Sélecteur produit — dropdown {%- endcomment -%}
      <div class="ml-calc__product-selector">
        <select class="ml-calc__product-select" id="ml-calc-select-{{ section.id }}" aria-label="Choisir un produit">
          <option value="" disabled selected>Choisissez un produit…</option>
        </select>
      </div>
      <div class="ml-calc__product-info" id="ml-calc-product-{{ section.id }}" style="display:none;">
        <div class="ml-calc__product-placeholder">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" opacity="0.3"><path d="M3 7h18l-2 13H5L3 7z" stroke="currentColor" stroke-width="1.5"/><path d="M8 7V5a4 4 0 018 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="ml-calc__product-name"></div>
          <div class="ml-calc__product-volume"></div>
        </div>
      </div>

      {%- comment -%} Slider quantité {%- endcomment -%}
      <div class="ml-calc__slider-header">
        <span class="ml-calc__slider-label">Quantité</span>
        <span class="ml-calc__slider-badge" id="ml-calc-qty-{{ section.id }}">—</span>
      </div>
      <input
        type="range"
        class="ml-calc__slider"
        id="ml-calc-slider-{{ section.id }}"
        min="1" max="200" value="12"
        aria-label="Quantité"
      >
      <div class="ml-calc__tier-hint" id="ml-calc-hint-{{ section.id }}"></div>

      {%- comment -%} Onglets {%- endcomment -%}
      <div class="ml-calc__tabs">
        <button class="ml-calc__tab" data-tab="savings">Économies</button>
        <button class="ml-calc__tab is-active" data-tab="roi">Retour sur investissement</button>
      </div>

      {%- comment -%} Résultats {%- endcomment -%}
      <div class="ml-calc__results" id="ml-calc-results-{{ section.id }}"></div>

      {%- comment -%} Bouton — visible uniquement pour les clients tagués "pro" ou "dossier-valide" {%- endcomment -%}
      {%- assign is_pro = false -%}
      {%- if customer -%}
        {%- for tag in customer.tags -%}
          {%- assign tag_lower = tag | downcase -%}
          {%- if tag_lower == 'pro' or tag_lower == 'dossier-valide' -%}
            {%- assign is_pro = true -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if is_pro -%}
        <a href="{{ section.settings.cta_link | default: '/pages/la-boutique-my-lab' }}" class="ml-calc__cta" id="ml-calc-cta-{{ section.id }}" data-is-pro="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h12M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {{ section.settings.cta_label | default: 'Commander maintenant' }}
        </a>
      {%- else -%}
        <a href="{{ section.settings.cta_link_guest | default: '/pages/contact' }}" class="ml-calc__cta" id="ml-calc-cta-{{ section.id }}" style="background:#555;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h12M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {{ section.settings.cta_label_guest | default: 'Obtenir mon dossier cosmétologique' }}
        </a>
      {%- endif -%}

      {%- if section.settings.footnote != blank -%}
        <p class="ml-calc__footnote">{{ section.settings.footnote }}</p>
      {%- endif -%}

    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  var sectionId = {{ section.id | json }};
  var mapUrl = {{ 'ml-product-map.json' | asset_url | json }};
  var retailMultiplier = {{ section.settings.retail_multiplier | default: 2.5 }};

  // DOM
  var elSelect  = document.getElementById('ml-calc-select-' + sectionId);
  var elProduct = document.getElementById('ml-calc-product-' + sectionId);
  var elSlider  = document.getElementById('ml-calc-slider-' + sectionId);
  var elQty     = document.getElementById('ml-calc-qty-' + sectionId);
  var elHint    = document.getElementById('ml-calc-hint-' + sectionId);
  var elResults = document.getElementById('ml-calc-results-' + sectionId);
  var elCta     = document.getElementById('ml-calc-cta-' + sectionId);
  var tabs      = document.querySelectorAll('#ml-calc-card-' + sectionId + ' .ml-calc__tab');

  if (!elSelect || !elSlider) return;

  var products = [];
  var state = { productIndex: -1, qty: 0, tab: 'roi' };

  /* ── Gammes pour le regroupement ── */
  var gammeOrder = ['Shampoings', 'Masques capillaires', 'Crèmes de coiffage sans rinçage', 'Sérums', 'Huiles', 'Sprays réparateurs', 'Produits de finition', 'Gamme Homme', 'Gamme Déjaunisseur / Coloristeur'];

  function fmt(cents) {
    return (cents / 100).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '\u00a0\u20ac';
  }

  function parseTiers(tierStr) {
    return tierStr.split(',').map(function(t) {
      var p = t.split(':');
      return { qty: parseInt(p[0], 10), price: parseInt(p[1], 10) };
    });
  }

  function getPricePerUnit(tiers, qty) {
    var price = tiers[0].price;
    for (var i = 0; i < tiers.length; i++) {
      if (qty >= tiers[i].qty) price = tiers[i].price;
    }
    return price;
  }

  function getNextTier(tiers, qty) {
    for (var i = 0; i < tiers.length; i++) {
      if (qty < tiers[i].qty) return tiers[i];
    }
    return null;
  }

  /* ── Charger la product map et construire la liste ── */
  fetch(mapUrl)
    .then(function(r) { return r.json(); })
    .then(function(map) {
      var byGamme = {};

      Object.keys(map).forEach(function(handle) {
        var entry = map[handle];
        if (!entry.tiers || !entry.gamme) return;
        var gamme = entry.gamme;
        if (!byGamme[gamme]) byGamme[gamme] = [];

        /* Pour chaque taille disponible, créer un produit */
        Object.keys(entry.sizes).forEach(function(size) {
          var tierStr = entry.tiers[size];
          if (!tierStr) return;
          var tiers = parseTiers(tierStr);
          var sizeHandle = entry.sizes[size];
          var sizeLabel = size + 'ml';
          var label = handle.replace(/-/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });

          byGamme[gamme].push({
            index: products.length,
            label: label + ' ' + sizeLabel,
            volume: sizeLabel,
            handle: sizeHandle,
            tiers: tiers,
            retailPrice: Math.round(tiers[0].price * retailMultiplier),
            maxQty: Math.min(tiers[tiers.length - 1].qty * 3, 500),
            url: '/products/' + sizeHandle,
            image: null
          });

          products.push(byGamme[gamme][byGamme[gamme].length - 1]);
        });
      });

      /* Construire le dropdown avec optgroups */
      gammeOrder.forEach(function(gamme) {
        if (!byGamme[gamme] || byGamme[gamme].length === 0) return;
        var group = document.createElement('optgroup');
        group.label = gamme;
        byGamme[gamme].forEach(function(p) {
          var opt = document.createElement('option');
          opt.value = p.index;
          opt.textContent = p.label;
          group.appendChild(opt);
        });
        elSelect.appendChild(group);
      });

      /* Charger les images en arrière-plan */
      products.forEach(function(p) {
        fetch('/products/' + p.handle + '.js')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.featured_image) {
              p.image = data.featured_image.replace(/\.([^.]+)$/, '_200x200.$1');
            }
            if (state.productIndex === p.index) renderProduct();
          })
          .catch(function() {});
      });
    })
    .catch(function(err) {
      console.error('ML Calc: impossible de charger la product map', err);
    });

  /* ── Render ── */
  function updateSlider(p) {
    var minQty = p.tiers[0].qty;
    var maxSlider = p.maxQty > 0 ? p.maxQty : p.tiers[p.tiers.length - 1].qty * 3;
    elSlider.min = minQty;
    elSlider.max = maxSlider;
    state.qty = Math.max(minQty, Math.min(state.qty || minQty, maxSlider));
    elSlider.value = state.qty;
  }

  function updateSliderTrack() {
    var min = parseFloat(elSlider.min);
    var max = parseFloat(elSlider.max);
    var val = parseFloat(elSlider.value);
    var pct = ((val - min) / (max - min)) * 100;
    elSlider.style.background = 'linear-gradient(to right, #111 ' + pct + '%, #e0e0e0 ' + pct + '%)';
  }

  function renderProduct() {
    var p = products[state.productIndex];
    if (!p) return;

    var imgHtml = p.image
      ? '<img src="' + p.image + '" alt="' + p.label + '" class="ml-calc__product-img">'
      : '<div class="ml-calc__product-placeholder"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" opacity="0.3"><path d="M3 7h18l-2 13H5L3 7z" stroke="currentColor" stroke-width="1.5"/></svg></div>';

    elProduct.style.display = '';
    elProduct.innerHTML = imgHtml +
      '<div><div class="ml-calc__product-name">' + p.label + '</div>' +
      '<div class="ml-calc__product-volume">' + p.volume + '</div></div>';

    if (elCta && p.url && elCta.dataset.isPro === 'true') {
      elCta.href = p.url;
    }

    updateSlider(p);
    renderResults();
  }

  function renderResults() {
    if (state.productIndex < 0) return;
    var p = products[state.productIndex];
    var qty = state.qty;
    var priceUnit = getPricePerUnit(p.tiers, qty);
    var totalCost = priceUnit * qty;
    var retailUnit = p.retailPrice;
    var totalEarnings = retailUnit * qty;
    var profit = totalEarnings - totalCost;
    var roi = totalCost > 0 ? Math.round((profit / totalCost) * 100) : 0;
    var catalogUnit = p.tiers[0].price;
    var catalogTotal = catalogUnit * qty;
    var savings = catalogTotal - totalCost;

    elQty.textContent = qty;
    updateSliderTrack();

    var next = getNextTier(p.tiers, qty);
    if (next) {
      var diff = next.qty - qty;
      elHint.textContent = 'Encore\u00a0' + diff + '\u00a0unit\u00e9' + (diff > 1 ? 's' : '') + ' pour atteindre\u00a0' + fmt(next.price) + '/unit\u00e9';
      elHint.className = 'ml-calc__tier-hint';
    } else {
      elHint.textContent = 'Vous b\u00e9n\u00e9ficiez du meilleur tarif !';
      elHint.className = 'ml-calc__tier-hint ml-calc__tier-hint--best';
    }

    var html = '';
    if (state.tab === 'roi') {
      html =
        '<div class="ml-calc__row"><span class="ml-calc__row-label">PVC conseill\u00e9 (unit\u00e9)</span><span class="ml-calc__row-value">' + fmt(retailUnit) + '</span></div>' +
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Prix d\'achat (' + qty + ' unit\u00e9s)</span><span class="ml-calc__row-value">' + fmt(totalCost) + '</span></div>' +
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Total b\u00e9n\u00e9fices clients</span><span class="ml-calc__row-value">' + fmt(totalEarnings) + '</span></div>' +
        '<div class="ml-calc__row ml-calc__row--total"><span class="ml-calc__row-label">Votre profit</span><span class="ml-calc__row-value">' + fmt(profit) + '</span></div>' +
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Retour sur investissement</span><span class="ml-calc__row-value">' + roi + '\u00a0%</span></div>';
    } else {
      html =
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Prix unitaire catalogue</span><span class="ml-calc__row-value">' + fmt(catalogUnit) + '</span></div>' +
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Votre prix unitaire</span><span class="ml-calc__row-value">' + fmt(priceUnit) + '</span></div>' +
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Total catalogue (' + qty + ' unit\u00e9s)</span><span class="ml-calc__row-value">' + fmt(catalogTotal) + '</span></div>' +
        '<div class="ml-calc__row ml-calc__row--total"><span class="ml-calc__row-label">\u00c9conomies r\u00e9alis\u00e9es</span><span class="ml-calc__row-value">' + fmt(savings) + '</span></div>' +
        '<div class="ml-calc__row"><span class="ml-calc__row-label">Prix d\'achat total</span><span class="ml-calc__row-value">' + fmt(totalCost) + '</span></div>';
    }
    elResults.innerHTML = html;
  }

  /* ── Événements ── */
  elSelect.addEventListener('change', function() {
    state.productIndex = parseInt(elSelect.value, 10);
    renderProduct();
  });

  elSlider.addEventListener('input', function() {
    state.qty = parseInt(elSlider.value, 10);
    renderResults();
  });

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      state.tab = tab.dataset.tab;
      tabs.forEach(function(t) { t.classList.remove('is-active'); });
      tab.classList.add('is-active');
      renderResults();
    });
  });

})();
</script>

