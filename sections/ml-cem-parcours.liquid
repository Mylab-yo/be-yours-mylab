    box-shadow: 0 14px 28px -12px rgba(26,26,26,0.12);
  }
  .ml-cem__product-img {
    aspect-ratio: 4 / 5;
    background: var(--cem-cream-2);
    border-radius: 0;
    overflow: hidden;
    margin-bottom: 0.2rem;
    position: relative;
  }
  .ml-cem__product-img::after {
