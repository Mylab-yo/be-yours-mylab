  }

  /* bandeau preuve — signature pharmacien + mentions réglementaires */
  .ml-cem__dossier-proof {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: 1.2rem 2rem;
    padding: 1.4rem 0;
    border-top: 1px solid rgba(117,90,37,0.2);
    border-bottom: 1px solid rgba(117,90,37,0.2);
    margin: 0 0 2rem;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1.094rem; letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cem-dark);
  }
  .ml-cem__dossier-proof span { display: inline-flex; align-items: center; gap: 0.6rem; }
  .ml-cem__dossier-proof span::before {
    content: ''; width: 14px; height: 1px; background: var(--cem-gold);
  }
  .ml-cem__dossier-details {
    background: #fff; border-radius: 14px; padding: 1.2rem 1.6rem;
    border: 1px solid var(--cem-line);
  }
  .ml-cem__dossier-details summary {
    cursor: pointer; list-style: none;
    font-weight: 600; display: flex; justify-content: space-between; align-items: center;
    padding: 0.5rem 0;
  }
  .ml-cem__dossier-details summary::-webkit-details-marker { display: none; }
  .ml-cem__dossier-details[open] summary::after { transform: rotate(45deg); }
  .ml-cem__dossier-details summary::after {
    content: '+'; font-size: 1.4rem; color: var(--cem-gold);
    transition: transform 0.25s;
  }
  .ml-cem__dossier-list {
    list-style: none; padding: 1rem 0 0.4rem 0; margin: 0;
