{%- comment -%}
  Parcours unifié "Créons ensemble votre marque"
  Section mono-fichier — hero + 4 étapes + récap sticky + JS state manager
{%- endcomment -%}

{%- liquid
  assign pro_col   = collections[section.settings.products_collection]
  assign forfait_couleur_variant = 55418356793678
  assign forfait_couleur_plan    = 690138775886
  assign forfait_noire_variant   = 55418362003790
  assign forfait_noire_plan      = 690138743118
-%}

{%- style -%}

  /* ═══════ ZOOM TYPO DESKTOP +20% ═══════ */
  @media screen and (min-width: 750px) {
    .ml-cem { font-size: 1.2em; }
  }

  #shopify-section-{{ section.id }} {
    padding: 0;
    --cem-gold: #c5a467;
    --cem-gold-dark: #755a25;
    --cem-dark: #1a1a1a;
    --cem-cream: #f5f0eb;
    --cem-cream-2: #fefaf7;
    --cem-line: #e5e5e5;
    --cem-mid: #555;
    --cem-muted: #888;
    --cem-success: #2d7a45;
  }

  .ml-cem { font-family: 'DM Sans', var(--font-body-family), sans-serif; color: var(--cem-dark); }
  .ml-cem *, .ml-cem *::before, .ml-cem *::after { box-sizing: border-box; }
  .ml-cem em, .ml-cem__h em {
    font-family: 'DM Sans', sans-serif;
    color: inherit;
    font-weight: 700;
    font-style: normal;
  }
  .ml-cem__h {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .ml-cem__eyebrow {
    font-size: 1.152rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cem-dark);
    margin: 0 0 0.8rem;
  }
  .ml-cem__btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.6rem;
    padding: 1.1rem 2.6rem;
    border-radius: 999px;
    font-size: 1rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: transform 0.18s, opacity 0.2s, background 0.25s, color 0.25s;
    min-height: 52px;
  }
  .ml-cem__btn:hover { opacity: 0.92; }
  .ml-cem__btn:active { transform: scale(0.97); }
  .ml-cem__btn--primary { background: var(--cem-dark); color: #fff; box-shadow: 0 12px 28px rgba(17,17,17,0.18); }
  .ml-cem__btn--gold { background: linear-gradient(135deg, var(--cem-gold-dark) 0%, var(--cem-gold) 100%); color: #fff; box-shadow: 0 12px 28px rgba(117,90,37,0.22); }
  .ml-cem__btn--ghost { background: transparent; color: var(--cem-dark); border: 1.5px solid var(--cem-dark); }
  .ml-cem__btn[disabled] { opacity: 0.35; cursor: not-allowed; transform: none; }

  /* ═══════════════════════════════════════ FADE-UP SCROLL REVEAL ═══════════════════════════════════════ */
  @media (prefers-reduced-motion: no-preference) {
    .ml-cem [data-ml-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
      transition-delay: var(--ml-reveal-delay, 0ms);
    }
    .ml-cem [data-ml-reveal].is-in {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ═══════════════════════════════════════ TWEAKS PANEL ═══════════════════════════════════════ */
  .ml-cem__tweaks {
    position: fixed; bottom: 5.5rem; right: 1rem;
    width: 260px; max-width: calc(100vw - 2rem);
    background: #fff;
    border: 1px solid rgba(117,90,37,0.25);
    border-radius: 2px;
    padding: 1rem 1rem 1.1rem;
    box-shadow: 0 18px 44px -14px rgba(17,17,17,0.25);
    z-index: 9998;
    font-family: 'DM Sans', sans-serif;
    display: none;
  }
  .ml-cem__tweaks::before,
  .ml-cem__tweaks::after {
    content: ''; position: absolute;
    width: 10px; height: 10px;
    border: 1px solid var(--cem-gold);
  }
  .ml-cem__tweaks::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .ml-cem__tweaks::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
  @media screen and (min-width: 1024px) {
    .ml-cem__tweaks { bottom: 1.5rem; right: 1.5rem; }
  }
  .ml-cem__tweaks[data-open="true"] { display: block; }
  .ml-cem__tweaks-title {
    font-family: 'DM Mono', monospace;
    font-size: 1.238rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--cem-dark); font-weight: 600;
    margin: 0 0 0.7rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid rgba(117,90,37,0.15);
    display: flex; justify-content: space-between; align-items: center;
  }
  .ml-cem__tweaks-close {
    background: none; border: none; cursor: pointer;
    font-size: 1.32rem; line-height: 1; color: var(--cem-mid);
    padding: 0 0.2rem;
  }
  .ml-cem__tweaks-row {
    display: flex; flex-direction: column; gap: 0.35rem;
    margin-bottom: 0.8rem;
  }
  .ml-cem__tweaks-row:last-child { margin-bottom: 0; }
  .ml-cem__tweaks-label {
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cem-mid);
  }
  .ml-cem__tweaks-seg {
    display: grid; grid-template-columns: 1fr 1fr;
    border: 1px solid rgba(117,90,37,0.2);
    border-radius: 2px;
    overflow: hidden;
  }
  .ml-cem__tweaks-seg button {
    border: none; background: transparent;
    padding: 0.5rem 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.123rem; font-weight: 700;
    color: var(--cem-mid); cursor: pointer;
    transition: all 0.2s;
  }
  .ml-cem__tweaks-seg button + button {
    border-left: 1px solid rgba(117,90,37,0.2);
  }
  .ml-cem__tweaks-seg button[data-active="true"] {
    background: var(--cem-dark); color: #fff;
  }
  .ml-cem__tweaks-toggle-btn {
    position: fixed; bottom: 5.5rem; right: 1rem;
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--cem-dark); color: var(--cem-gold);
    border: 1px solid var(--cem-gold);
    cursor: pointer;
    z-index: 9997;
    display: none;
    align-items: center; justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.1em;
    box-shadow: 0 8px 20px -6px rgba(0,0,0,0.3);
  }
  @media screen and (min-width: 1024px) {
    .ml-cem__tweaks-toggle-btn { bottom: 1.5rem; right: 1.5rem; }
  }
  .ml-cem[data-tweaks-on="true"] .ml-cem__tweaks-toggle-btn { display: flex; }

  /* ═══════════════════════════════════════ HERO — split Oribe ═══════════════════════════════════════ */
  .ml-cem__hero {
    position: relative;
    background: var(--cem-cream);
    color: var(--cem-dark);
    overflow: hidden;
    padding: 5.2rem 1.25rem 2.6rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    text-align: left;
    min-height: auto;
  }
  /* millésime — coin haut-droit, discret monospace */
  .ml-cem__hero::before {
    content: 'N° 01 — MMXXVI';
    position: absolute; top: 1.4rem; right: 1.25rem;
    font-family: 'DM Mono', ui-monospace, 'SFMono-Regular', monospace;
    font-size: 1.094rem; letter-spacing: 0.2em;
    color: var(--cem-dark); opacity: 0.78;
    z-index: 3;
  }
  /* mention PARIS · LAB — coin bas-gauche */
  .ml-cem__hero::after {
    content: 'PARIS · LAB';
    position: absolute; bottom: 1.2rem; left: 1.4rem;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1.238rem; letter-spacing: 0.22em;
    color: var(--cem-dark); opacity: 0.75;
    z-index: 3;
  }
  .ml-cem__hero-bg {
    position: relative;
    order: -1;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 2px;
    box-shadow: 0 24px 48px -20px rgba(26,26,26,0.25);
  }
  .ml-cem__hero-bg video, .ml-cem__hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    filter: saturate(0.88) contrast(1.02);
  }
  .ml-cem__hero-bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(175deg, transparent 55%, rgba(26,26,26,0.18) 100%);
  }
  .ml-cem__hero-content {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    gap: 1.1rem;
    padding: 0 0.2rem;
    max-width: 34rem;
  }
  .ml-cem__hero-eyebrow {
    font-size: 1.152rem;
    letter-spacing: 0.22em;
    text-transform: uppercase; font-weight: 700;
    color: var(--cem-dark);
    display: inline-flex; align-items: center; gap: 0.6rem;
  }
  .ml-cem__hero-eyebrow::before {
    content: ''; display: inline-block;
    width: 28px; height: 1px; background: var(--cem-gold);
  }
  .ml-cem__hero-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2.4rem, 6.2vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--cem-dark);
    margin: 0;
    text-wrap: balance;
  }
  .ml-cem__hero-title em {
    color: inherit;
    font-weight: 700;
  }
  /* filet signature sous le titre */
  .ml-cem__hero-title::after {
    content: ''; display: block;
    width: 48px; height: 1px;
    background: var(--cem-gold);
    margin-top: 1.2rem;
  }
  .ml-cem__hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1.15rem, 4.2vw, 1.35rem);
    line-height: 1.45;
    color: var(--cem-mid);
    max-width: 32rem;
    margin: 0;
    text-wrap: pretty;
  }
  .ml-cem__hero-ctas {
    display: flex; gap: 0.7rem; flex-wrap: wrap;
    margin-top: 0.4rem;
  }
  /* CTA primaire = dark plein (dominant), CTA alt = ghost dark */
  .ml-cem__hero .ml-cem__btn--gold {
    background: var(--cem-dark);
    color: #fff;
    box-shadow: 0 12px 28px -10px rgba(26,26,26,0.35);
    padding: 1rem 1.8rem;
    font-size: 1.181rem;
  }
  .ml-cem__hero .ml-cem__btn--gold:hover {
    background: #000; opacity: 1;
    box-shadow: 0 16px 36px -12px rgba(26,26,26,0.45);
  }
  .ml-cem__hero-cta-secondary {
    background: transparent;
    color: var(--cem-dark);
    border: 1px solid var(--cem-dark);
    padding: 1rem 1.6rem;
    font-size: 1.181rem;
    font-weight: 600;
  }
  .ml-cem__hero-cta-secondary:hover {
    background: var(--cem-dark); color: #fff; opacity: 1;
  }
  .ml-cem__trust {
    position: relative; z-index: 1;
    display: flex; flex-wrap: wrap;
    gap: 0.3rem 1.6rem;
    margin-top: 1.4rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgba(117,90,37,0.18);
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1.123rem; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cem-dark);
  }
  .ml-cem__trust-item {
    display: inline-flex; align-items: center;
    gap: 0.5rem;
  }
  .ml-cem__trust-item::before {
    content: ''; display: inline-block;
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--cem-gold);
    margin: 0;
    font-size: inherit;
  }
  .ml-cem__trust-item:first-child::before { display: inline-block; }

  /* Desktop : split 2 colonnes — uniquement >= 1024px pour garder titre + image confortables */
  @media screen and (min-width: 1024px) {
    .ml-cem__hero {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 3.2rem;
      padding: 7rem 3rem 5rem;
      align-items: center;
    }
    .ml-cem__hero::before { top: 2rem; right: 3rem; font-size: 1.181rem; }
    .ml-cem__hero::after { bottom: 2rem; left: 3rem; font-size: 1.152rem; }
    .ml-cem__hero-bg {
      order: 1;
      aspect-ratio: 4 / 5;
      max-height: 72vh;
    }
    .ml-cem__hero-content {
      padding: 1rem 0 1rem 2rem;
      border-left: 1px solid rgba(117,90,37,0.22);
    }
  }
  @media screen and (min-width: 1280px) {
    .ml-cem__hero {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
      padding: 8rem 4.5rem 6rem;
      gap: 4.5rem;
    }
    .ml-cem__hero-title { font-size: clamp(3.4rem, 4.8vw, 5rem); }
  }

  /* Tablette intermédiaire 750-1023px : conserve layout empilé mais avec hauteur image réduite */
  @media screen and (min-width: 750px) and (max-width: 1023px) {
    .ml-cem__hero {
      padding: 5rem 3rem 4rem;
    }
    .ml-cem__hero-title { font-size: clamp(3rem, 6vw, 4rem); }
    .ml-cem__hero-bg {
      aspect-ratio: 16 / 9;
      max-height: 480px;
    }
  }

  /* Variante hero B (Tweaks) : overlay La Bouche Rouge — image plein fond, bloc texte ancré */
  .ml-cem[data-hero-variant="B"] .ml-cem__hero {
    grid-template-columns: 1fr;
    gap: 0;
    padding: 0;
    min-height: 72vh;
    color: #fff;
    background: #1a1a1a;
    align-items: stretch;
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-bg {
    position: absolute; inset: 0;
    aspect-ratio: auto;
    border-radius: 0;
    box-shadow: none;
    order: 0;
    max-height: none;
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-bg img,
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-bg video {
    object-position: center 30%;
    filter: saturate(0.85) contrast(1) brightness(0.92);
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-bg::after {
    background:
      linear-gradient(90deg, rgba(26,26,26,0.78) 0%, rgba(26,26,26,0.45) 45%, rgba(26,26,26,0.25) 100%),
      linear-gradient(180deg, rgba(26,26,26,0.35) 0%, rgba(26,26,26,0.55) 100%);
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-content {
    position: relative; z-index: 2;
    align-self: end;
    justify-self: start;
    padding: 2rem 1.5rem 5rem;
    border-left: none;
    max-width: 40rem;
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-eyebrow,
  .ml-cem[data-hero-variant="B"] .ml-cem__hero::before,
  .ml-cem[data-hero-variant="B"] .ml-cem__hero::after {
    color: #e8c685;
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-title { color: #fff; }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-title em { color: #e8c685; }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-title::after { background: #e8c685; }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-sub { color: rgba(255,255,255,0.82); }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero .ml-cem__btn--gold {
    background: #fff; color: var(--cem-dark); box-shadow: 0 12px 28px -8px rgba(0,0,0,0.45);
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-cta-secondary {
    color: #fff; border-color: rgba(255,255,255,0.55);
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__hero-cta-secondary:hover {
    background: #fff; color: var(--cem-dark);
  }
  .ml-cem[data-hero-variant="B"] .ml-cem__trust {
    border-top-color: rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.75);
  }
  @media screen and (min-width: 750px) {
    .ml-cem[data-hero-variant="B"] .ml-cem__hero { padding: 0; }
    .ml-cem[data-hero-variant="B"] .ml-cem__hero-content {
      padding: 3rem 4rem 6rem;
      max-width: 50rem;
    }
  }

  /* ═══════════════════════════════════════ ÉTAPES — shell commun ═══════════════════════════════════════ */
  .ml-cem__step {
    padding: 4.5rem 1.25rem;
    scroll-margin-top: 80px;
    position: relative;
  }
  @media screen and (min-width: 750px) {
    .ml-cem__step { padding: 6.5rem 3rem; }
  }
  @media screen and (min-width: 1100px) {
    .ml-cem__step { padding: 7.5rem 4.5rem; }
  }
  .ml-cem__step-inner {
    max-width: 88rem; margin: 0 auto;
  }
  .ml-cem__step--produits .ml-cem__step-inner,
  .ml-cem__step--recap .ml-cem__step-inner {
    max-width: 96rem;
  }
  .ml-cem__step-head {
    text-align: left; max-width: 100%;
    margin: 0 0 2.4rem;
    display: flex; flex-direction: column; gap: 1.1rem; align-items: flex-start;
  }
  /* cartouche noire: étape XX/04 — forcer shrink-to-content dans flex column */
  .ml-cem__step-head::before {
    align-self: flex-start !important;
    width: fit-content;
    max-width: fit-content;
    flex: 0 0 auto;
  }
  /* dédoublonne : on cache l'eyebrow HTML puisque le cartouche porte déjà l'étape */
  .ml-cem__step-head .ml-cem__eyebrow {
    display: none;
  }
  .ml-cem__step-head h2 {
    font-size: clamp(2.2rem, 7vw, 3.4rem);
  }
  .ml-cem__step-intro {
    font-family: 'DM Sans', sans-serif !important;
    font-style: normal !important;
    font-size: 1.2rem; line-height: 1.65; color: var(--cem-mid); margin: 0;
  }

  /* ═══════════════════════════════════════ ÉTAPE 1 — DOSSIER ═══════════════════════════════════════ */
  .ml-cem__step--dossier { background: var(--cem-cream); position: relative; }
  /* ornement : filet + numéro étape monospace en haut */
  .ml-cem__step--dossier .ml-cem__step-head { position: relative; text-align: left; max-width: 100%; margin: 0 0 2.4rem; align-items: flex-start; }
  .ml-cem__step--dossier .ml-cem__step-head::before {
    content: 'ÉTAPE 01 / 04';
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1rem; font-weight: 600; letter-spacing: 0.2em;
    color: #fff !important;
    background: #1a1a1a !important;
    padding: 0.6rem 1.1rem !important;
    border-radius: 4px !important;
    display: inline-block !important;
    align-self: flex-start !important;
    width: fit-content !important;
    margin-bottom: 1rem !important;
    line-height: 1 !important;
  }
  .ml-cem__step--dossier .ml-cem__eyebrow { color: var(--cem-dark); font-size: 1.181rem; letter-spacing: 0.2em; }
  .ml-cem__step--dossier .ml-cem__h {
    font-size: clamp(2.2rem, 7vw, 3.4rem);
    max-width: 22ch;
    text-wrap: balance;
  }
  .ml-cem__step--dossier .ml-cem__step-intro {
    font-size: 1.2rem; line-height: 1.6;
    max-width: 36rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.38rem;
  }
  .ml-cem__pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: 2.4rem;
    border-top: 1px solid rgba(117,90,37,0.2);
  }
  @media screen and (min-width: 750px) {
    .ml-cem__pillars { grid-template-columns: repeat(3, 1fr); gap: 0; }
  }
  .ml-cem__pillar {
    position: relative;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(117,90,37,0.2);
    border-radius: 0;
    padding: 1.8rem 0 1.8rem;
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1.4rem;
    row-gap: 0.35rem;
    align-items: baseline;
  }
  @media screen and (min-width: 750px) {
    .ml-cem__pillar {
      grid-template-columns: 1fr;
      border-bottom: none;
      border-right: 1px solid rgba(117,90,37,0.2);
      padding: 2.2rem 1.8rem 2.2rem 0;
    }
    .ml-cem__pillar + .ml-cem__pillar { padding-left: 1.8rem; }
    .ml-cem__pillar:last-child { border-right: none; padding-right: 0; }
  }
  /* numéro XXL Cormorant en outline or */
  .ml-cem__pillar::before {
    content: attr(data-step-n);
    font-family: 'DM Sans', sans-serif;
    font-size: 3.4rem;
    font-weight: 700;
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 1px var(--cem-gold);
    grid-row: span 4;
    align-self: start;
    margin-top: 0.2rem;
  }
  @media screen and (min-width: 750px) {
    .ml-cem__pillar::before {
      font-size: 4.2rem;
      grid-row: auto;
      margin-bottom: 0.6rem;
    }
  }
  .ml-cem__pillar-icon { display: none; } /* icônes retirées — les numéros portent l'identité */
  .ml-cem__pillar-name {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1.152rem; letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cem-dark); font-weight: 600;
    margin-bottom: 0.1rem;
  }
  .ml-cem__pillar-title {
