    background: rgba(45, 122, 69, 0.08);
    color: var(--cem-dark);
  }
  .ml-cem__forfait-callout[data-state="skipped"]::before { background: var(--cem-success); }
  .ml-cem__forfait-callout-inner { display: flex; flex-direction: column; gap: 0.3rem; flex: 1; min-width: 0; }
  .ml-cem__forfait-callout-tag {
    font-family: 'DM Mono', monospace;
    font-size: 1.094rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--cem-gold); font-weight: 600;
  }
  .ml-cem__forfait-callout[data-state="skipped"] .ml-cem__forfait-callout-tag { color: var(--cem-success); }
  .ml-cem__forfait-callout-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.25rem; font-weight: 700; line-height: 1.3;
    color: inherit;
  }
  .ml-cem__forfait-callout-price {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700; font-style: normal; font-size: 1.55rem;
    letter-spacing: -0.01em;
    color: var(--cem-gold);
  }
  .ml-cem__forfait-callout-price small {
    font-size: 1.181rem; font-family: 'DM Mono', monospace;
    color: rgba(255,255,255,0.6); font-weight: 400; font-style: normal;
    letter-spacing: 0.12em;
  }
  .ml-cem__forfait-callout[data-state="skipped"] .ml-cem__forfait-callout-price {
    color: var(--cem-success);
    font-size: 1.296rem; font-family: 'DM Mono', monospace;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; font-style: normal;
  }
  /* UX retournement empty : on "prépare" au lieu de "déterminer" */
  .ml-cem__forfait-callout[data-state="empty"] .ml-cem__forfait-callout-tag::after {
    content: ' → étape suivante'; opacity: 0.6;
  }

  /* ═══════════════════════════════════════ ÉTAPE 3 — PRODUITS ═══════════════════════════════════════ */
  .ml-cem__step--products { background: var(--cem-cream); }
  .ml-cem__step--products .ml-cem__step-head {
    text-align: left; max-width: 100%; align-items: flex-start;
    margin: 0 0 2rem;
  }
  .ml-cem__step--products .ml-cem__step-head::before {
    content: 'ÉTAPE 03 / 04';
    font-family: 'DM Mono', monospace;
    font-size: 1rem; font-weight: 600; letter-spacing: 0.2em;
    color: #fff !important;
    background: #1a1a1a !important;
    padding: 0.6rem 1.1rem !important;
    border-radius: 4px !important;
    display: inline-block !important;
    align-self: flex-start !important;
    width: fit-content !important;
    margin-bottom: 1rem !important;
    line-height: 1 !important;
