  <div class="ml-cem__modal" id="ml-cem-modal" data-modal role="dialog" aria-label="Configurateur de design" aria-modal="true" inert>
    <div class="ml-cem__modal-frame">
      <button type="button" class="ml-cem__modal-close" data-modal-close aria-label="Fermer le configurateur">×</button>
      <div class="ml-cem__modal-loader" data-modal-loader>Chargement du configurateur…</div>
      <div class="ml-cem__modal-error" data-modal-error>
        <p>Impossible de charger le configurateur.</p>
        <a href="https://mylab-configurateur.vercel.app/configurateur" target="_blank" rel="noopener" class="ml-cem__btn ml-cem__btn--primary">Ouvrir dans un nouvel onglet</a>
      </div>
      <iframe class="ml-cem__modal-iframe" data-modal-iframe title="Configurateur MY.LAB" allow="clipboard-write; fullscreen" loading="lazy"></iframe>
    </div>
  </div>

</div>

<script>
  (function(){
    'use strict';
    var root = document.getElementById('ml-cem');
    if (!root) return;

    var state = {
      dossierVariant: 59234431041870,
      dossierPriceCents: 38990,
      label: null,              // { option, variantId, priceCents, alreadyInCart }
      products: {},             // { handle: { variantId, qty, unitPriceCents, title } }
    };

    // Mapping forfait impression par type d'étiquette — doit matcher ml-forfait-gate.js
    var FORFAITS = {
      'standard':   { variantId: 55418362003790, sellingPlanId: 690138743118, priceCents: 9900,  name: "Forfait d'impression noire",   tag: 'abo-impression-noire' },
      'modeles':    { variantId: 55418356793678, sellingPlanId: 690138775886, priceCents: 25000, name: "Forfait d'impression couleur", tag: 'abo-impression-couleur' },
      'sur-mesure': { variantId: 55418356793678, sellingPlanId: 690138775886, priceCents: 25000, name: "Forfait d'impression couleur", tag: 'abo-impression-couleur' }
    };

    function customerHasTag(tag) {
      var tags = (window.MylabForfaitGate && window.MylabForfaitGate.customerTags) || [];
      return tags.indexOf(tag) >= 0;
    }

    function activeForfait() {
      if (!state.label) return null;
      var f = FORFAITS[state.label.option];
      if (!f) return null;
      if (customerHasTag(f.tag)) return { skipped: true };
      return f;
    }

    var toastEl = root.querySelector('[data-toast]');
    var toastTimer;
    function toast(msg) {
      if (!toastEl) return;
      toastEl.textContent = msg;
      toastEl.setAttribute('data-show', 'true');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function(){ toastEl.removeAttribute('data-show'); }, 2400);
    }

    function eur(cents) {
      var v = cents / 100;
      return v.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
    }

    function total() {
      var t = state.dossierPriceCents;
      if (state.label) t += state.label.priceCents;
      var fa = activeForfait();
      if (fa && !fa.skipped) t += fa.priceCents;
      Object.keys(state.products).forEach(function(h){
        t += state.products[h].lineCents;
      });
      return t;
    }

    function productCount() {
      var n = 0;
      Object.keys(state.products).forEach(function(h){ n += state.products[h].qty; });
      return n;
    }

    function updateForfaitCallout() {
      var callout = root.querySelector('[data-forfait-callout]');
      if (!callout) return;
      var nameEl = callout.querySelector('[data-forfait-name]');
      var priceEl = callout.querySelector('[data-forfait-price]');

      if (!state.label) {
        callout.setAttribute('data-state', 'empty');
        if (nameEl) nameEl.textContent = "À déterminer selon votre choix d'étiquette";
        if (priceEl) priceEl.textContent = '—';
        return;
      }
      var f = FORFAITS[state.label.option];
      if (!f) {
        callout.setAttribute('data-state', 'empty');
        return;
      }
      if (customerHasTag(f.tag)) {
        callout.setAttribute('data-state', 'skipped');
        if (nameEl) nameEl.textContent = "Vous êtes déjà abonné·e à " + f.name.toLowerCase() + " — rien à ajouter";
        if (priceEl) priceEl.textContent = '✓ déjà actif';
        return;
      }
      callout.setAttribute('data-state', 'active');
      if (nameEl) nameEl.textContent = f.name + " · ajouté à la validation";
      if (priceEl) priceEl.innerHTML = (f.priceCents/100) + '<small>&nbsp;€ / an</small>';
    }

    function renderRecap() {
      var labelEl = root.querySelector('[data-recap-label] .ml-cem__recap-value');
      if (labelEl) {
        if (state.label) {
          var names = { 'standard': 'Design MY.LAB (gratuit)', 'modeles': 'Modèle graphique (99 €)', 'sur-mesure': 'Sur mesure (390 € + solde)' };
          labelEl.textContent = names[state.label.option] || state.label.option;
          labelEl.classList.remove('ml-cem__recap-empty');
        } else {
          labelEl.textContent = 'à choisir';
          labelEl.classList.add('ml-cem__recap-empty');
        }
      }

      // Ajoute/maj une ligne récap "Forfait impression" si pertinent
      var linesEl = root.querySelector('[data-recap-lines]');
      if (linesEl) {
        var existingForfait = linesEl.querySelector('[data-recap-forfait]');
        var fa = activeForfait();
        if (fa && !fa.skipped) {
          if (!existingForfait) {
            existingForfait = document.createElement('li');
            existingForfait.className = 'ml-cem__recap-line';
            existingForfait.setAttribute('data-recap-forfait', '');
            existingForfait.innerHTML = '<span class="ml-cem__recap-label"></span><span class="ml-cem__recap-value"></span>';
            linesEl.appendChild(existingForfait);
          }
          existingForfait.querySelector('.ml-cem__recap-label').textContent = fa.name + ' (1 an)';
          existingForfait.querySelector('.ml-cem__recap-value').textContent = eur(fa.priceCents);
        } else if (existingForfait) {
          existingForfait.remove();
        }
      }

      var prodEl = root.querySelector('[data-recap-products] .ml-cem__recap-value');
      if (prodEl) {
        var n = productCount();
        if (n > 0) {
          var prodTotal = 0;
          Object.keys(state.products).forEach(function(h){
            prodTotal += state.products[h].lineCents;
          });
          prodEl.textContent = n + ' article' + (n > 1 ? 's' : '') + ' — ' + eur(prodTotal);
          prodEl.classList.remove('ml-cem__recap-empty');
        } else {
          prodEl.textContent = '0 article';
          prodEl.classList.add('ml-cem__recap-empty');
        }
      }

      root.querySelectorAll('[data-recap-total]').forEach(function(el){ el.textContent = eur(total()); });
      root.querySelectorAll('[data-sticky-total]').forEach(function(el){ el.textContent = eur(total()); });

      root.querySelectorAll('[data-sticky="label"]').forEach(function(el){
        el.setAttribute('data-done', state.label ? 'true' : 'false');
      });
      root.querySelectorAll('[data-sticky="products"]').forEach(function(el){
        el.setAttribute('data-done', productCount() > 0 ? 'true' : 'false');
      });

      root.querySelectorAll('[data-tl="label"]').forEach(function(el){
        el.setAttribute('data-done', state.label ? 'true' : 'false');
        var ic = el.querySelector('.ml-cem__tl-icon');
        if (ic) ic.textContent = state.label ? '✓' : '2';
      });
      root.querySelectorAll('[data-tl="products"]').forEach(function(el){
        var done = productCount() > 0;
        el.setAttribute('data-done', done ? 'true' : 'false');
        var ic = el.querySelector('.ml-cem__tl-icon');
        if (ic) ic.textContent = done ? '✓' : '3';
      });

      var completed = 1 + (state.label ? 1 : 0) + (productCount() > 0 ? 1 : 0);
      root.setAttribute('data-complete', completed === 3 ? 'true' : 'false');
      var bbSteps = root.querySelector('[data-bottombar-steps]');
      if (bbSteps) bbSteps.textContent = completed + '/3 étape' + (completed > 1 ? 's' : '');

      updateForfaitCallout();
    }

    // ─── Étape 2 : sélection d'option étiquette ───
    function selectLabel(card, opts) {
      opts = opts || {};
      var option = card.getAttribute('data-label-option');
      var variantId = card.getAttribute('data-variant-id');
      var priceCents = parseInt(card.getAttribute('data-price-cents'), 10) || 0;

      state.label = { option: option, variantId: variantId, priceCents: priceCents };
      root.querySelectorAll('[data-label-option]').forEach(function(c){
        c.setAttribute('data-selected', c === card ? 'true' : 'false');
      });
      renderRecap();

      if (!opts.silent) {
        toast('Option étiquette enregistrée : ' + card.querySelector('.ml-cem__option-title').textContent.trim());
      }
    }

    // ─── Configurateur embed modal ───
    var CONFIGURATEUR_URL = 'https://mylab-configurateur.vercel.app/configurateur';
    var MODE_MAP = { 'standard': 'standard', 'modeles': 'template', 'sur-mesure': 'studio' };
    var CONFIGURATEUR_ORIGIN = 'https://mylab-configurateur.vercel.app';

    var modalEl     = root.querySelector('[data-modal]');
    var modalIframe = root.querySelector('[data-modal-iframe]');
    var modalClose  = root.querySelector('[data-modal-close]');
    var modalLoader = root.querySelector('[data-modal-loader]');
    var modalError  = root.querySelector('[data-modal-error]');
    var openingCard = null;   // the label card that triggered the modal
    var loadTimer   = null;

    function openConfigModal(card) {
      if (!modalEl || !modalIframe) return;
      var option = card.getAttribute('data-label-option');
      var mode = MODE_MAP[option];
      if (!mode) return;
      openingCard = card;

      var parentOrigin = window.location.origin;
      var url = CONFIGURATEUR_URL
        + '?embed=1&mode=' + encodeURIComponent(mode)
        + '&parentOrigin=' + encodeURIComponent(parentOrigin);

      modalLoader.hidden = false;
      modalError.removeAttribute('data-show');
      modalIframe.src = url;
      modalEl.setAttribute('data-open', 'true');
      modalEl.removeAttribute('inert');
      document.body.setAttribute('data-ml-cem-modal-open', 'true');

      clearTimeout(loadTimer);
      loadTimer = setTimeout(function(){
        // Iframe didn't reach onload within 12s — surface the error fallback.
        if (!modalLoader.hidden) modalError.setAttribute('data-show', 'true');
      }, 12000);
    }

    function closeConfigModal() {
      if (!modalEl) return;
      modalEl.removeAttribute('data-open');
      modalEl.setAttribute('inert', '');
      document.body.removeAttribute('data-ml-cem-modal-open');
      modalIframe.src = 'about:blank';
      clearTimeout(loadTimer);
      openingCard = null;
    }

    if (modalIframe) {
      modalIframe.addEventListener('load', function(){
        if (modalIframe.src === 'about:blank') return;
        modalLoader.hidden = true;
      });
    }
    if (modalClose) modalClose.addEventListener('click', closeConfigModal);
    if (modalEl) modalEl.addEventListener('click', function(e){
      if (e.target === modalEl) closeConfigModal();
    });
    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape' && modalEl && modalEl.getAttribute('data-open') === 'true') closeConfigModal();
    });

    function applyDesignToCard(card, design) {
      // design: { mode, reference, variantId, cartLabel, templateName, previewImageUrl, logoUrl, rangeNames }
      card.setAttribute('data-design-ready', 'true');
      if (design.variantId) card.setAttribute('data-variant-id', String(design.variantId));

      var thumb = card.querySelector('[data-preview-thumb]');
      var refEl = card.querySelector('[data-preview-ref]');
      var labelEl = card.querySelector('[data-preview-label]');
      if (thumb && design.previewImageUrl) thumb.style.backgroundImage = 'url(' + design.previewImageUrl + ')';
      if (refEl) refEl.textContent = design.reference || '';
      if (labelEl) labelEl.textContent = design.templateName || design.cartLabel || 'Design validé';

      var addBtn = card.querySelector('[data-option-add]');
      if (addBtn) {
        addBtn.textContent = '✓ Design validé';
        addBtn.disabled = false;
      }
    }

    window.addEventListener('message', function(event){
      if (event.origin !== CONFIGURATEUR_ORIGIN) return;
      var data = event.data;
      if (!data || typeof data !== 'object' || data.type !== 'design:ready') return;
      if (!openingCard) return;

      var card = openingCard;
      // Update state.label with the resolved variant + embedded design payload
      var priceCents = parseInt(card.getAttribute('data-price-cents'), 10) || 0;
      state.label = {
        option: card.getAttribute('data-label-option'),
        variantId: data.variantId || card.getAttribute('data-variant-id'),
        priceCents: priceCents,
        design: {
          reference: data.reference || null,
          mode: data.mode || null,
          templateName: data.templateName || null,
          previewImageUrl: data.previewImageUrl || null,
          logoUrl: data.logoUrl || null,
          rangeNames: data.rangeNames || [],
          cartLabel: data.cartLabel || null
        }
      };
      root.querySelectorAll('[data-label-option]').forEach(function(c){
        c.setAttribute('data-selected', c === card ? 'true' : 'false');
      });
      applyDesignToCard(card, data);
      renderRecap();
      toast('Design validé — ' + (data.reference || 'enregistré'));
      closeConfigModal();
    });

    // ─── Cards étiquette — click = ouvrir le configurateur ───
    root.querySelectorAll('[data-label-option].ml-cem__option--dual').forEach(function(card){
      var addBtn = card.querySelector('[data-option-add]');
      if (addBtn) {
        addBtn.addEventListener('click', function(e){
          e.stopPropagation();
          openConfigModal(card);
        });
      }
      var editBtn = card.querySelector('[data-preview-edit]');
      if (editBtn) {
        editBtn.addEventListener('click', function(e){
          e.stopPropagation();
          openConfigModal(card);
        });
      }
    });

    // ─── Étape 3 : paliers (boutons tier) + ajout produit ───
    root.querySelectorAll('[data-category]').forEach(function(card){
      var tiersContainer = card.querySelector('[data-tiers]');
      var unitDisplay = card.querySelector('[data-unit-display]');
      var totalDisplay = card.querySelector('[data-total-display]');
      var addBtn = card.querySelector('[data-product-add]');
      if (!tiersContainer || !addBtn) return;

      function getActiveTier() {
        var active = card.querySelector('.ml-cem__tier[data-active="true"]');
        if (!active) active = card.querySelector('.ml-cem__tier');
        return {
          qty: parseInt(active.getAttribute('data-qty'), 10),
          unitCents: parseInt(active.getAttribute('data-unit-cents'), 10)
        };
      }

      // Click palier
      card.querySelectorAll('.ml-cem__tier').forEach(function(tier){
        tier.addEventListener('click', function(e){
          e.stopPropagation();
          card.querySelectorAll('.ml-cem__tier').forEach(function(t){ t.setAttribute('data-active', 'false'); });
          tier.setAttribute('data-active', 'true');
          var t = getActiveTier();
          if (unitDisplay) unitDisplay.textContent = eur(t.unitCents);
          if (totalDisplay) totalDisplay.textContent = eur(t.unitCents * t.qty);
        });
      });

      addBtn.addEventListener('click', function(){
        var t = getActiveTier();
        var handle = card.getAttribute('data-handle');
        var variantId = card.getAttribute('data-variant-id');
        var title = card.querySelector('.ml-cem__product-title').textContent.trim();

        state.products[handle] = {
          variantId: variantId,
          qty: t.qty,
          unitPriceCents: t.unitCents,
          lineCents: t.unitCents * t.qty,
          title: title
        };

        addBtn.setAttribute('data-added', 'true');
        addBtn.textContent = 'Ajouté ✓';
        setTimeout(function(){
          addBtn.removeAttribute('data-added');
          addBtn.textContent = 'Mettre à jour';
        }, 1800);

        renderRecap();
        toast(title + ' · ' + t.qty + ' unités à ' + eur(t.unitCents) + ' / u');
      });
    });

    // ─── Filtres tabs ───
    function matchesFilter(card, filter) {
      if (filter === 'all') return true;
      var cat = card.getAttribute('data-category');
      var gamme = card.getAttribute('data-gamme');
      var format = card.getAttribute('data-format');
      if (filter === 'shampoing-repigmentant') return cat === 'shampoing' && gamme === 'dejaunisseur';
      if (filter === 'soin-repigmentant') return gamme === 'dejaunisseur';
      if (filter === 'gamme-homme') return gamme === 'homme';
      if (filter === 'finition') return cat === 'finition' || cat === 'serum';
      if (filter === 'bac-1000') return format === '1000';
      // "Shampoings" et "Masques" n'affichent que les produits neutres (pas repigmentant ni homme)
      if (filter === 'shampoing' || filter === 'masque') return cat === filter && !gamme;
      return filter === cat;
    }

    root.querySelectorAll('.ml-cem__tab').forEach(function(tab){
      tab.addEventListener('click', function(){
        var filter = tab.getAttribute('data-filter');
        root.querySelectorAll('.ml-cem__tab').forEach(function(t){
          t.setAttribute('data-active', t === tab ? 'true' : 'false');
        });
        root.querySelectorAll('[data-category]').forEach(function(card){
          card.style.display = matchesFilter(card, filter) ? '' : 'none';
        });
      });
    });

    // ─── Smooth scroll pour liens internes ───
    root.querySelectorAll('[data-smooth]').forEach(function(link){
      link.addEventListener('click', function(e){
        var href = link.getAttribute('href');
        if (href && href.charAt(0) === '#') {
          e.preventDefault();
          var target = document.querySelector(href);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // ─── Fade-up reveal via IntersectionObserver (stagger 80ms) ───
    (function initReveal(){
      var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced || !('IntersectionObserver' in window)) {
        root.querySelectorAll('[data-ml-reveal]').forEach(function(el){ el.classList.add('is-in'); });
        return;
      }
      // Appliquer un stagger delay pour les groupes (parent a data-ml-reveal-stagger)
      root.querySelectorAll('[data-ml-reveal-stagger]').forEach(function(group){
        var kids = group.querySelectorAll('[data-ml-reveal]');
        kids.forEach(function(k, i){
          if (!k.style.getPropertyValue('--ml-reveal-delay')) {
            k.style.setProperty('--ml-reveal-delay', (i * 80) + 'ms');
          }
        });
      });
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (e.isIntersecting) {
            e.target.classList.add('is-in');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      root.querySelectorAll('[data-ml-reveal]').forEach(function(el){ io.observe(el); });
    })();

    // ─── Tweaks panel (A/B variants par zone) ───
    (function initTweaks(){
      var panel = root.querySelector('[data-ml-tweaks]');
      var openBtn = root.querySelector('[data-ml-tweaks-open]');
      var closeBtn = root.querySelector('[data-ml-tweaks-close]');
      if (!panel || !openBtn) return;

      root.setAttribute('data-tweaks-on', 'true');

      function applyTweak(key, value){
        root.setAttribute('data-tweak-' + key, value);
      }
      // défauts
      applyTweak('hero-variant', 'A');
      applyTweak('label-variant', 'A');
      applyTweak('products-variant', 'A');
      applyTweak('motion', 'on');

      openBtn.addEventListener('click', function(){
        var open = panel.getAttribute('data-open') === 'true';
        panel.setAttribute('data-open', open ? 'false' : 'true');
      });
      if (closeBtn) closeBtn.addEventListener('click', function(){ panel.setAttribute('data-open', 'false'); });

      panel.querySelectorAll('[data-tweak]').forEach(function(seg){
        var key = seg.getAttribute('data-tweak');
        seg.querySelectorAll('button[data-value]').forEach(function(btn){
          btn.addEventListener('click', function(){
            seg.querySelectorAll('button[data-value]').forEach(function(b){ b.setAttribute('data-active', 'false'); });
            btn.setAttribute('data-active', 'true');
            applyTweak(key, btn.getAttribute('data-value'));
          });
        });
      });
    })();

    // ─── Validation finale : ajoute tout au cart, dédup avec /cart.js ───
    function validate() {
      var btns = root.querySelectorAll('[data-validate]');
      btns.forEach(function(b){ b.disabled = true; b.textContent = 'Ajout au panier…'; });

      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.json(); })
        .then(function(cart){
          var existing = {};
          (cart.items || []).forEach(function(i){ existing[i.variant_id] = i; });

          var items = [];
          // Dossier (toujours — ml-dossier-gate force qty=1 si doublon)
          if (!existing[state.dossierVariant]) {
            items.push({ id: state.dossierVariant, quantity: 1 });
          }
          // Étiquette (avec les infos de design validées dans le configurateur)
          if (state.label && state.label.variantId) {
            var lvid = parseInt(state.label.variantId, 10);
            if (!existing[lvid]) {
              var labelItem = { id: lvid, quantity: 1 };
              var d = state.label.design;
              if (d) {
                var props = {};
                if (d.reference)       props['Référence design'] = d.reference;
                if (d.templateName)    props['Modèle']           = d.templateName;
                if (d.previewImageUrl) props['Aperçu']           = d.previewImageUrl;
                if (d.logoUrl)         props['Logo']             = d.logoUrl;
                if (d.rangeNames && d.rangeNames.length) props['Gammes'] = d.rangeNames.join(', ');
                if (Object.keys(props).length) labelItem.properties = props;
              }
              items.push(labelItem);
            }
          }
          // Forfait impression (avec selling_plan)
          var fa = activeForfait();
          if (fa && !fa.skipped && !existing[fa.variantId]) {
            items.push({ id: fa.variantId, quantity: 1, selling_plan: fa.sellingPlanId });
          }
          // Produits
          Object.keys(state.products).forEach(function(h){
            var p = state.products[h];
            var vid = parseInt(p.variantId, 10);
            if (!existing[vid]) {
              items.push({ id: vid, quantity: p.qty });
            }
          });

          if (items.length === 0) {
            window.location.href = '/cart';
            return;
          }

          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ items: items })
          }).then(function(r){
            if (!r.ok) return r.json().then(function(e){ throw new Error(e.description || e.message || 'Erreur panier'); });
            return r.json();
          }).then(function(){
            window.location.href = '/cart';
          });
        })
        .catch(function(err){
          toast('Erreur : ' + err.message);
          btns.forEach(function(b){ b.disabled = false; b.textContent = 'Valider notre projet →'; });
        });
    }
    root.querySelectorAll('[data-validate]').forEach(function(b){
      b.addEventListener('click', validate);
    });

    renderRecap();
  })();
</script>

{% schema %}
{
  "name": "ML Parcours marque (sans hero)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Vidéo de fond (muette, en boucle)"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image de fond / poster (fallback)"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Surtitre",
      "default": "COSMÉTIQUES CAPILLAIRES B2B · FABRIQUÉS EN FRANCE"
    },
    {
