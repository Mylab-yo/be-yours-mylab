    min-height: 48px;
  }
  .ml-cem__tier:hover { border-color: var(--cem-gold); }
  .ml-cem__tier[data-active="true"] {
    background: var(--cem-dark);
    border-color: var(--cem-dark);
    color: #fff;
  }
  .ml-cem__tier-qty {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem; font-weight: 700; letter-spacing: 0; line-height: 1;
  }
  .ml-cem__tier-unit {
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; text-transform: uppercase; letter-spacing: 0.08em;
    opacity: 0.65; line-height: 1;
  }
  .ml-cem__tier-badge {
    position: absolute;
    top: -7px; right: -4px;
    background: var(--cem-gold-dark); color: #fff;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; font-weight: 600;
    padding: 0.1rem 0.36rem; border-radius: 999px;
    letter-spacing: 0.04em;
  }
  .ml-cem__tier[data-active="true"] .ml-cem__tier-badge { background: var(--cem-gold); color: var(--cem-dark); }
  .ml-cem__product-price-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.5rem; margin-top: 0.5rem;
    padding-top: 0.7rem;
    border-top: 1px dashed rgba(117,90,37,0.3);
  }
  .ml-cem__product-price-unit {
    font-family: 'DM Mono', monospace;
    font-size: 1.152rem; color: var(--cem-mid);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .ml-cem__product-price-unit span {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem; font-weight: 700; color: var(--cem-dark); text-transform: none; letter-spacing: 0;
  }
  .ml-cem__product-price-unit small { font-size: 1.181rem; color: var(--cem-mid); }
  .ml-cem__product-price-total {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700; font-style: normal; font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--cem-dark);
  }
  .ml-cem__product-price-total small {
    font-size: 1.181rem; color: var(--cem-mid); font-weight: 400; font-style: normal;
    font-family: 'DM Mono', monospace; letter-spacing: 0.1em;
  }
  .ml-cem__product-add {
    background: var(--cem-dark); color: #fff; border: none;
    padding: 0.7rem 1rem; border-radius: 999px;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s;
    margin-top: 0.3rem;
  }
  .ml-cem__product-add:hover { background: var(--cem-gold-dark); }
  .ml-cem__product-add[data-added="true"] { background: var(--cem-success); }

  /* ═══════════════════════════════════════ ÉTAPE 4 — RÉCAP ═══════════════════════════════════════ */
  .ml-cem__step--recap {
    background: var(--cem-dark); color: #fff;
    position: relative;
  }
  .ml-cem__step--recap::before {
    content: 'N° 01 — MMXXVI · PARIS';
    position: absolute; top: 1.6rem; right: 1.25rem;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.22em;
    color: rgba(232,198,133,0.55);
  }
  .ml-cem__step--recap .ml-cem__step-head {
    text-align: left; max-width: 100%; align-items: flex-start;
    margin: 0 0 2.2rem;
  }
  .ml-cem__step--recap .ml-cem__step-head::before {
    content: 'ÉTAPE 04 / 04 · PRÊTS À LANCER';
    font-family: 'DM Mono', monospace;
    font-size: 1rem; font-weight: 600; letter-spacing: 0.2em;
    color: #1a1a1a !important;
    background: #fff !important;
    padding: 0.6rem 1.1rem !important;
    border-radius: 4px !important;
    display: inline-block !important;
    align-self: flex-start !important;
    width: fit-content !important;
    margin-bottom: 1rem !important;
    line-height: 1 !important;
  }
  .ml-cem__step--recap h2 { color: #fff; font-size: clamp(2.4rem, 7.5vw, 3.8rem); max-width: 22ch; }
  .ml-cem__step--recap h2 em { color: #e8c685; }
  .ml-cem__step--recap .ml-cem__step-intro {
    color: rgba(255,255,255,0.7);
    font-size: 1.2rem; max-width: 36rem;
  }
  .ml-cem__timeline {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    justify-content: flex-start;
    margin-bottom: 2.4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(232,198,133,0.2);
  }
  .ml-cem__tl-step {
    display: flex; align-items: center; gap: 0.55rem;
    padding: 0.55rem 1rem; border-radius: 999px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.18);
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
  }
  .ml-cem__tl-step[data-done="true"] {
    background: transparent;
    border-color: var(--cem-gold);
    color: #e8c685;
  }
  .ml-cem__tl-icon {
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.12);
    font-size: 1.094rem; font-weight: 700;
    font-family: 'DM Sans', sans-serif;
  }
  .ml-cem__tl-step[data-done="true"] .ml-cem__tl-icon {
    background: var(--cem-gold); color: var(--cem-dark);
  }
  .ml-cem__recap-box {
    background: transparent;
    border: 1px solid rgba(232,198,133,0.25);
    border-radius: 2px;
    padding: 1.8rem 1.4rem;
    max-width: 100%;
    margin: 0;
    position: relative;
  }
  /* coins dorés — feel "document notarié" */
  .ml-cem__recap-box::before,
  .ml-cem__recap-box::after {
    content: ''; position: absolute;
    width: 16px; height: 16px;
    border: 1px solid var(--cem-gold);
  }
  .ml-cem__recap-box::before {
    top: -1px; left: -1px;
    border-right: none; border-bottom: none;
  }
  .ml-cem__recap-box::after {
    bottom: -1px; right: -1px;
    border-left: none; border-top: none;
  }
  @media screen and (min-width: 750px) {
    .ml-cem__recap-box { padding: 2.8rem 2.6rem; max-width: 48rem; }
  }
  .ml-cem__recap-lines {
    list-style: none; padding: 0; margin: 0 0 1.6rem;
    display: flex; flex-direction: column; gap: 0;
  }
  .ml-cem__recap-line {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 0.9rem 0;
    border-bottom: 1px dashed rgba(232,198,133,0.2);
    gap: 1rem;
  }
  .ml-cem__recap-line:last-child { border-bottom: none; padding-bottom: 0.2rem; }
  .ml-cem__recap-label {
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
  }
  .ml-cem__recap-value {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    color: #e8c685;
    font-size: 1.32rem;
    text-align: right;
  }
  .ml-cem__recap-empty {
    color: rgba(255,255,255,0.38);
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
  }
  .ml-cem__recap-total {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-top: 1.4rem; margin-top: 0.4rem;
    border-top: 2px solid var(--cem-gold);
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    gap: 1rem;
  }
  .ml-cem__recap-total .val {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(2rem, 7vw, 2.8rem);
    font-weight: 700; font-style: normal;
    letter-spacing: -0.02em;
    color: #fff;
    letter-spacing: -0.01em;
    text-transform: none;
  }
  .ml-cem__recap-cta {
    display: flex; flex-direction: column; gap: 0.6rem;
    margin-top: 1.8rem;
  }
  @media screen and (min-width: 620px) {
    .ml-cem__recap-cta { flex-direction: row; align-items: center; gap: 1rem; flex-wrap: wrap; }
  }
  /* CTA primaire validation = gold plein, dominant */
  .ml-cem__recap-cta .ml-cem__btn--primary {
    background: var(--cem-gold);
    color: var(--cem-dark);
    box-shadow: 0 14px 32px -10px rgba(197,164,103,0.4);
    padding: 1.1rem 2rem;
    font-size: 1.181rem; letter-spacing: 0.14em;
    flex: 1 1 auto;
  }
  .ml-cem__recap-cta .ml-cem__btn--primary:hover {
    background: #fff; opacity: 1;
  }
  /* CTA secondaire = lien texte discret pour ne plus rivaliser */
  .ml-cem__recap-cta .ml-cem__btn--ghost {
    background: transparent;
    color: rgba(255,255,255,0.75);
    border: none;
    padding: 0.8rem 0.4rem;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.14em;
    text-decoration: underline;
    text-underline-offset: 5px;
    box-shadow: none;
  }
  .ml-cem__recap-cta .ml-cem__btn--ghost:hover {
    background: transparent; color: var(--cem-gold);
  }
  /* mention post-clic rassurance */
  .ml-cem__recap-box::after { /* keep */ }
  .ml-cem__step--recap .ml-cem__recap-box + .ml-cem__recap-aftermath {
    margin: 1.6rem 0 0;
    font-family: 'DM Mono', monospace;
    font-size: 1.123rem; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    max-width: 48rem;
    line-height: 1.7;
  }

  /* ═══════════════════════════════════════ STICKY SIDEBAR ═══════════════════════════════════════ */
  .ml-cem__sticky {
    position: fixed; right: 1.5rem; top: 50%; transform: translateY(-50%);
    width: 280px; max-width: calc(100vw - 3rem);
    background: #fff;
    border: 1px solid rgba(117,90,37,0.2);
    border-radius: 2px;
    padding: 1.3rem 1.3rem 1.4rem;
    box-shadow: 0 18px 44px -18px rgba(17,17,17,0.18);
    z-index: 50;
    display: none;
    font-family: 'DM Sans', sans-serif;
    position: fixed;
  }
  .ml-cem__sticky::before,
  .ml-cem__sticky::after {
    content: ''; position: absolute;
    width: 12px; height: 12px;
    border: 1px solid var(--cem-gold);
  }
  .ml-cem__sticky::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .ml-cem__sticky::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
  @media screen and (min-width: 1024px) {
    .ml-cem__sticky { display: block; }
  }
  .ml-cem__sticky-title {
    font-family: 'DM Mono', monospace;
    font-size: 1.094rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--cem-dark); font-weight: 600;
    margin: 0 0 1rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid rgba(117,90,37,0.15);
  }
  .ml-cem__sticky-steps { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .ml-cem__sticky-step {
    display: flex; align-items: center; gap: 0.7rem;
    font-size: 1.224rem;
    color: var(--cem-mid);
    transition: color 0.3s;
  }
  .ml-cem__sticky-step[data-done="true"] { color: var(--cem-dark); font-weight: 700; }
  .ml-cem__sticky-step-circle {
    width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
    border: 1px solid rgba(117,90,37,0.3);
    display: flex; align-items: center; justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.123rem; color: var(--cem-muted);
    background: var(--cem-cream-2);
    transition: all 0.3s;
  }
  .ml-cem__sticky-step[data-done="true"] .ml-cem__sticky-step-circle {
    background: var(--cem-gold); border-color: var(--cem-gold); color: var(--cem-dark);
    animation: ml-cem-pulse 0.6s ease-out;
  }
  @keyframes ml-cem-pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.18); box-shadow: 0 0 0 6px rgba(197,164,103,0.2); }
    100% { transform: scale(1); }
  }
  .ml-cem__sticky-total {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-top: 0.9rem;
    border-top: 1px dashed rgba(117,90,37,0.3);
    font-family: 'DM Mono', monospace;
    font-size: 1.152rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--cem-mid);
    margin-bottom: 0.9rem;
  }
  .ml-cem__sticky-total strong {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.35rem; color: var(--cem-dark);
    font-weight: 700; font-style: normal;
    letter-spacing: -0.01em;
    text-transform: none;
  }
  .ml-cem__sticky .ml-cem__btn--primary {
    width: 100%; padding: 0.85rem 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; min-height: 44px; letter-spacing: 0.14em;
  }

  /* Bottom bar mobile */
  .ml-cem__bottombar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: #fff;
    border-top: 1px solid rgba(117,90,37,0.2);
    padding: 0.7rem 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 0.8rem;
    z-index: 50;
    box-shadow: 0 -8px 24px -8px rgba(0,0,0,0.08);
    padding-bottom: calc(0.7rem + env(safe-area-inset-bottom, 0));
  }
  @media screen and (min-width: 1024px) {
    .ml-cem__bottombar { display: none; }
  }
  .ml-cem__bottombar-info { display: flex; flex-direction: column; gap: 0.1rem; }
  .ml-cem__bottombar-label {
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--cem-dark);
  }
  .ml-cem__bottombar-total {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem; font-weight: 700; font-style: normal;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .ml-cem__bottombar .ml-cem__btn {
    padding: 0.7rem 1.2rem; min-height: 42px;
    font-family: 'DM Mono', monospace;
    font-size: 1.152rem; letter-spacing: 0.14em;
  }
  /* Bouton finaliser : ghost tant qu'incomplet, gold quand complet */
  .ml-cem__bottombar .ml-cem__btn--gold {
    background: var(--cem-dark); color: #fff;
    box-shadow: none;
  }
  .ml-cem[data-complete="true"] .ml-cem__bottombar .ml-cem__btn--gold {
    background: linear-gradient(135deg, var(--cem-gold-dark) 0%, var(--cem-gold) 100%);
    color: #fff;
    box-shadow: 0 8px 20px -8px rgba(117,90,37,0.5);
  }

  /* Toast */
  .ml-cem__toast {
    position: fixed; bottom: 6rem; left: 50%; transform: translateX(-50%) translateY(20px);
    background: var(--cem-dark); color: #fff;
    padding: 0.8rem 1.4rem; border-radius: 999px;
    font-size: 1.296rem; font-weight: 700;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
    z-index: 100;
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
  }
  .ml-cem__toast[data-show="true"] { opacity: 1; transform: translateX(-50%) translateY(0); }
  @media screen and (min-width: 1200px) {
    .ml-cem__toast { bottom: 2rem; }
  }

  /* Configurateur iframe modal */
  .ml-cem__modal {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(17,17,17,0.78);
    display: none;
    align-items: stretch; justify-content: center;
  }
  .ml-cem__modal[data-open="true"] { display: flex; }
  .ml-cem__modal-frame {
    position: relative;
    width: 100%; height: 100%;
    background: #fff;
    display: flex; flex-direction: column;
  }
  @media screen and (min-width: 960px) {
    .ml-cem__modal { padding: 2.5rem; }
    .ml-cem__modal-frame { border-radius: 14px; overflow: hidden; max-width: 1280px; max-height: 100%; }
  }
  .ml-cem__modal-close {
    position: absolute; top: 0.7rem; right: 0.8rem; z-index: 2;
    appearance: none; border: none; cursor: pointer;
    width: 40px; height: 40px; border-radius: 999px;
    background: rgba(255,255,255,0.95); color: #1a1a1a;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 1.4rem; line-height: 1;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
  }
  .ml-cem__modal-close:hover { background: #fff; }
  .ml-cem__modal-iframe { flex: 1 1 auto; width: 100%; border: 0; display: block; }
  .ml-cem__modal-loader {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: #fff; color: var(--cem-mid); font-size: 1.296rem;
    transition: opacity 0.2s;
  }
  .ml-cem__modal-loader[hidden] { display: none; }
  .ml-cem__modal-error {
    position: absolute; inset: 0; display: none; flex-direction: column; gap: 0.8rem;
    align-items: center; justify-content: center; text-align: center; padding: 2rem;
    background: #fff;
  }
  .ml-cem__modal-error[data-show="true"] { display: flex; }
  body[data-ml-cem-modal-open="true"] { overflow: hidden; }

  /* Card post-design preview */
  .ml-cem__option[data-design-ready="true"] .ml-cem__option-cta { background: var(--cem-success); color: #fff; }
  .ml-cem__option-preview {
    display: none;
    margin: 0.8rem 0 0.4rem;
    padding: 0.6rem;
    border: 1px solid var(--cem-line);
    border-radius: 10px;
    background: #fff;
    align-items: center;
    gap: 0.7rem;
  }
  .ml-cem__option[data-design-ready="true"] .ml-cem__option-preview { display: flex; }
  .ml-cem__option-preview-thumb {
    width: 52px; height: 52px; flex-shrink: 0;
    background: #f5f0eb center/contain no-repeat;
    border-radius: 8px; border: 1px solid var(--cem-line);
  }
  .ml-cem__option-preview-meta { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; flex: 1; }
  .ml-cem__option-preview-ref {
    font-family: 'DM Sans', sans-serif; font-size: 1.181rem; letter-spacing: 0.08em;
    color: var(--cem-dark); font-weight: 600; text-transform: uppercase;
  }
  .ml-cem__option-preview-label { font-size: 1.238rem; font-weight: 600; color: var(--cem-dark); }
  .ml-cem__option-preview-edit {
    background: none; border: none; color: var(--cem-mid); cursor: pointer;
    font-size: 1.123rem; text-decoration: underline; padding: 0.3rem 0.5rem;
  }
  .ml-cem__option-preview-edit:hover { color: var(--cem-dark); }

  /* ═══════════════════════════════════════ TWEAK VARIANTS A/B ═══════════════════════════════════════ */
  /* Hero variant B — overlay sur image au lieu de split */
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-grid {
    display: block;
    position: relative;
    min-height: 88vh;
  }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-media {
    position: absolute; inset: 0;
    height: 100%;
    z-index: 0;
  }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-media::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(105deg, rgba(17,17,17,0.82) 0%, rgba(17,17,17,0.55) 45%, rgba(17,17,17,0.1) 85%);
    z-index: 1;
  }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-text {
    position: relative;
    z-index: 2;
    color: #fff;
    padding: 5rem 1.5rem;
    max-width: 38rem;
  }
  @media screen and (min-width: 750px) {
    .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-text { padding: 8rem 4rem; }
  }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-text h1,
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-text p,
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-eyebrow,
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-millesime { color: #fff; }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-eyebrow,
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-millesime { color: rgba(255,255,255,0.75); }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__hero-text h1 em { color: #e8c685; }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__btn--primary {
    background: #fff; color: var(--cem-dark);
  }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__btn--ghost {
    border-color: rgba(255,255,255,0.55); color: #fff;
  }
  .ml-cem[data-tweak-hero-variant="B"] .ml-cem__btn--ghost:hover {
    background: rgba(255,255,255,0.08);
  }

  /* Label variant B — une seule carte Sur-mesure dominante, autres compressées */
  .ml-cem[data-tweak-label-variant="B"] .ml-cem__options {
    grid-template-columns: 1fr;
    max-width: 36rem;
    margin-left: auto; margin-right: auto;
  }
  @media screen and (min-width: 900px) {
    .ml-cem[data-tweak-label-variant="B"] .ml-cem__options {
      grid-template-columns: 1fr 1.5fr;
      max-width: 62rem;
      align-items: start;
    }
    .ml-cem[data-tweak-label-variant="B"] .ml-cem__option--premium { grid-row: span 2; }
  }
  .ml-cem[data-tweak-label-variant="B"] .ml-cem__option--nu,
  .ml-cem[data-tweak-label-variant="B"] .ml-cem__option--dual {
    padding: 1.4rem 1.6rem;
  }
