    .ml-cem__dossier-list { grid-template-columns: 1fr 1fr; gap: 0.8rem 2rem; }
  }
  .ml-cem__dossier-list li {
    display: flex; align-items: flex-start; gap: 0.6rem;
    font-size: 1.368rem; line-height: 1.5; color: var(--cem-mid);
  }
  .ml-cem__dossier-list li::before {
    content: ''; flex-shrink: 0;
    width: 18px; height: 18px; margin-top: 2px;
    background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23c5a467' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6L9 17l-5-5'/></svg>") no-repeat center / contain;
  }
  .ml-cem__dossier-hint {
    text-align: center; margin-top: 1.6rem;
    font-size: 1.368rem; color: var(--cem-mid); }

  /* ═══════════════════════════════════════ ÉTAPE 2 — ÉTIQUETTE ═══════════════════════════════════════ */
  .ml-cem__step--label { background: var(--cem-cream-2); }
  .ml-cem__step--label .ml-cem__step-head::before {
    content: 'ÉTAPE 02 / 04';
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1rem; font-weight: 600; letter-spacing: 0.2em;
    color: #fff !important;
    background: #1a1a1a !important;
    padding: 0.6rem 1.1rem !important;
    border-radius: 4px !important;
    display: inline-block !important;
    align-self: flex-start !important;
    width: fit-content !important;
    margin-bottom: 1rem !important;
    line-height: 1 !important;
  }
  .ml-cem__step--label .ml-cem__step-head {
    text-align: left; max-width: 100%; align-items: flex-start;
    margin: 0 0 2.4rem;
  }
  .ml-cem__step--label .ml-cem__h { font-size: clamp(2.2rem, 7vw, 3.4rem); max-width: 22ch; }
  .ml-cem__step--label .ml-cem__step-intro {
    font-size: 1.2rem; max-width: 36rem;
  }
  .ml-cem__options {
    display: grid; grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media screen and (min-width: 950px) {
    .ml-cem__options { grid-template-columns: repeat(3, 1fr); gap: 1.2rem; align-items: stretch; }
  }
  .ml-cem__option {
    position: relative;
    border: 1px solid rgba(117,90,37,0.2);
    border-radius: 4px;
    background: #fff;
    padding: 1.8rem 1.4rem 1.4rem;
    display: flex; flex-direction: column; gap: 0.9rem;
    cursor: pointer;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    text-align: left;
  }
  .ml-cem__option:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px -14px rgba(26,26,26,0.15);
    border-color: var(--cem-gold);
  }
  .ml-cem__option[data-selected="true"] {
    border-color: var(--cem-gold-dark);
    box-shadow: 0 20px 42px -14px rgba(197,164,103,0.28);
  }
  .ml-cem__option[data-selected="true"]::after {
    content: '✓ Sélectionné';
    position: absolute; top: -10px; right: 1.2rem;
    background: var(--cem-gold-dark); color: #fff;
    padding: 0.28rem 0.7rem; border-radius: 999px;
    font-family: 'DM Mono', monospace;
    font-size: 1.238rem; font-weight: 600; letter-spacing: 0.14em;
  }
  .ml-cem__option-badge {
    align-self: flex-start;
    background: transparent; color: var(--cem-dark);
    padding: 0; border-radius: 0;
    font-family: 'DM Mono', monospace;
    font-size: 1.094rem; font-weight: 600; letter-spacing: 0.22em;
    text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 0.6rem;
  }
  .ml-cem__option-badge::before {
    content: ''; display: inline-block;
    width: 20px; height: 1px; background: var(--cem-gold);
  }
  .ml-cem__option-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.9rem; font-weight: 700; font-style: normal;
    margin: 0; line-height: 1.1;
  }
  .ml-cem__option-title em {
    color: var(--cem-dark);
  }
  .ml-cem__option-price {
    font-family: 'DM Sans', sans-serif;
    font-size: 2rem; font-weight: 700; font-style: normal;
    letter-spacing: -0.01em;
    color: var(--cem-dark);
    display: flex; align-items: baseline; gap: 0.35rem;
    margin: 0.1rem 0 0.2rem;
    line-height: 1;
  }
  .ml-cem__option-price small {
    font-size: 1.123rem; font-family: 'DM Sans', sans-serif;
    color: var(--cem-mid); font-weight: 400; font-style: normal;
    letter-spacing: 0.02em;
  }
  .ml-cem__option-meta {
    display: flex; flex-direction: column; gap: 0.55rem;
    font-size: 1.267rem; color: var(--cem-mid);
    padding: 1rem 0;
    border-top: 1px dashed rgba(117,90,37,0.3);
    border-bottom: 1px dashed rgba(117,90,37,0.3);
  }
  .ml-cem__option-meta span { display: flex; align-items: flex-start; gap: 0.6rem; line-height: 1.4; }
  .ml-cem__option-meta span::before {
    content: ''; flex-shrink: 0;
    width: 4px; height: 4px; margin-top: 0.55rem;
    background: var(--cem-gold); border-radius: 0;
    transform: rotate(45deg);
  }
  .ml-cem__option-best {
    font-size: 1.238rem; font-family: 'DM Sans', sans-serif;
    color: var(--cem-mid); margin: 0;
    line-height: 1.45;
  }
  .ml-cem__option-cta {
    margin-top: auto;
    background: var(--cem-dark); color: #fff;
    padding: 0.95rem 1.2rem; border-radius: 999px;
    font-size: 1.123rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    text-align: center; border: none; cursor: pointer;
    transition: background 0.2s;
  }
  .ml-cem__option-cta:hover { background: var(--cem-gold-dark); }
  .ml-cem__option[data-selected="true"] .ml-cem__option-cta { background: var(--cem-success); }
  .ml-cem__option-more {
    display: inline-block;
    text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.152rem; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cem-mid);
    text-decoration: none;
    padding-top: 0.4rem;
    border-top: none;
    transition: color 0.2s;
  }
  .ml-cem__option-more:hover { color: var(--cem-dark); }

  /* Option 02 — sweet-spot : fond cream + badge "Le plus choisi" en micro */
  .ml-cem__option[data-label-option="modeles"] {
    background: var(--cem-cream);
    border-color: rgba(117,90,37,0.3);
  }
  .ml-cem__option[data-label-option="modeles"]::before {
    content: 'LE PLUS CHOISI';
    position: absolute; top: -10px; left: 1.4rem;
    background: var(--cem-gold);
    color: #fff;
    padding: 0.28rem 0.7rem;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; font-weight: 600; letter-spacing: 0.2em;
    border-radius: 999px;
  }

  /* Option 03 — premium : carte dark + liseré or + badge Collection privée */
  .ml-cem__option[data-label-option="sur-mesure"] {
    background: var(--cem-dark);
    color: #fff;
    border-color: var(--cem-gold-dark);
    box-shadow: inset 0 0 0 1px rgba(197,164,103,0.25);
  }
  .ml-cem__option[data-label-option="sur-mesure"]::before {
    content: 'COLLECTION PRIVÉE';
    position: absolute; top: -10px; left: 1.4rem;
    background: var(--cem-dark);
    color: var(--cem-gold);
    border: 1px solid var(--cem-gold);
    padding: 0.28rem 0.7rem;
    font-family: 'DM Mono', monospace;
    font-size: 1.181rem; font-weight: 600; letter-spacing: 0.2em;
    border-radius: 999px;
  }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-badge { color: var(--cem-gold); }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-badge::before { background: var(--cem-gold); }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-title { color: #fff; }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-title em { color: var(--cem-gold); }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-price { color: #fff; }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-price small { color: rgba(255,255,255,0.65); }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-meta {
    color: rgba(255,255,255,0.78);
    border-top-color: rgba(197,164,103,0.3);
    border-bottom-color: rgba(197,164,103,0.3);
  }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-best { color: rgba(255,255,255,0.68); }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-cta {
    background: var(--cem-gold); color: var(--cem-dark);
  }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-cta:hover {
    background: #fff;
  }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-more {
    color: rgba(255,255,255,0.55);
  }
  .ml-cem__option[data-label-option="sur-mesure"] .ml-cem__option-more:hover { color: var(--cem-gold); }
  .ml-cem__option[data-label-option="sur-mesure"]:hover { border-color: var(--cem-gold); }

  .ml-cem__option--dual:hover { /* overrides réduits — hover fin */ }
  .ml-cem__option--dual:hover .ml-cem__option-cta { background: var(--cem-gold-dark); }

  /* ═══════════════════════════════════════ ÉTAPE 2.5 — FORFAIT ═══════════════════════════════════════ */
  .ml-cem__step--forfait { background: #fff; position: relative; }
  .ml-cem__step--forfait::before {
    content: ''; position: absolute; left: 50%; top: 0;
    width: 1px; height: 48px;
    background: linear-gradient(180deg, transparent, var(--cem-gold));
  }
  .ml-cem__step--forfait .ml-cem__step-head {
    text-align: left; max-width: 100%; align-items: flex-start;
    margin: 0 0 2.2rem;
  }
  .ml-cem__step--forfait .ml-cem__step-head::before {
    content: 'ÉTAPE 02 · EXTENSION';
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 1rem; font-weight: 600; letter-spacing: 0.2em;
    color: #fff !important;
    background: #1a1a1a !important;
    padding: 0.6rem 1.1rem !important;
    border-radius: 4px !important;
    display: inline-block !important;
    align-self: flex-start !important;
    width: fit-content !important;
    margin-bottom: 1rem !important;
    line-height: 1 !important;
  }
  .ml-cem__step--forfait .ml-cem__h { font-size: clamp(2rem, 6.5vw, 3rem); max-width: 22ch; }
  .ml-cem__step--forfait .ml-cem__step-intro {
    font-size: 1.2rem; max-width: 36rem;
  }
  /* piliers forfait : pattern différent du dossier — liste indexée */
  .ml-cem__step--forfait .ml-cem__pillars {
    border-top: none;
    display: flex; flex-direction: column;
    gap: 0;
  }
  @media screen and (min-width: 750px) {
    .ml-cem__step--forfait .ml-cem__pillars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }
  .ml-cem__step--forfait .ml-cem__pillar {
    background: var(--cem-cream-2);
    border: 1px solid rgba(117,90,37,0.15);
    border-radius: 2px;
    padding: 1.6rem 1.4rem;
    display: flex; flex-direction: column; gap: 0.4rem;
    grid-template-columns: 1fr;
  }
  .ml-cem__step--forfait .ml-cem__pillar::before { display: none; }
  .ml-cem__step--forfait .ml-cem__pillar-name { color: var(--cem-dark); }
  .ml-cem__step--forfait .ml-cem__pillar-title { font-size: 1.3rem; }

  .ml-cem__forfait-callout {
    margin-top: 2rem;
    background: var(--cem-dark);
    color: #fff;
    border: none;
    border-left: none;
    border-radius: 2px;
    padding: 1.4rem 1.6rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    flex-wrap: wrap;
    position: relative;
    transition: background 0.3s;
    overflow: hidden;
  }
  .ml-cem__forfait-callout::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--cem-gold);
  }
  .ml-cem__forfait-callout[data-state="active"] {
    background: var(--cem-dark);
  }
  .ml-cem__forfait-callout[data-state="active"]::before { background: var(--cem-gold); }
