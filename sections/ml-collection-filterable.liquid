{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .ml-filterable {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  /* ── BADGE RUPTURE / SUR COMMANDE ── */
  .ml-filterable .flex-grid__item { position: relative; }
  .ml-card-badge {
    position: absolute; top: 10px; left: 10px; z-index: 2; padding: 5px 11px;
    font-size: 11px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase;
    border-radius: 50px; font-family: 'DM Sans', sans-serif;
  }
  .ml-card-badge--backorder { background: #fff0dc; color: #8a3a00; border: 1px solid #ffd9a8; }
  .ml-card-badge--oos { background: #f2f2f2; color: #888; border: 1px solid #e0e0e0; }

  /* ── FILTER BAR ── */
  .ml-filter-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }
  .ml-filter-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.55rem 1.4rem;
    border: 1.5px solid #E5E5E5;
    border-radius: 50px;
    background: transparent;
    color: #555;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .ml-filter-btn:hover {
    border-color: #111;
    color: #111;
  }
  .ml-filter-btn--active,
  .ml-filter-btn--active:hover {
    background: #111 !important;
    border-color: #111 !important;
    color: #fff !important;
  }

  /* ── FIX: forcer opacité images produit (animation zoom-fade sans parent [data-animate-image]) ── */
  .ml-filterable use-animate .image-animate,
  .ml-filterable .card .media img {
    opacity: 1 !important;
  }

  /* ── HIDE FILTERED ITEMS ── */
  .ml-filterable-hidden,
  .ml-volume-hidden {
    display: none !important;
  }
  .ml-filterable__empty {
    text-align: center;
    padding: 3rem 1rem;
    color: #888;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.3rem;
    display: none;
    width: 100%;
  }
  .ml-filterable__empty--visible {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ml-filter-bar {
      gap: 0.5rem;
    }
    .ml-filter-btn {
      font-size: 1.1rem;
      padding: 0.6rem 1rem;
      min-height: 44px;
    }
  }
{%- endstyle -%}

{%- assign collection = collections[section.settings.collection] -%}
{%- if collection != blank -%}

  {%- comment -%} Build unique tag list from filter settings {%- endcomment -%}
  {%- assign filter_tags = '' -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'filter' and block.settings.tag != blank -%}
      {%- if filter_tags != '' -%}{%- assign filter_tags = filter_tags | append: ',' -%}{%- endif -%}
      {%- assign filter_tags = filter_tags | append: block.settings.tag -%}
    {%- endif -%}
  {%- endfor -%}

  <div class="section--padding ml-filterable" id="ml-filterable-{{ section.id }}" data-collection-handle="{{ section.settings.collection.handle }}"{% if section.settings.hide_volume_duplicates %} data-product-map-url="{{ 'ml-product-map.json' | asset_url }}"{% endif %}>
    <div class="page-width">

      {%- if filter_tags != '' -%}
        <div class="ml-filter-bar">
          <button class="ml-filter-btn ml-filter-btn--active" data-filter="all">Tout</button>
          {%- for block in section.blocks -%}
            {%- if block.type == 'filter' and block.settings.tag != blank -%}
              <button class="ml-filter-btn" data-filter="{{ block.settings.tag | handleize }}" {{ block.shopify_attributes }}>
                {{ block.settings.label | default: block.settings.tag }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <ul class="product-grid flex-grid flex-grid--rigid{% if section.settings.columns_mobile == '1' %} flex-grid--1-col-mobile{% endif %} flex-grid--2-col flex-grid--2-col-tablet flex-grid--{{ section.settings.columns_desktop }}-col-desktop" role="list">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {%- if section.settings.hide_multivariant and product.variants.size > 1 -%}
            {%- continue -%}
          {%- endif -%}
          {%- capture product_tags_handleized -%}
            {%- for tag in product.tags -%}{{ tag | handleize }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
          {%- endcapture -%}
          {%- liquid
            assign cv = product.variants.first
            assign card_oos = false
            if cv.inventory_management == 'shopify' and cv.inventory_quantity <= 0
              assign card_oos = true
            endif
            assign card_backorder = true
            if product.tags contains 'no-backorder'
              assign card_backorder = false
            endif
          -%}
          <li class="flex-grid__item{% if card_oos %} ml-card-oos{% endif %}" data-tags="{{ product_tags_handleized }}">
            {%- if card_oos -%}
              <span class="ml-card-badge {% if card_backorder %}ml-card-badge--backorder{% else %}ml-card-badge--oos{% endif %}">{% if card_backorder %}Sur commande{% else %}Rupture{% endif %}</span>
            {%- endif -%}
            {% render 'card-product',
              card_product: product,
              card_collection: collection,
              media_size: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: false,
              show_rating: false,
              show_quick_buy: section.settings.show_quick_buy,
              enable_quick_view: section.settings.enable_quick_view,
              enable_color_swatches: false,
              enable_countdown: false,
              enable_image_fill: section.settings.enable_image_fill,
              section_id: section.id
            %}
          </li>
        {%- endfor -%}
      </ul>
      <div class="ml-filterable__empty">Aucun produit dans cette catégorie.</div>

    </div>
  </div>

  <script>
    (function() {
      var container = document.getElementById('ml-filterable-{{ section.id }}');
      if (!container) return;

      var buttons = container.querySelectorAll('.ml-filter-btn');
      var grid = container.querySelector('.product-grid');
      var emptyMsg = container.querySelector('.ml-filterable__empty');

      function getActiveFilter() {
        var active = container.querySelector('.ml-filter-btn--active');
        return active ? active.getAttribute('data-filter') : 'all';
      }

      function applyFilter(filter) {
        var items = container.querySelectorAll('.flex-grid__item[data-tags]');
        var visibleCount = 0;
        items.forEach(function(item) {
          if (filter === 'all') {
            item.classList.remove('ml-filterable-hidden');
            visibleCount++;
          } else {
            var tags = item.getAttribute('data-tags').split(',');
            if (tags.indexOf(filter) !== -1) {
              item.classList.remove('ml-filterable-hidden');
              visibleCount++;
            } else {
              item.classList.add('ml-filterable-hidden');
            }
          }
        });
        if (emptyMsg) {
          emptyMsg.classList.toggle('ml-filterable__empty--visible', visibleCount === 0);
        }
      }

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var filter = btn.getAttribute('data-filter');
          buttons.forEach(function(b) { b.classList.remove('ml-filter-btn--active'); });
          btn.classList.add('ml-filter-btn--active');
          applyFilter(filter);
        });
      });

      // Volume-duplicate hiding: load ml-product-map.json, mark handles that are
      // size variants of a hub (sizes[X] !== hubKey) to hide them from the grid.
      var productMapUrl = container.getAttribute('data-product-map-url');
      var hideHandles = Object.create(null);
      var mapLoaded = Promise.resolve();
      if (productMapUrl) {
        mapLoaded = fetch(productMapUrl).then(function(r) { return r.ok ? r.json() : null; })
          .then(function(map) {
            if (!map) return;
            Object.keys(map).forEach(function(hubKey) {
              if (hubKey === '_doc') return;
              var entry = map[hubKey];
              if (entry && entry.sizes) {
                Object.keys(entry.sizes).forEach(function(size) {
                  var h = entry.sizes[size];
                  if (h && h !== hubKey) hideHandles[h] = true;
                });
              }
            });
          })
          .catch(function(e) { console.warn('ml-product-map load failed:', e); });
      }
      function hideVariantCards() {
        if (!Object.keys(hideHandles).length) return;
        grid.querySelectorAll('.flex-grid__item').forEach(function(c) {
          var link = c.querySelector('a[href*="/products/"]');
          if (!link) return;
          var m = link.getAttribute('href').match(/\/products\/([^/?#]+)/);
          if (m && hideHandles[m[1]]) c.classList.add('ml-volume-hidden');
        });
      }
      mapLoaded.then(hideVariantCards);

      // Lazy-load remaining products beyond Liquid's 50-cap (boutique-adherents has 73)
      var collectionHandle = container.getAttribute('data-collection-handle');
      if (!collectionHandle || !grid) return;

      var existingHandles = {};
      grid.querySelectorAll('a[href*="/products/"]').forEach(function(a) {
        var m = a.getAttribute('href').match(/\/products\/([^/?#]+)/);
        if (m) existingHandles[m[1]] = true;
      });

      function handleizeTag(t) {
        return (t || '').toString().toLowerCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '');
      }
      function formatPrice(price) {
        try { return parseFloat(price).toFixed(2).replace('.', ',') + ' \u20AC'; } catch(e) { return ''; }
      }
      function escAttr(s) {
        return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      function buildCard(p) {
        var tagsHandleized = (p.tags || []).map(handleizeTag).filter(Boolean).join(',');
        var img = (p.images && p.images.length && p.images[0].src) ? p.images[0].src : '';
        var price = (p.variants && p.variants[0] && p.variants[0].price != null) ? formatPrice(p.variants[0].price) : '';
        var titleEsc = escAttr(p.title);
        var href = '/products/' + p.handle;
        var li = document.createElement('li');
        li.className = 'flex-grid__item';
        li.setAttribute('data-tags', tagsHandleized);
        li.innerHTML =
          '<div class="card-wrapper">' +
            '<div class="card card--product" tabindex="-1">' +
              '<a href="' + href + '" class="card__media media-wrapper" tabindex="-1" aria-label="' + titleEsc + '">' +
                '<div class="card--image-animate image-animate media media--portrait media--hover-effect">' +
                  (img ? '<img src="' + img + '" alt="' + titleEsc + '" loading="lazy" class="motion-reduce">' : '') +
                '</div>' +
              '</a>' +
              '<div class="card-information">' +
                '<div class="card-information__wrapper">' +
                  '<a href="' + href + '" class="card-information__text h4" tabindex="-1">' + titleEsc + '</a>' +
                  (price ? '<div class="price"><div class="price__container"><div class="price__regular"><span class="price-item price-item--regular">' + price + '</span></div></div></div>' : '') +
                '</div>' +
              '</div>' +
            '</div>' +
          '</div>';
        return li;
      }

      mapLoaded.then(function() {
        return fetch('/collections/' + encodeURIComponent(collectionHandle) + '/products.json?limit=250');
      })
        .then(function(r) { return r && r.ok ? r.json() : null; })
        .then(function(data) {
          if (!data || !data.products) return;
          var frag = document.createDocumentFragment();
          var appended = 0;
          data.products.forEach(function(p) {
            if (existingHandles[p.handle]) return;
            if (hideHandles[p.handle]) return;
            frag.appendChild(buildCard(p));
            appended++;
          });
          if (appended > 0) {
            grid.appendChild(frag);
            applyFilter(getActiveFilter());
          }
        })
        .catch(function(e) { console.warn('ml-filterable lazy:', e); });
    })();
  </script>

{%- else -%}
  <div class="ml-filterable" style="text-align:center;padding:3rem;color:#888;">
    <p>Sélectionnez une collection dans les paramètres de la section.</p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Collection filtrable",
  "tag": "section",
  "class": "ml-collection-filterable",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Produits à afficher",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes bureau",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format image",
      "options": [
        { "value": "square", "label": "Carré" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Paysage" },
        { "value": "adapt", "label": "Adapter à l'image" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "enable_image_fill",
      "label": "Remplir l'image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Image au survol",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_buy",
      "label": "Bouton Achat rapide",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_view",
      "label": "Aperçu rapide",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_multivariant",
      "label": "Masquer produits avec variants",
      "info": "Cache les produits ayant plus d'un variant (ex: produits pro avec contenances)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_volume_duplicates",
      "label": "Masquer les variantes par contenance",
      "info": "Cache les produits qui sont des variantes de contenance d'un hub (selon ml-product-map.json). Les produits standalone (sans hub) restent visibles.",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Filtre",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag produit",
          "info": "Le tag exact du produit Shopify (ex: shampoings)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Libellé affiché",
          "info": "Le texte du bouton filtre (ex: Shampoings)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection filtrable",
      "blocks": [
        { "type": "filter", "settings": { "tag": "shampoings", "label": "Shampoings" } },
        { "type": "filter", "settings": { "tag": "masques", "label": "Masques" } },
        { "type": "filter", "settings": { "tag": "pigments", "label": "Pigments" } }
      ]
    }
  ]
}
{% endschema %}
