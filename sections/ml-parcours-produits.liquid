{% comment %} ml-parcours-produits.liquid — Étape 02 — Produits avec tabs + paliers {% endcomment %}

{% liquid
  assign pro_col = collections['boutique-adherents']
  assign extra_products = section.settings.extra_products
%}

<section class="ml-parcours__page">
  <div class="ml-parcours__container">
    <div class="ml-parcours__kicker">Étape 02 / 04 — Produits</div>
    <h1 class="ml-parcours__display">{{ section.settings.heading }}</h1>
    <p class="ml-parcours__lede">{{ section.settings.lede }}</p>

    <div class="ml-parcours__product-tabs">
      <button type="button" class="ml-parcours__product-tab is-active" data-cat="all">Tous</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="shampoing">Shampoings</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="shampoing-rep">Repigmentants</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="masque">Masques</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="creme">Crèmes</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="finition">Finition</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="homme">Gamme Homme</button>
      <button type="button" class="ml-parcours__product-tab" data-cat="bac1000">Format 1000ml</button>
    </div>

    <div class="ml-parcours__product-grid" data-collection-handle="boutique-adherents">
      {% for p in pro_col.products %}
        {% render 'ml-parcours-product-card', product: p %}
      {% endfor %}
      {% for p in extra_products %}
        {% render 'ml-parcours-product-card', product: p, extra: true %}
      {% endfor %}
    </div>

    <div class="ml-parcours__page-footer">
      <a href="/pages/parcours-dossier" class="ml-parcours__page-footer-back">
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M13 5H1m0 0l4-4M1 5l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Retour à l'étape précédente
      </a>
      <a href="/pages/parcours-etiquette" class="ml-parcours__btn ml-parcours__btn--primary">
        Valider et créer mon étiquette
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
(function(){
  'use strict';

  // ─── Tier data + classification mirrors snippets/ml-parcours-product-card.liquid ───
  const TIER_MAP = [
    { match: r => r.g==='dejaunisseur'&&r.t==='shampoing'&&r.f==='200', data: '6:750,12:710,24:675,48:600,96:540' },
    { match: r => r.g==='dejaunisseur'&&r.t==='masque'&&r.f==='200', data: '6:960,12:910,24:860,48:765,96:690' },
    { match: r => r.g==='dejaunisseur'&&r.t==='shampoing'&&r.f==='1000', data: '1:2890,3:2745,6:2450,12:2160' },
    { match: r => r.g==='dejaunisseur'&&r.t==='masque'&&r.f==='1000', data: '1:3490,3:3315,6:2965,12:2615' },
    { match: r => r.g==='homme'&&r.t==='masque'&&r.f==='500', data: '6:1990,12:1790,24:1690,48:1590,96:1430' },
    { match: r => r.t==='spray_reparateur', data: '6:990,12:940,24:890,48:790,96:710' },
    { match: r => r.t==='shampoing'&&r.f==='200', data: '6:700,12:665,24:630,48:560,96:500' },
    { match: r => r.t==='shampoing'&&r.f==='500', data: '6:1490,12:1340,24:1265,48:1190,96:1065' },
    { match: r => r.t==='shampoing'&&r.f==='1000', data: '1:2490,3:2365,6:2100,12:1865' },
    { match: r => r.t==='masque'&&r.f==='200', data: '6:950,12:900,24:855,48:760,96:680' },
    { match: r => r.t==='masque'&&r.f==='400', data: '6:1690,12:1590,24:1520,48:1350,96:1210' },
    { match: r => r.t==='masque'&&r.f==='1000', data: '1:3290,3:3125,6:2790,12:2465' },
    { match: r => r.t==='creme'&&r.f==='200', data: '6:850,12:805,24:765,48:680,96:610' },
    { match: r => r.t==='creme'&&r.f==='400', data: '6:1690,12:1590,24:1520,48:1350,96:1210' },
    { match: r => r.t==='creme'&&r.f==='1000', data: '1:3290,3:3125,6:2790,12:2465' },
    { match: r => r.t==='serum', data: '6:850,12:805,24:765,48:680,96:610' },
    { match: r => r.t==='huile', data: '6:950,12:900,24:850,48:760,96:680' },
    { match: r => r.t==='cire', data: '6:690,12:660,24:630,48:600' }
  ];

  function classify(title, tags) {
    const tl = (title || '').toLowerCase();
    const ts = (tags || []).join(' ').toLowerCase();
    let t = '', f = '', g = '';
    if (ts.includes('shampoing') || tl.includes('shampoing')) t = 'shampoing';
    else if (tl.includes('spray') && tl.includes('masque')) t = 'spray_reparateur';
    else if (ts.includes('masque') || tl.includes('masque')) t = 'masque';
    else if (ts.includes('creme') || ts.includes('crème') || tl.includes('crème')) t = 'creme';
    else if (ts.includes('serum') || ts.includes('sérum') || tl.includes('sérum')) t = 'serum';
    else if (ts.includes('huile') || tl.includes('huile') || tl.includes('bain miraculeux')) t = 'huile';
    else if (ts.includes('cire') || tl.includes('cire')) t = 'cire';
    if (ts.includes('1000ml') || ts.includes('1l') || tl.includes('1000')) f = '1000';
    else if (ts.includes('500ml') || tl.includes('500')) f = '500';
    else if (ts.includes('400ml') || tl.includes('400')) f = '400';
    else if (ts.includes('200ml') || tl.includes('200')) f = '200';
    else if (ts.includes('50ml') || tl.includes('50ml')) f = '50';
    if (ts.includes('dejauniss') || ts.includes('colorist') || tl.includes('colorist') || tl.includes('dejauniss') || tl.includes('déjauniss') || tl.includes('repigment')) g = 'dejaunisseur';
    else if (ts.includes('homme') || ts.includes('herborist') || tl.includes('herborist') || tl.includes('barbe') || tl.includes('gel douche') || tl.includes('masque intense')) g = 'homme';
    let primary = 'shampoing';
    if (ts.includes('dejauniss') || ts.includes('coloristeur') || tl.includes('coloristeur') || tl.includes('déjauniss') || tl.includes('jaune') || tl.includes('repigment')) primary = 'shampoing-rep';
    else if (ts.includes('homme') || ts.includes('herborist') || ts.includes('barber') || tl.includes('barbe') || tl.includes('gel douche')) primary = 'homme';
    else if (ts.includes('masque') || tl.includes('masque')) primary = 'masque';
    else if (ts.includes('crème') || ts.includes('creme') || tl.includes('crème') || tl.includes('creme')) primary = 'creme';
    else if (['finition','sérum','serum','huile','cire','spray'].some(k => ts.includes(k)) || ['sérum','serum','huile','cire','spray','bain'].some(k => tl.includes(k))) primary = 'finition';
    let cats = primary;
    if (f === '1000' && primary !== 'bac1000') cats = primary + ' bac1000';
    let tier = '';
    for (const m of TIER_MAP) { if (m.match({t, f, g})) { tier = m.data; break; } }
    return { cats, tier };
  }

  function fmtMoney(cents) {
    return (cents / 100).toFixed(2).replace('.', ',') + ' €';
  }

  function buildCard(p) {
    const tags = Array.isArray(p.tags) ? p.tags : (p.tags || '').split(',').map(t => t.trim()).filter(Boolean);
    const { cats, tier } = classify(p.title, tags);
    const variant = (p.variants && p.variants[0]) || {};
    const img = p.featured_image ? p.featured_image.replace(/(\.[a-z]+)(\?.*)?$/i, '_400x$1') : '';
    const card = document.createElement('div');
    card.className = 'ml-parcours__product-card';
    card.dataset.handle = p.handle;
    card.dataset.variantId = variant.id || '';
    card.dataset.cat = cats;
    card.dataset.tierData = tier;
    let tiersHtml = '';
    if (tier) {
      tiersHtml = tier.split(',').map(t => {
        const [q, u] = t.split(':').map(Number);
        return `<button type="button" class="ml-parcours__tier" data-qty="${q}" data-unit-cents="${u}"><span class="ml-parcours__tier-qty">${q}</span><span class="ml-parcours__tier-unit">${fmtMoney(u)}/u</span></button>`;
      }).join('');
    } else {
      tiersHtml = ['6','12','24','48','96'].map(q => `<button type="button" class="ml-parcours__tier" data-qty="${q}"><span class="ml-parcours__tier-qty">${q}</span></button>`).join('');
    }
    card.innerHTML = `
      <div class="ml-parcours__product-card-img">${img ? `<img src="${img}" alt="${p.title.replace(/"/g,'&quot;')}" loading="lazy">` : p.title}</div>
      <div class="ml-parcours__product-card-body">
        <div class="ml-parcours__product-card-title">${p.title}</div>
        <div class="ml-parcours__product-card-sub">${variant.title && variant.title !== 'Default Title' ? variant.title : ''}</div>
        <div class="ml-parcours__product-card-tiers">${tiersHtml}</div>
        <div class="ml-parcours__product-card-qty" data-qty-display>${tier ? 'Sélectionnez un palier' : fmtMoney(variant.price || 0)}</div>
        <button type="button" class="ml-parcours__product-card-btn" data-add-product disabled>Ajouter à mon projet</button>
      </div>`;
    return card;
  }

  async function lazyLoadMissing() {
    const grid = document.querySelector('.ml-parcours__product-grid[data-collection-handle]');
    if (!grid) return;
    const collHandle = grid.dataset.collectionHandle;
    const rendered = new Set(Array.from(grid.querySelectorAll('.ml-parcours__product-card[data-handle]')).map(c => c.dataset.handle));
    let products = [];
    try {
      const r = await fetch(`/collections/${collHandle}/products.json?limit=250`, { credentials: 'same-origin' });
      if (!r.ok) return;
      products = (await r.json()).products || [];
    } catch { return; }
    const missing = products.filter(p => !rendered.has(p.handle));
    if (!missing.length) return;
    const frag = document.createDocumentFragment();
    for (const p of missing) {
      try {
        const r = await fetch(`/products/${p.handle}.js`, { credentials: 'same-origin' });
        if (!r.ok) continue;
        const detail = await r.json();
        frag.appendChild(buildCard(detail));
      } catch { /* skip */ }
    }
    grid.appendChild(frag);
    bindCardInteractions(grid.querySelectorAll('.ml-parcours__product-card'));
    // Re-apply current tab filter
    const activeTab = document.querySelector('.ml-parcours__product-tab.is-active');
    if (activeTab) activeTab.click();
  }

  // Tab filter — supports multi-cat cards (data-cat="masque bac1000")
  document.querySelectorAll('.ml-parcours__product-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.cat;
      document.querySelectorAll('.ml-parcours__product-tab').forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      document.querySelectorAll('.ml-parcours__product-card').forEach(card => {
        const cardCats = (card.dataset.cat || '').split(/\s+/);
        card.style.display = (cat === 'all' || cardCats.includes(cat)) ? '' : 'none';
      });
    });
  });

  function bindCardInteractions(cards) {
    cards.forEach(card => {
      if (card.dataset.bound === '1') return;
      card.dataset.bound = '1';
      const display = card.querySelector('[data-qty-display]');
      const addBtn = card.querySelector('[data-add-product]');
      card.querySelectorAll('.ml-parcours__tier').forEach(tier => {
      tier.addEventListener('click', () => {
        const qty = parseInt(tier.dataset.qty, 10);
        const unitCents = parseInt(tier.dataset.unitCents, 10);
        if (!qty) return;
        card.querySelectorAll('.ml-parcours__tier').forEach(t => t.classList.remove('is-active'));
        tier.classList.add('is-active');
        if (display) {
          if (unitCents) {
            const total = unitCents * qty;
            display.textContent = qty + ' × ' + fmtMoney(unitCents) + ' = ' + fmtMoney(total) + ' HT';
          } else {
            display.textContent = qty + ' unité' + (qty > 1 ? 's' : '');
          }
          display.classList.add('is-set');
        }
        if (addBtn) {
          addBtn.disabled = false;
          addBtn.classList.remove('is-added');
          addBtn.textContent = 'Ajouter à mon projet';
        }
      });
    });

    // Step 2 — Add button: actually performs cart mutation
    if (addBtn) {
      addBtn.addEventListener('click', async () => {
        const activeTier = card.querySelector('.ml-parcours__tier.is-active');
        if (!activeTier) return;
        const variantId = card.dataset.variantId;
        const qty = parseInt(activeTier.dataset.qty, 10);
        if (!variantId || !qty) return;
        addBtn.disabled = true;
        addBtn.textContent = 'Ajout en cours…';
        try {
          const cartRes = await fetch('/cart.js', { credentials: 'same-origin' });
          if (!cartRes.ok) throw new Error('cart fetch failed: ' + cartRes.status);
          const cart = await cartRes.json();
          const existing = (cart.items || []).find(it => String(it.variant_id) === String(variantId));
          let res;
          if (existing) {
            res = await fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              body: JSON.stringify({ id: existing.key, quantity: qty })
            });
          } else {
            res = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              body: JSON.stringify({ items: [{ id: parseInt(variantId, 10), quantity: qty }] })
            });
          }
          if (!res.ok) throw new Error('cart update failed: ' + res.status);
          addBtn.classList.add('is-added');
          addBtn.textContent = '✓ Ajouté à votre projet';
          document.dispatchEvent(new CustomEvent('cart:refresh'));
        } catch (err) {
          console.error('[ml-parcours-produits] add error', err);
          addBtn.disabled = false;
          addBtn.textContent = 'Erreur — réessayer';
        }
      });
    }
    });
  }

  bindCardInteractions(document.querySelectorAll('.ml-parcours__product-card'));
  lazyLoadMissing();
})();
</script>

{% schema %}
{
  "name": "Parcours · Produits",
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Titre", "default": "<p>Composez votre <em>gamme</em>.</p>" },
    { "type": "textarea", "id": "lede", "label": "Sous-titre", "default": "Sélectionnez vos références et vos quantités. Plus vous prenez, moins ça coûte par flacon. Aucune obligation de tout choisir d'un coup." },
    { "type": "product_list", "id": "extra_products", "label": "Produits hors catalogue (bac 1000ml)", "limit": 50 }
  ],
  "presets": [{ "name": "Parcours · Produits" }]
}
{% endschema %}
