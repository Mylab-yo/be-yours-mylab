{% comment %} ml-parcours-etiquette.liquid — Étape 03 — Choix du type d'étiquette (sélection directe panier) + MyLab Studio en inspiration {% endcomment %}

{% liquid
  assign default_modele = section.settings.modele_default_product
  assign default_modele_variant_id = '55418309083470'
  if default_modele != blank and default_modele.variants.size > 0
    assign default_modele_variant_id = default_modele.variants.first.id
  endif
%}

<section class="ml-parcours__page">
  <div class="ml-parcours__container">
    <div class="ml-parcours__kicker">Étape 03 / 05 — Étiquette & impression</div>
    <h1 class="ml-parcours__display">{{ section.settings.heading }}</h1>
    <p class="ml-parcours__lede">{{ section.settings.lede }}</p>

    <div class="ml-parcours__label-cards">
      <div class="ml-parcours__label-card" data-mode="standard">
        <div class="ml-parcours__label-card-visual">
          {%- if section.settings.card_standard_image != blank -%}
            {{ section.settings.card_standard_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: 'Aperçu Standard', class: 'ml-parcours__label-card-img' }}
          {%- else -%}
            Aperçu Standard
          {%- endif -%}
        </div>
        <div class="ml-parcours__label-card-title">Standard</div>
        <div class="ml-parcours__label-card-price">Gratuit</div>
        <div class="ml-parcours__label-card-for">Pour lancer vite, sans travailler le design</div>
        <div class="ml-parcours__label-card-desc">Étiquette neutre noire, votre logo en bichromie. Idéal pour démarrer rapidement.</div>
        <div class="ml-parcours__label-card-actions">
          <button type="button" class="ml-parcours__label-card-btn" data-select-etiquette data-variant="59231350554958" data-type="Standard">Choisir Standard</button>
        </div>
      </div>
      <div class="ml-parcours__label-card ml-parcours__label-card--featured" data-mode="template">
        <span class="ml-parcours__label-card-badge">Recommandé</span>
        <div class="ml-parcours__label-card-visual">
          {%- if section.settings.card_template_image != blank -%}
            {{ section.settings.card_template_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: 'Aperçu Modèles', class: 'ml-parcours__label-card-img' }}
          {%- else -%}
            Aperçu Modèles
          {%- endif -%}
        </div>
        <div class="ml-parcours__label-card-title">Modèles</div>
        <div class="ml-parcours__label-card-price">99 €</div>
        <div class="ml-parcours__label-card-for">Pour un rendu pro en quelques minutes</div>
        <div class="ml-parcours__label-card-desc">11 designs professionnels prêts à porter vos couleurs. Vous affinez le choix avec nos graphistes après la commande.</div>
        <div class="ml-parcours__label-card-actions">
          <button type="button" class="ml-parcours__label-card-btn" data-select-etiquette data-variant="{{ default_modele_variant_id }}" data-type="Modèles">Choisir Modèles</button>
        </div>
      </div>
      <div class="ml-parcours__label-card" data-mode="studio">
        <div class="ml-parcours__label-card-visual">
          {%- if section.settings.card_studio_image != blank -%}
            {{ section.settings.card_studio_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: 'Aperçu Sur-mesure', class: 'ml-parcours__label-card-img' }}
          {%- else -%}
            Aperçu Sur-mesure
          {%- endif -%}
        </div>
        <div class="ml-parcours__label-card-title">Sur-mesure</div>
        <div class="ml-parcours__label-card-price">390 €</div>
        <div class="ml-parcours__label-card-for">Pour une identité unique, créée avec nos designers</div>
        <div class="ml-parcours__label-card-desc">Création exclusive avec notre équipe : après la commande, vous transmettez brief, logo, moodboard et inspirations. Allers-retours jusqu'à validation.</div>
        <div class="ml-parcours__label-card-actions">
          <button type="button" class="ml-parcours__label-card-btn" data-select-etiquette data-variant="55418346242382" data-type="Sur-mesure">Choisir Sur-mesure</button>
        </div>
      </div>
      <div class="ml-parcours__label-card" data-mode="import">
        <div class="ml-parcours__label-card-visual">
          {%- if section.settings.card_import_image != blank -%}
            {{ section.settings.card_import_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: 'Aperçu Import', class: 'ml-parcours__label-card-img' }}
          {%- else -%}
            <img src="{{ 'ml-carte-import.jpg' | asset_url }}" alt="Aperçu Import" loading="lazy" width="600" height="600" class="ml-parcours__label-card-img">
          {%- endif -%}
        </div>
        <div class="ml-parcours__label-card-title">J'ai mes étiquettes</div>
        <div class="ml-parcours__label-card-price">Gratuit</div>
        <div class="ml-parcours__label-card-for">Pour celles et ceux qui ont déjà leur design</div>
        <div class="ml-parcours__label-card-desc">Votre design est déjà prêt ? Transmettez vos fichiers (JPEG, PDF ou PNG) après la commande et obtenez un shooting photo pour vos réseaux sociaux et votre site internet !</div>
        <div class="ml-parcours__label-card-actions">
          <button type="button" class="ml-parcours__label-card-btn" data-select-etiquette data-variant="55418312622414" data-type="J'ai mes étiquettes">Choisir cette option</button>
        </div>
      </div>
    </div>

    <div class="ml-parcours__label-note">
      <strong>Et ensuite ?</strong> Après votre commande, votre espace projet s'ouvre : vous y transmettez logo, moodboard et inspirations à nos graphistes, qui créent vos étiquettes. Rien ne part à l'impression sans votre bon à tirer.
    </div>

    <div class="ml-parcours__studio-invite">
      <div class="ml-parcours__studio-invite-text">
        <h3>Envie d'explorer des pistes ?</h3>
        <p>Essayez le MyLab Studio : générez des idées d'étiquettes par IA, librement, pour vous inspirer avant de choisir. Sans engagement — fermez quand vous voulez.</p>
      </div>
      <button type="button" class="ml-parcours__btn ml-parcours__btn--primary" data-open-config="studio">Essayer le MyLab Studio</button>
    </div>

    <div class="ml-parcours__forfait">
      <div class="ml-parcours__forfait-head">
        <h3>Forfait d'impression annuel</h3>
        <span class="ml-parcours__forfait-chip">Inclus selon votre étiquette</span>
      </div>
      <div class="ml-parcours__forfait-pillars">
        <div class="ml-parcours__forfait-pillar">
          <h4>1 an d'impressions illimitées</h4>
          <p>Imprimez à la demande, sans seuil minimum, avec votre design validé.</p>
        </div>
        <div class="ml-parcours__forfait-pillar">
          <h4>Reconduction tacite</h4>
          <p>Renouvelé automatiquement chaque année. Annulable à tout moment.</p>
        </div>
        <div class="ml-parcours__forfait-pillar">
          <h4>Noir & blanc ou couleur</h4>
          <p>99 €/an pour étiquettes noires standards · 250 €/an pour étiquettes couleur.</p>
        </div>
      </div>
    </div>

    <div class="ml-parcours__page-footer">
      <a href="/pages/parcours-produits" class="ml-parcours__page-footer-back">
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M13 5H1m0 0l4-4M1 5l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Retour à l'étape précédente
      </a>
      <a href="/pages/parcours-recap" class="ml-parcours__btn ml-parcours__btn--primary">
        Voir le récap final
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<div class="ml-parcours__modal" id="ml-parcours-config-modal" inert aria-modal="true" aria-label="MyLab Studio">
  <div class="ml-parcours__modal-backdrop" data-close-config></div>
  <div class="ml-parcours__modal-panel">
    <button type="button" class="ml-parcours__modal-close" data-close-config aria-label="Fermer le studio">×</button>
    <iframe class="ml-parcours__modal-iframe" data-config-iframe title="MyLab Studio"></iframe>
  </div>
</div>

<script>
(function(){
  'use strict';

  /* ---- Sélection directe du type d'étiquette (remplace toute étiquette déjà au panier) ---- */
  const selectBtns = Array.prototype.slice.call(document.querySelectorAll('[data-select-etiquette]'));
  const allVariants = selectBtns.map(function(b){ return parseInt(b.dataset.variant, 10); }).filter(Boolean);

  function readCart() {
    return fetch('/cart.js', { credentials: 'same-origin' }).then(function(r){ return r.ok ? r.json() : null; });
  }

  function syncSelected(cart) {
    const inCart = {};
    ((cart && cart.items) || []).forEach(function(it){ inCart[it.variant_id] = true; });
    selectBtns.forEach(function(b){
      const v = parseInt(b.dataset.variant, 10);
      const selected = !!inCart[v];
      const card = b.closest('.ml-parcours__label-card');
      if (card) card.classList.toggle('is-selected', selected);
      b.textContent = selected ? 'Sélectionné ✓' : b.dataset.label;
    });
  }

  function selectEtiquette(btn) {
    const id = parseInt(btn.dataset.variant, 10);
    if (!id) return;
    btn.disabled = true;
    readCart().then(function(cart){
      const items = (cart && cart.items) || [];
      const updates = {};
      items.forEach(function(it){
        if (allVariants.indexOf(it.variant_id) !== -1 && it.variant_id !== id) updates[it.variant_id] = 0;
      });
      const clear = Object.keys(updates).length
        ? fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify({ updates: updates }) })
        : Promise.resolve();
      return clear.then(function(){
        const already = items.some(function(it){ return it.variant_id === id; });
        if (already) return null;
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ items: [{ id: id, quantity: 1, properties: { 'Type étiquette': btn.dataset.type || '' } }] })
        }).then(function(res){ if (!res.ok) throw new Error('cart add failed: ' + res.status); });
      });
    }).then(function(){
      return readCart();
    }).then(function(cart){
      syncSelected(cart);
      document.dispatchEvent(new CustomEvent('cart:refresh'));
    }).catch(function(err){
      console.error('[ml-parcours-etiquette] selection error', err);
    }).then(function(){
      btn.disabled = false;
    });
  }

  selectBtns.forEach(function(b){
    b.dataset.label = b.textContent.trim();
    b.addEventListener('click', function(){ selectEtiquette(b); });
  });
  readCart().then(syncSelected).catch(function(){});

  /* ---- Modale MyLab Studio (inspiration facultative) ---- */
  const modal = document.getElementById('ml-parcours-config-modal');
  if (!modal) return;
  const iframe = modal.querySelector('[data-config-iframe]');
  const allowedOrigin = 'https://mylab-configurateur.vercel.app';

  function openConfig(mode) {
    const parentOrigin = encodeURIComponent(window.location.origin);
    iframe.src = allowedOrigin + '/configurateur?embed=1&mode=' + encodeURIComponent(mode) + '&parentOrigin=' + parentOrigin;
    modal.removeAttribute('inert');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeConfig() {
    modal.classList.remove('is-open');
    modal.setAttribute('inert', '');
    iframe.src = 'about:blank';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-open-config]').forEach(function(btn){
    btn.addEventListener('click', function(){ openConfig(btn.dataset.openConfig); });
  });

  document.querySelectorAll('[data-close-config]').forEach(function(el){
    el.addEventListener('click', closeConfig);
  });

  /* Un design finalisé dans le Studio reste possible : il rejoint le panier comme étiquette. */
  window.addEventListener('message', function(event){
    if (event.origin !== allowedOrigin) return;
    if (!event.data || event.data.type !== 'design:ready') return;
    const variantId = event.data.variantId;
    const reference = event.data.reference;
    const templateName = event.data.templateName;
    const previewImageUrl = event.data.previewImageUrl;
    const logoUrl = event.data.logoUrl;
    const rangeNames = event.data.rangeNames;
    if (!variantId) return;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({
        items: [{
          id: parseInt(variantId, 10),
          quantity: 1,
          properties: {
            'Référence design': reference || '',
            'Modèle': templateName || '',
            'Aperçu': previewImageUrl || '',
            'Logo': logoUrl || '',
            'Gammes': (rangeNames || []).join(', ')
          }
        }]
      })
    }).catch(function(err){
      console.error('[ml-parcours-etiquette] design:ready add error', err);
    }).then(function(){
      closeConfig();
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      readCart().then(syncSelected).catch(function(){});
    });
  });
})();
</script>

{% schema %}
{
  "name": "Parcours · Étiquette",
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Titre", "default": "<p>L'identité de votre <em>flacon</em>.</p>" },
    { "type": "textarea", "id": "lede", "label": "Sous-titre", "default": "Choisissez comment naîtront vos étiquettes — un clic suffit, votre panier se remplit. Le design se crée ensuite avec nos graphistes, après votre commande." },
    { "type": "product", "id": "modele_default_product", "label": "Produit modèle par défaut (Modèles card)" },
    { "type": "header", "content": "Miniatures aperçu (4 cards)" },
    { "type": "image_picker", "id": "card_standard_image", "label": "Image Aperçu Standard" },
    { "type": "image_picker", "id": "card_template_image", "label": "Image Aperçu Modèles" },
    { "type": "image_picker", "id": "card_studio_image", "label": "Image Aperçu Sur-mesure" },
    { "type": "image_picker", "id": "card_import_image", "label": "Image Aperçu Import (J'ai mes étiquettes)" }
  ],
  "presets": [{ "name": "Parcours · Étiquette" }]
}
{% endschema %}
