{%- style -%}
  .ml-perso-config {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
  }
  .ml-perso-config__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .ml-perso-config__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .ml-perso-config__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
    margin-bottom: 0.8rem;
  }
  .ml-perso-config__heading {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.8rem;
  }
  .ml-perso-config__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.4rem;
    color: {{ section.settings.muted_color }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Product grid */
  .ml-perso-products {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 2rem;
  }
  .ml-perso-product {
    position: relative;
    background: {{ section.settings.card_bg }};
    border: 1px solid #E5E5E5;
    border-radius: 1.6rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s, box-shadow 0.3s;
    display: flex;
    flex-direction: column;
  }
  .ml-perso-product:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .ml-perso-product__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: {{ section.settings.card_bg }};
    overflow: hidden;
  }
  .ml-perso-product__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .ml-perso-product:hover .ml-perso-product__image {
    transform: scale(1.04);
  }
  .ml-perso-product__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 50px;
  }
  .ml-perso-product__info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .ml-perso-product__name {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }
  .ml-perso-product__type {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    color: {{ section.settings.muted_color }};
    margin: 0;
  }
  .ml-perso-product__price {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    margin: 0;
  }
  .ml-perso-product__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 1.5rem 1.5rem;
    padding: 12px 20px;
    background: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 2px solid {{ section.settings.text_color }};
    border-radius: 50px;
    transition: all 0.25s;
    text-decoration: none;
  }
  .ml-perso-product:hover .ml-perso-product__cta {
    background: transparent;
    color: {{ section.settings.text_color }};
  }
  .ml-perso-product__cta svg {
    width: 1.6rem;
    height: 1.6rem;
    flex-shrink: 0;
  }

  /* Empty state */
  .ml-perso-products__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    color: {{ section.settings.muted_color }};
    font-family: 'DM Sans', sans-serif;
    font-size: 1.4rem;
  }

  @media screen and (max-width: 749px) {
    .ml-perso-config {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    .ml-perso-products {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }
    .ml-perso-product__info {
      padding: 1rem;
    }
    .ml-perso-product__name {
      font-size: 1.3rem;
    }
    .ml-perso-product__cta {
      margin: 0 1rem 1rem;
      padding: 10px 16px;
      font-size: 1.1rem;
    }
  }
{%- endstyle -%}

<div class="ml-perso-config">
  <div class="ml-perso-config__inner">
    {%- if section.settings.heading != blank -%}
      <div class="ml-perso-config__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ml-perso-config__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="ml-perso-config__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="ml-perso-config__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ml-perso-products" id="ml-zakeke-products">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.products_limit -%}
          <a href="{{ product.url }}" class="ml-perso-product">
            <div class="ml-perso-product__image-wrap">
              {%- if product.featured_image != blank -%}
                <img
                  class="ml-perso-product__image"
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  width="300"
                  height="300"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'ml-perso-product__image' }}
              {%- endif -%}
              <span class="ml-perso-product__badge">{{ section.settings.badge_text }}</span>
            </div>
            <div class="ml-perso-product__info">
              <h3 class="ml-perso-product__name">{{ product.title }}</h3>
              {%- if product.type != blank -%}
                <p class="ml-perso-product__type">{{ product.type }}</p>
              {%- endif -%}
              <p class="ml-perso-product__price">{{ product.price | money }}</p>
            </div>
            <span class="ml-perso-product__cta">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
              </svg>
              {{ section.settings.cta_label }}
            </span>
          </a>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback: manual blocks when no collection is selected -->
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <a href="{{ block.settings.link }}" class="ml-perso-product" {{ block.shopify_attributes }}>
              <div class="ml-perso-product__image-wrap">
                {%- if block.settings.image != blank -%}
                  <img
                    class="ml-perso-product__image"
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.title | escape }}"
                    width="300"
                    height="300"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'ml-perso-product__image' }}
                {%- endif -%}
                <span class="ml-perso-product__badge">{{ section.settings.badge_text }}</span>
              </div>
              <div class="ml-perso-product__info">
                <h3 class="ml-perso-product__name">{{ block.settings.title }}</h3>
                {%- if block.settings.subtitle != blank -%}
                  <p class="ml-perso-product__type">{{ block.settings.subtitle }}</p>
                {%- endif -%}
                {%- if block.settings.price != blank -%}
                  <p class="ml-perso-product__price">{{ block.settings.price }}</p>
                {%- endif -%}
              </div>
              <span class="ml-perso-product__cta">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
                </svg>
                {{ section.settings.cta_label }}
              </span>
            </a>
          {%- endfor -%}
        {%- else -%}
          <p class="ml-perso-products__empty">Sélectionnez une collection de produits personnalisables dans les paramètres de la section.</p>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Perso — Produits",
  "tag": "section",
  "class": "ml-perso-config-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "PERSONNALISER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Choisissez votre produit"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Sélectionnez un produit et personnalisez son étiquette avec votre identité de marque."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection de produits personnalisables"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Nombre de produits",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Colonnes",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge sur les cartes",
      "default": "Personnalisable"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "Personnaliser"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Couleur texte secondaire",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#F5F4F2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product_manual",
      "name": "Produit (manuel)",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Nom du produit",
          "default": "Crème Volume"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Type / sous-titre",
          "default": "Soin capillaire"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Prix",
          "default": "À partir de 7,00 €"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien vers le produit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perso — Produits"
    }
  ]
}
{% endschema %}
