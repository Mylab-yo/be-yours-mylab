{%- comment -%}
  Bastien Chat Widget — bulle flottante en bas à droite du site MY.LAB.
  L'utilisateur clique sur l'icône WhatsApp, s'ouvre une fenêtre de chat
  avec Bastien (assistant IA MY.LAB).

  Backend : https://chat.mylab-shop.com/public-chat (bastien-svc, VPS)
  Pas de dépendance JS externe. Pure vanilla.
{%- endcomment -%}

<style>
  .bastien-launcher {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #25D366; /* WhatsApp green */
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    border: none;
  }
  .bastien-launcher:hover {
    transform: scale(1.06);
    box-shadow: 0 6px 22px rgba(0,0,0,0.24);
  }
  .bastien-launcher svg {
    width: 32px;
    height: 32px;
    fill: #fff;
  }

  .bastien-panel {
    position: fixed;
    bottom: 100px;
    right: 24px;
    width: 380px;
    max-width: calc(100vw - 32px);
    height: 600px;
    max-height: calc(100vh - 130px);
    background: #faf6f0; /* cream MY.LAB */
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.22);
    display: none;
    flex-direction: column;
    z-index: 9999;
    overflow: hidden;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }
  .bastien-panel.open {
    display: flex;
    animation: bastien-slide-up 0.22s ease;
  }
  @keyframes bastien-slide-up {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .bastien-header {
    padding: 16px 18px;
    background: #1a1a1a; /* ink MY.LAB */
    color: #faf6f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bastien-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .bastien-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 18px;
  }
  .bastien-title {
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
  }
  .bastien-subtitle {
    font-size: 12px;
    opacity: 0.7;
    line-height: 1.2;
    margin-top: 2px;
  }
  .bastien-close {
    background: transparent;
    border: none;
    color: #faf6f0;
    cursor: pointer;
    font-size: 22px;
    line-height: 1;
    padding: 4px 8px;
    opacity: 0.7;
  }
  .bastien-close:hover { opacity: 1; }

  .bastien-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .bastien-msg {
    max-width: 82%;
    padding: 10px 14px;
    border-radius: 14px;
    line-height: 1.45;
    font-size: 14px;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .bastien-msg a { color: inherit; text-decoration: underline; }
  .bastien-msg.user {
    background: #1a1a1a;
    color: #faf6f0;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .bastien-msg.bot {
    background: #fff;
    color: #1a1a1a;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
  .bastien-msg.system {
    background: transparent;
    color: rgba(0,0,0,0.5);
    align-self: center;
    font-size: 12px;
    font-style: italic;
    max-width: 100%;
    text-align: center;
  }
  .bastien-typing {
    display: flex;
    gap: 4px;
    padding: 12px 14px;
    background: #fff;
    border-radius: 14px;
    border-bottom-left-radius: 4px;
    align-self: flex-start;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
  .bastien-typing span {
    width: 7px; height: 7px;
    background: #1a1a1a;
    border-radius: 50%;
    opacity: 0.3;
    animation: bastien-bounce 1.4s infinite;
  }
  .bastien-typing span:nth-child(2) { animation-delay: 0.2s; }
  .bastien-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bastien-bounce {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-3px); }
  }

  .bastien-input-row {
    padding: 12px;
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex;
    gap: 8px;
  }
  .bastien-input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 24px;
    font-family: inherit;
    font-size: 16px; /* 16px+ pour éviter zoom auto iOS */
    outline: none;
    background: #faf6f0;
    -webkit-appearance: none;
  }
  .bastien-input:focus { border-color: #1a1a1a; }
  .bastien-send {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #faf6f0;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .bastien-send:hover { background: #25D366; }
  .bastien-send:disabled { opacity: 0.4; cursor: not-allowed; }
  .bastien-send svg { width: 18px; height: 18px; fill: currentColor; }

  .bastien-footer {
    padding: 6px 12px;
    text-align: center;
    font-size: 11px;
    color: rgba(0,0,0,0.45);
    background: #fff;
  }

  /* === MOBILE / SMALL TABLET === */
  @media (max-width: 768px) {
    .bastien-launcher {
      /* Lifted above the mobile dock so it doesn't overlap the rightmost item (Compte). */
      bottom: calc(var(--mobile-dock-height, 72px) + 12px);
      right: 12px;
      width: 52px;
      height: 52px;
    }
    .bastien-launcher svg { width: 26px; height: 26px; }

    .bastien-panel {
      bottom: 0;
      right: 0;
      left: 0;
      top: 0;
      width: 100%;
      max-width: 100%;
      height: 100vh;
      height: 100dvh; /* dynamic vh = correctement ajusté avec barre browser mobile */
      max-height: 100dvh;
      border-radius: 0;
      padding-top: env(safe-area-inset-top, 0px);
      padding-bottom: env(safe-area-inset-bottom, 0px);
      box-sizing: border-box;
    }
    .bastien-header {
      padding: 14px 16px;
      padding-top: max(14px, env(safe-area-inset-top, 14px));
    }
    .bastien-messages {
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
      padding: 12px;
    }
    .bastien-msg { font-size: 15px; max-width: 88%; }
    .bastien-input-row {
      padding: 10px 12px;
      padding-bottom: max(10px, env(safe-area-inset-bottom, 10px));
    }
    .bastien-send { width: 44px; height: 44px; } /* tap target Apple HIG */
    .bastien-close { padding: 8px 12px; font-size: 26px; } /* easier tap */
    .bastien-footer { display: none; } /* gain de place */
  }

  /* Quand le chat est ouvert sur mobile, lock body scroll */
  body.bastien-open { overflow: hidden; position: fixed; width: 100%; }
  @media (min-width: 769px) {
    body.bastien-open { position: static; overflow: auto; } /* desktop : scroll OK */
  }
</style>

<button id="bastien-launcher" class="bastien-launcher" aria-label="Ouvrir le chat MY.LAB" type="button">
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
  </svg>
</button>

<div id="bastien-panel" class="bastien-panel" role="dialog" aria-labelledby="bastien-title-text">
  <div class="bastien-header">
    <div class="bastien-header-info">
      <div class="bastien-avatar">B</div>
      <div>
        <div class="bastien-title" id="bastien-title-text">Bastien · MY.LAB</div>
        <div class="bastien-subtitle">Assistant en ligne</div>
      </div>
    </div>
    <button class="bastien-close" id="bastien-close" aria-label="Fermer le chat" type="button">×</button>
  </div>
  <div class="bastien-messages" id="bastien-messages" aria-live="polite"></div>
  <form class="bastien-input-row" id="bastien-form" autocomplete="off">
    <input type="text" class="bastien-input" id="bastien-input" placeholder="Écrivez votre message…" maxlength="2000" required>
    <button type="submit" class="bastien-send" id="bastien-send" aria-label="Envoyer">
      <svg viewBox="0 0 24 24"><path d="M2.01 21l20.99-9L2.01 3l-.01 7 15 2-15 2z"/></svg>
    </button>
  </form>
  <div class="bastien-footer">Propulsé par MY.LAB · Vos messages sont confidentiels</div>
</div>

<script>
(function() {
  'use strict';

  const API_URL = 'https://chat.mylab-shop.com/public-chat';
  const STORAGE_SESSION = 'bastien_session_id';
  const STORAGE_HISTORY = 'bastien_history_v1';
  const STORAGE_OPENED  = 'bastien_was_opened';
  const MAX_HISTORY = 60;

  // === Session ID (UUID v4) persistant ===
  function getOrCreateSession() {
    let sid = localStorage.getItem(STORAGE_SESSION);
    if (!sid) {
      sid = (crypto.randomUUID && crypto.randomUUID()) || _fallbackUuid();
      localStorage.setItem(STORAGE_SESSION, sid);
    }
    return sid;
  }
  function _fallbackUuid() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
      const r = Math.random() * 16 | 0;
      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
    });
  }

  // === DOM refs ===
  const launcher = document.getElementById('bastien-launcher');
  const panel    = document.getElementById('bastien-panel');
  const closeBtn = document.getElementById('bastien-close');
  const form     = document.getElementById('bastien-form');
  const input    = document.getElementById('bastien-input');
  const sendBtn  = document.getElementById('bastien-send');
  const msgsEl   = document.getElementById('bastien-messages');

  // === History rendering ===
  function loadHistory() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_HISTORY) || '[]');
    } catch (e) { return []; }
  }
  function saveHistory(arr) {
    const trimmed = arr.slice(-MAX_HISTORY);
    try { localStorage.setItem(STORAGE_HISTORY, JSON.stringify(trimmed)); } catch (e) {}
  }
  function renderMessage(role, text) {
    const el = document.createElement('div');
    el.className = 'bastien-msg ' + role;
    // Linkify URLs
    const escaped = text.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    el.innerHTML = escaped.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener">$1</a>');
    msgsEl.appendChild(el);
    msgsEl.scrollTop = msgsEl.scrollHeight;
  }
  function showTyping() {
    const el = document.createElement('div');
    el.className = 'bastien-typing';
    el.id = 'bastien-typing-indicator';
    el.innerHTML = '<span></span><span></span><span></span>';
    msgsEl.appendChild(el);
    msgsEl.scrollTop = msgsEl.scrollHeight;
  }
  function hideTyping() {
    const el = document.getElementById('bastien-typing-indicator');
    if (el) el.remove();
  }

  // === Open / close ===
  let _bodyScrollY = 0;
  function isMobile() { return window.matchMedia('(max-width: 768px)').matches; }

  function openPanel() {
    panel.classList.add('open');
    launcher.style.display = 'none';
    if (isMobile()) {
      _bodyScrollY = window.scrollY;
      document.body.classList.add('bastien-open');
      document.body.style.top = '-' + _bodyScrollY + 'px';
    }
    // Focus seulement en desktop (sur mobile ça force l'ouverture du clavier non désirée)
    if (!isMobile()) input.focus();
    if (!localStorage.getItem(STORAGE_OPENED)) {
      localStorage.setItem(STORAGE_OPENED, '1');
      renderMessage('bot', "Bonjour 👋 Je suis Bastien, l'assistant MY.LAB. Comment puis-je vous aider ?");
      const hist = loadHistory();
      hist.push({ role: 'bot', text: "Bonjour 👋 Je suis Bastien, l'assistant MY.LAB. Comment puis-je vous aider ?" });
      saveHistory(hist);
    }
    // Force scroll messages au bas (utile au re-open)
    setTimeout(() => { msgsEl.scrollTop = msgsEl.scrollHeight; }, 50);
  }
  function closePanel() {
    panel.classList.remove('open');
    launcher.style.display = 'flex';
    if (document.body.classList.contains('bastien-open')) {
      document.body.classList.remove('bastien-open');
      document.body.style.top = '';
      window.scrollTo(0, _bodyScrollY);
    }
  }

  // Si le clavier mobile s'ouvre/ferme, garde le scroll en bas des messages
  if (window.visualViewport) {
    window.visualViewport.addEventListener('resize', function() {
      if (panel.classList.contains('open')) {
        setTimeout(() => { msgsEl.scrollTop = msgsEl.scrollHeight; }, 100);
      }
    });
  }

  // === Send message ===
  async function sendMessage(text) {
    const sid = getOrCreateSession();
    renderMessage('user', text);
    const hist = loadHistory();
    hist.push({ role: 'user', text });
    saveHistory(hist);

    sendBtn.disabled = true;
    showTyping();

    try {
      const r = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ session_id: sid, message: text }),
      });
      hideTyping();

      if (!r.ok) {
        renderMessage('bot', "Désolé, je rencontre un souci technique. Réessayez dans un instant.");
        return;
      }

      const data = await r.json();

      if (data.reply) {
        renderMessage('bot', data.reply);
        hist.push({ role: 'bot', text: data.reply });
        saveHistory(hist);
      } else if (data.handoff) {
        renderMessage('system', "✓ Yoann a été notifié, il revient vers vous rapidement.");
      } else if (data.needs_otp) {
        // Le code a été envoyé par email — pas affiché ici
        renderMessage('bot', "Je vous ai envoyé un code à 6 chiffres à " + data.needs_otp.email + ". Donnez-le moi pour confirmer.");
      }

      if (data.handoff && data.reply == null) {
        // Fallback : pas de reply mais handoff seul → message générique déjà affiché ci-dessus
      }
    } catch (e) {
      hideTyping();
      renderMessage('bot', "Connexion impossible. Vérifiez votre internet et réessayez.");
    } finally {
      sendBtn.disabled = false;
      input.focus();
    }
  }

  // === Events ===
  launcher.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  form.addEventListener('submit', e => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    sendMessage(text);
  });

  // === Replay history on init ===
  document.addEventListener('DOMContentLoaded', function() {
    const hist = loadHistory();
    hist.forEach(m => renderMessage(m.role, m.text));
  });
})();
</script>
