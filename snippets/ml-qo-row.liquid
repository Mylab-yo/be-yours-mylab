{%- comment -%}
  Snippet: ml-qo-row.liquid
  Renders a single product row in the quick order table.
  Arguments: qo_product, qo_tier_data (optional — JS populates from product map), qo_format
{%- endcomment -%}

<tr data-variant-id="{{ qo_product.variants.first.id }}"
    data-handle="{{ qo_product.handle }}"
    {% if qo_tier_data != blank %}data-tier-data="{{ qo_tier_data }}"{% endif %}
    style="{% if qo_tier_data == blank %}display:none{% endif %}">
  <td class="ml-qo__check">
    <input type="checkbox" aria-label="Sélectionner {{ qo_product.title | escape }}">
  </td>
  <td>
    <div class="ml-qo__product">
      {%- if qo_product.featured_image -%}
        <img
          class="ml-qo__product-img"
          src="{{ qo_product.featured_image | image_url: width: 100 }}"
          alt="{{ qo_product.featured_image.alt | escape }}"
          width="50"
          height="50"
          loading="lazy"
        >
      {%- endif -%}
      <div>
        <div class="ml-qo__product-name">{{ qo_product.title }}</div>
        <div class="ml-qo__product-variant">{% if qo_format != blank %}{{ qo_format }}ml{% endif %}</div>
      </div>
    </div>
  </td>
  <td>
    <div class="ml-qo__select-wrap">
      <select class="ml-qo__select" data-qo-qty>
        <option value="0">—</option>
        {%- if qo_tier_data != blank -%}
          {%- assign tiers = qo_tier_data | split: ',' -%}
          {%- for tier in tiers -%}
            {%- assign parts = tier | split: ':' -%}
            <option value="{{ parts[0] }}" data-price="{{ parts[1] }}">{{ parts[0] }} unités</option>
          {%- endfor -%}
        {%- endif -%}
      </select>
    </div>
  </td>
  <td class="ml-qo__price">
    <span data-qo-unit>—</span>
    <div class="ml-qo__price-unit">€ HT</div>
  </td>
  <td class="ml-qo__price">
    <span data-qo-line>—</span>
    <div class="ml-qo__price-unit">€ HT</div>
  </td>
</tr>
