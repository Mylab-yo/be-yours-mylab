{% comment %}
  MY.LAB — Étape 4 : Quantité et calcul de prix
  snippets/bulk-step-quantity.liquid
  Peuplé dynamiquement par bulk-order.js
{% endcomment %}

<div class="bulk-quantity" id="bulk-quantity">
  <h2 class="bulk-step__title">Quantités et tarifs</h2>
  <p class="bulk-step__desc">Indiquez la quantité souhaitée pour chaque formule. Minimum 50 kg par référence.</p>

  <div class="bulk-quantity__list" id="bulk-quantity-list"></div>

  {%- comment -%} Total général {%- endcomment -%}
  <div class="bulk-quantity__grand-total" id="bulk-quantity-grand-total">
    <div class="bulk-quantity__grand-total-row">
      <span class="bulk-quantity__grand-total-label">Total général HT</span>
      <span class="bulk-quantity__grand-total-value" id="bulk-quantity-grand-value">0,00 €</span>
    </div>
    <div class="bulk-quantity__grand-total-sub" id="bulk-quantity-grand-units">0 flacons au total</div>
  </div>

  {%- comment -%} Notes {%- endcomment -%}
  <div class="bulk-quantity__notes">
    <div class="bulk-quantity__note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      Marge de production et/ou de conditionnement : +/- 3%
    </div>
    <div class="bulk-quantity__note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      Délai de mise à disposition : 6 à 8 semaines
    </div>
    <div class="bulk-quantity__note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
      Conditions de règlement : 50% à la commande — 50% au départ marchandise
    </div>
    <div class="bulk-quantity__note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      Prix HT départ de nos entrepôts — transport à votre charge
    </div>
  </div>
</div>
