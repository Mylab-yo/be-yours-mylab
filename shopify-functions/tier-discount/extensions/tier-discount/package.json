{
  "name": "tier-discount",
  "version": "1.0.0",
  "description": "MyLab Tier Discount Function — applique les tarifs paliers MY.LAB au checkout depuis ml-product-map.json",
  "type": "module",
  "scripts": {
    "build": "shopify-function build",
    "preview": "shopify app function run",
    "typegen": "shopify app function typegen",
    "deploy": "shopify app deploy"
  },
  "codegen": {
    "schema": "schema.graphql",
    "documents": ["src/**/*.graphql"],
    "generates": {
      "generated/api.ts": {
        "plugins": ["@shopify/shopify_function/typegen"]
      }
    }
  },
  "devDependencies": {
    "@shopify/shopify_function": "^1.0.0"
  }
}
